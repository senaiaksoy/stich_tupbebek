# Auto-normalize line endings
* text=auto
*.html text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.astro text eol=lf
*.css text eol=lf
*.md text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
