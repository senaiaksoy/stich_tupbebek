---
interface Props {
  items: Array<{
    href: string;
    icon: string;
    title: string;
    description: string;
  }>;
}

const { items } = Astro.props;
---

<section class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
  <h2 class="font-headline text-2xl text-on-surface mb-6">Bunları da Okuyun</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item) => (
      <a href={item.href} class="border rounded-xl p-6 hover:shadow-lg transition-shadow block">
        <span class="material-symbols-outlined text-primary mb-2">{item.icon}</span>
        <h3 class="font-bold text-on-surface text-sm">{item.title}</h3>
        <p class="text-xs text-on-surface-variant mt-1">{item.description}</p>
      </a>
    ))}
  </div>
</section>

<style>
  p {
    margin: 0;
  }
</style>
