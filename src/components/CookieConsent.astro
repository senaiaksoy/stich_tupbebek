---
interface Props {
  version?: string;
}

const { version = "1.0" } = Astro.props;
---

<div
  id="cookie-consent"
  class="fixed bottom-0 left-0 right-0 bg-surface-container-low border-t border-outline p-4 md:p-6 shadow-2xl z-50"
  role="alertdialog"
  aria-labelledby="cookie-title"
  aria-describedby="cookie-description"
>
  <div class="max-w-5xl mx-auto px-4 md:px-8">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <div class="flex-1">
        <h3 id="cookie-title" class="font-bold text-on-surface mb-2">Çerez Kullanımı</h3>
        <p id="cookie-description" class="text-sm text-on-surface-variant">
          Web sitesinin işlevselliğini sağlamak ve kullanıcı deneyimini iyileştirmek için çerezler kullanıyoruz.
          <a href="/cerez-politikasi" class="text-primary hover:underline">Çerez Politikasını</a> inceleyebilirsiniz.
        </p>
      </div>
      <div class="flex gap-3 flex-shrink-0">
        <button
          id="cookie-reject"
          class="px-4 py-2 rounded-lg border border-outline text-on-surface hover:bg-surface-container transition-colors text-sm font-medium"
        >
          Reddet
        </button>
        <button
          id="cookie-accept"
          class="px-4 py-2 rounded-lg bg-primary text-on-primary hover:opacity-90 transition-opacity text-sm font-medium"
        >
          Kabul Et
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ version }}>
  // Check if consent was already given
  const consentKey = `cookie-consent-v${version}`;
  const hasConsent = localStorage.getItem(consentKey);

  if (hasConsent) {
    document.getElementById('cookie-consent').style.display = 'none';
  }

  document.getElementById('cookie-accept').addEventListener('click', () => {
    localStorage.setItem(consentKey, 'accepted');
    document.getElementById('cookie-consent').style.display = 'none';
  });

  document.getElementById('cookie-reject').addEventListener('click', () => {
    localStorage.setItem(consentKey, 'rejected');
    document.getElementById('cookie-consent').style.display = 'none';
  });
</script>

<style>
  p {
    margin: 0;
  }
</style>
