---
/**
 * ReferenceList — Bilimsel referans/kaynak listesi
 *
 * Makale iceriginin altinda bilimsel kaynaklari numarali
 * liste halinde gosterir. DOI ve URL linkleri iceriri.
 *
 * Kullanim:
 *   <ReferenceList references={entry.data.references} />
 */
interface Reference {
    title: string;
    authors?: string;
    journal?: string;
    year?: number;
    url?: string;
    doi?: string;
}

interface Props {
    references: Reference[];
}

const { references } = Astro.props;
---

{references && references.length > 0 && (
    <section class="mt-12 pt-8 border-t border-gray-200" aria-label="Bilimsel kaynaklar">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary-600 text-xl">science</span>
            </div>
            <div>
                <h3 class="font-headline text-lg font-bold text-gray-900">Bilimsel Kaynaklar</h3>
                <p class="text-xs text-gray-500">{references.length} referans</p>
            </div>
        </div>

        <ol class="space-y-3 list-none">
            {references.map((ref, i) => (
                <li class="flex gap-3 text-sm group">
                    <span class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center shrink-0 text-xs font-bold text-gray-500 mt-0.5 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                        {i + 1}
                    </span>
                    <div class="min-w-0">
                        <p class="text-gray-800 leading-relaxed">
                            {ref.authors && <span class="text-gray-500">{ref.authors}. </span>}
                            <span class="font-semibold">{ref.title}</span>
                            {ref.journal && <span class="italic text-gray-500">. {ref.journal}</span>}
                            {ref.year && <span class="text-gray-500"> ({ref.year})</span>}
                        </p>
                        <div class="flex items-center gap-3 mt-1">
                            {ref.doi && (
                                <a
                                    href={`https://doi.org/${ref.doi}`}
                                    class="inline-flex items-center gap-1 text-xs text-primary-600 hover:text-primary-700 font-semibold transition-colors"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <span class="material-symbols-outlined text-[12px]">link</span>
                                    DOI: {ref.doi}
                                </a>
                            )}
                            {ref.url && !ref.doi && (
                                <a
                                    href={ref.url}
                                    class="inline-flex items-center gap-1 text-xs text-primary-600 hover:text-primary-700 font-semibold transition-colors"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <span class="material-symbols-outlined text-[12px]">open_in_new</span>
                                    Kaynak
                                </a>
                            )}
                        </div>
                    </div>
                </li>
            ))}
        </ol>
    </section>
)}
