---
/**
 * OptimizedImage Component
 * Renders optimized responsive images with proper presets
 *
 * Usage:
 * <OptimizedImage src="/images/hero.jpg" type="hero" alt="Hero section" />
 * <OptimizedImage src="/images/avatar.jpg" type="avatar" alt="Doctor profile" className="rounded-full" />
 */

import { IMAGE_PRESETS, type ImageType } from '../utils/imageOptimization';

interface Props {
  src: string;
  type: ImageType;
  alt: string;
  className?: string;
  title?: string;
  style?: Record<string, string | number>;
}

const { src, type, alt, className = '', title, style } = Astro.props;
const preset = IMAGE_PRESETS[type];

// Generate srcset for responsive images
const baseSrc = src.replace(/\.[^/.]+$/, '');
const ext = src.match(/\.[^/.]+$/)?.[0] || '.jpg';
const srcset = `${src} 1x, ${baseSrc}@2x${ext} 2x`;

// Generate WebP sources
const webpSrcset = `${baseSrc}.webp 1x, ${baseSrc}@2x.webp 2x`;

const computedStyle = {
  aspectRatio: `${preset.width}/${preset.height}`,
  ...style,
};
---

<picture>
  <!-- WebP format for modern browsers (better compression) -->
  <source
    srcset={webpSrcset}
    type="image/webp"
    sizes={preset.sizes}
  />

  <!-- Fallback to original format -->
  <source
    srcset={srcset}
    type={`image/${ext.toLowerCase().replace('.', '')}`}
    sizes={preset.sizes}
  />

  <!-- Fallback img tag with optimization attributes -->
  <img
    src={src}
    alt={alt}
    title={title}
    loading={preset.loading}
    fetchpriority={preset.fetchpriority || 'auto'}
    decoding="async"
    width={preset.width}
    height={preset.height}
    class={className}
    style={computedStyle}
  />
</picture>
