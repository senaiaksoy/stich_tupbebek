---
// SearchAutocomplete.astro
// Search component with autocomplete suggestions
// Usage: <SearchAutocomplete searchData={allArticles} />

export interface SearchItem {
  id: string;
  title: string;
  description?: string;
  url: string;
  category?: string;
  type?: 'article' | 'guide' | 'question';
}

export interface Props {
  searchData: SearchItem[];
  placeholder?: string;
  position?: 'modal' | 'dropdown';
  maxResults?: number;
  categoryFilter?: string | null;
}

const {
  searchData = [],
  placeholder = 'Rehberlerde ara...',
  position = 'modal',
  maxResults = 8
} = Astro.props;

// Generate JSON data for client-side search
const jsonData = JSON.stringify(searchData);
---

<!-- Search Button (for modal/overlay) -->
<button id="search-trigger"
        class="p-2 text-slate-500 hover:text-primary hover:bg-slate-50
               rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-primary"
        aria-label="Search">
  <span class="material-symbols-outlined">search</span>
</button>

<!-- Search Modal/Overlay -->
<div id="search-modal"
     class="hidden fixed inset-0 z-[1000] bg-black/50 backdrop-blur-sm
            transition-all duration-300 opacity-0 invisible"
     onclick="if(event.target === this) document.getElementById('search-modal').classList.add('hidden')">

  <div class="relative h-full flex items-start justify-center pt-20">
    <!-- Search Container -->
    <div class="w-full max-w-2xl mx-4 glass-card rounded-3xl shadow-2xl overflow-hidden
                transform transition-all duration-500 scale-95 opacity-0 active-modal:scale-100 active-modal:opacity-100">

      <!-- Search Input Wrapper with Focus Glow -->
      <div class="relative p-6 border-b border-slate-100/50 bg-white/40">
        <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-secondary/20 blur opacity-0 transition-opacity duration-500 group-focus-within:opacity-100"></div>
        <div class="relative flex items-center gap-4">
          <span class="text-primary animate-pulse-soft">
            <span class="material-symbols-outlined text-3xl">search_spark</span>
          </span>
          <input
            id="search-input"
            type="search"
            placeholder={placeholder}
            class="w-full bg-transparent text-xl font-bold text-slate-800 placeholder-slate-400 focus:outline-none"
            autocomplete="off"
            aria-label="Search articles and guides"
            aria-describedby="search-results-label" />

          <!-- Clear button -->
          <button
            id="search-clear"
            class="text-slate-400 hover:text-primary transition-colors hidden"
            aria-label="Clear search">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
      </div>

      <!-- Search Results Area -->
      <div id="search-results"
           class="max-h-[65vh] overflow-y-auto bg-white/30 backdrop-blur-md"
           role="region"
           aria-live="polite"
           aria-label="Search results">

        <!-- Loading state -->
        <div id="search-loading"
             class="p-12 text-center text-slate-500 hidden">
          <div class="inline-block w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin mb-4"></div>
          <p class="font-bold tracking-tight">Klinik veri taranıyor...</p>
        </div>

        <!-- Initial state -->
        <div id="search-initial"
             class="p-12 text-center text-slate-400">
           <div class="w-20 h-20 bg-primary/5 rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="material-symbols-outlined text-primary/40 text-5xl">manage_search</span>
           </div>
          <p class="font-extrabold text-slate-900 mb-2">Nasıl yardımcı olabiliriz?</p>
          <p class="text-sm max-w-xs mx-auto">Tanı süreçleri, tedavi protokolleri veya makaleler arasında arama yapın.</p>
        </div>

        <!-- Results list -->
        <ul id="search-results-list" class="p-4 space-y-2"></ul>

        <!-- No results -->
        <div id="search-no-results"
             class="p-12 text-center text-slate-500 hidden">
          <span class="material-symbols-outlined text-6xl block mb-4 opacity-20">sentiment_neutral</span>
          <p class="font-extrabold text-slate-900">Aradığınızı bulamadık</p>
          <p class="text-sm mt-2">Daha genel terimler kullanmayı deneyin (örn: "tüp bebek", "rezerv").</p>
        </div>
      </div>

      <!-- Footer Help -->
      <div class="px-6 py-4 bg-slate-50/80 backdrop-blur-sm border-t border-slate-100 flex items-center justify-between">
        <span id="search-count" class="text-xs font-bold text-slate-400 uppercase tracking-widest hidden">
          Bulunan: <span class="text-primary">0</span> protokol
        </span>
        <div class="ml-auto flex items-center gap-3">
          <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white border border-slate-200 rounded shadow-sm text-[10px] font-bold text-slate-500">
             <span class="material-symbols-outlined text-[14px]">keyboard_return</span>
             Seç
          </div>
          <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white border border-slate-200 rounded shadow-sm text-[10px] font-bold text-slate-500">
             <kbd class="tracking-tighter">ESC</kbd>
             Kapat
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Smooth scrolling for results */
  #search-results {
    scroll-behavior: smooth;
  }

  /* Highlight matched text */
  .search-highlight {
    background-color: rgba(53, 97, 143, 0.15);
    color: #35618f;
    font-weight: 800;
    padding: 0 2px;
    border-radius: 2px;
  }

  /* Staggered result items */
  .search-result-item {
    opacity: 0;
    transform: translateY(10px);
    animation: slideInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Modal transition helper */
  #search-modal.modal-active .glass-card {
    transform: scale(1);
    opacity: 1;
  }
</style>

<script define:vars={{ searchData, maxResults }}>
  const modal = document.getElementById('search-modal');
  const trigger = document.getElementById('search-trigger');
  const input = document.getElementById('search-input');
  const clearBtn = document.getElementById('search-clear');
  const resultsList = document.getElementById('search-results-list');
  const initialState = document.getElementById('search-initial');
  const loadingState = document.getElementById('search-loading');
  const noResults = document.getElementById('search-no-results');
  const searchCount = document.getElementById('search-count');
  const resultsContainer = document.getElementById('search-results');

  // Debounce search
  let searchTimeout;
  const debounceDelay = 200;

  // Open modal
  trigger?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    setTimeout(() => {
      modal?.classList.remove('opacity-0', 'invisible');
      modal?.classList.add('modal-active'); // For glass-card animation
      input?.focus();
    }, 10);
  });

  // Close modal
  function closeModal() {
    modal?.classList.add('opacity-0', 'invisible');
    modal?.classList.remove('modal-active');
    setTimeout(() => modal?.classList.add('hidden'), 300);
    input.value = '';
    clearBtn?.classList.add('hidden');
    resultsList.innerHTML = '';
    initialState?.classList.remove('hidden');
    noResults?.classList.add('hidden');
    searchCount?.classList.add('hidden');
  }

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      closeModal();
    }
  });

  // Clear button
  clearBtn?.addEventListener('click', () => {
    input.value = '';
    input.focus();
    search('');
  });

  // Search on input
  input?.addEventListener('input', (e) => {
    const query = e.target.value;

    // Show/hide clear button
    if (query) {
      clearBtn?.classList.remove('hidden');
    } else {
      clearBtn?.classList.add('hidden');
    }

    // Debounce search
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => search(query), debounceDelay);
  });

  // Perform search (matching the premium "live" feel)
  function search(query) {
    const trimmed = query.trim().toLowerCase();

    // Show initial state if empty
    if (!trimmed) {
      initialState?.classList.remove('hidden');
      noResults?.classList.add('hidden');
      searchCount?.classList.add('hidden');
      resultsList.innerHTML = '';
      return;
    }

    initialState?.classList.add('hidden');
    loadingState?.classList.remove('hidden');

    // Simulate search delay (optimized 150ms for responsiveness)
    setTimeout(() => {
      loadingState?.classList.add('hidden');

      // Filter results
      const results = searchData
        .filter((item) => {
          const titleMatch = item.title.toLowerCase().includes(trimmed);
          const descMatch = item.description?.toLowerCase().includes(trimmed);
          const categoryMatch = item.category?.toLowerCase().includes(trimmed);
          return titleMatch || descMatch || categoryMatch;
        })
        .slice(0, maxResults);

      // Render results
      if (results.length === 0) {
        noResults?.classList.remove('hidden');
        searchCount?.classList.add('hidden');
        resultsList.innerHTML = '';
      } else {
        noResults?.classList.add('hidden');
        searchCount?.classList.remove('hidden');
        searchCount.querySelector('span').textContent = results.length;

        resultsList.innerHTML = results
          .map((result, index) => {
            const title = highlightText(result.title, trimmed);
            const category = result.category || result.type || 'Makale';

            return `
              <li class="search-result-item" style="animation-delay: ${index * 0.05}s">
                <a href="${result.url}"
                   class="block p-4 bg-white/40 border border-slate-100/50 rounded-2xl 
                          hover:bg-primary hover:border-primary/20 transition-all duration-300
                          focus:outline-none focus:ring-2 focus:ring-primary/20 group/item"
                   onclick="closeModal()">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center 
                                group-hover/item:bg-white/20 transition-colors">
                      <span class="material-symbols-outlined text-slate-400 group-hover/item:text-white">
                        ${getCategoryIcon(category)}
                      </span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-bold text-slate-900 text-sm line-clamp-1 group-hover/item:text-white transition-colors">
                        ${title}
                      </h3>
                      ${result.description ? `
                        <p class="text-xs text-slate-500 mt-0.5 line-clamp-1 group-hover/item:text-white/80 transition-colors">
                          ${result.description}
                        </p>
                      ` : ''}
                    </div>
                    <span class="material-symbols-outlined text-slate-300 group-hover/item:text-white group-hover/item:translate-x-1 transition-all">
                      arrow_forward_ios
                    </span>
                  </div>
                </a>
              </li>
            `;
          })
          .join('');

        // Smooth scroll to top of results
        resultsContainer?.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }, 150);
  }

  // Helper: Get icon based on category
  function getCategoryIcon(cat) {
    cat = cat.toLowerCase();
    if (cat.includes('kadın')) return 'female';
    if (cat.includes('erkek')) return 'male';
    if (cat.includes('tedavi')) return 'medical_services';
    if (cat.includes('tüfek')) return 'science'; // for IVF
    return 'description';
  }

  // Helper: Highlight matched text
  function highlightText(text, query) {
    const regex = new RegExp(`(${query})`, 'gi');
    return text.replace(regex, '<span class="search-highlight">$1</span>');
  }

  // Handle keyboard navigation in results
  input?.addEventListener('keydown', (e) => {
    const items = resultsList.querySelectorAll('a');
    if (items.length === 0) return;

    switch (e.key) {
      case 'ArrowDown':
        e.preventDefault();
        items[0]?.focus();
        break;
      case 'ArrowUp':
        e.preventDefault();
        items[items.length - 1]?.focus();
        break;
    }
  });

  // Handle arrow navigation in results
  resultsList?.addEventListener('keydown', (e) => {
    const items = Array.from(resultsList.querySelectorAll('a'));
    const current = document.activeElement;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      const currentIndex = items.indexOf(current);
      const nextItem = items[currentIndex + 1];
      nextItem?.focus();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      const currentIndex = items.indexOf(current);
      if (currentIndex === 0) {
        input?.focus();
      } else {
        items[currentIndex - 1]?.focus();
      }
    }
  });
</script>
