---
/**
 * ResponsiveImage.astro - Optimized image component
 * Features:
 * - WebP with fallback
 * - Lazy loading
 * - Responsive sizes
 * - Proper aspect ratio
 */

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low';
  class?: string;
  sizes?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority,
  class: className,
  sizes
} = Astro.props;

// Generate WebP version if source is JPG/PNG
const webpSrc = src.replace(/\.(jpg|jpeg|png)$/i, '.webp');
const finalSrc = src.endsWith('.webp') ? src : webpSrc;
const fallbackSrc = src;
---

<picture>
  {!src.endsWith('.webp') && (
    <source srcset={finalSrc} type="image/webp" {sizes} />
  )}
  <img
    src={fallbackSrc}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
    {sizes}
  />
</picture>
