---
/**
 * EEATBadge — E-E-A-T Seffaflik Rozeti
 *
 * Makale basinda yazar kimligi, tibbi onay durumu, son guncelleme
 * ve bilimsel referans sayisini gosteren guvenilirlik rozeti.
 *
 * Kullanim:
 *   <EEATBadge
 *     author="Dr. Ayse Yilmaz"
 *     authorTitle="Ureme Endokrinolojisi Uzmani"
 *     medicalReviewer="Prof. Dr. Mehmet Demir"
 *     reviewDate="3 Nisan 2026"
 *     lastModified="3 Nisan 2026"
 *     status="published"
 *     referenceCount={12}
 *   />
 */
interface Props {
    author: string;
    authorTitle?: string;
    authorCredentials?: string;
    medicalReviewer?: string;
    reviewerTitle?: string;
    reviewDate?: string;
    lastModified?: string;
    publishDate?: string;
    status?: 'draft' | 'in_review' | 'published';
    referenceCount?: number;
}

const {
    author,
    authorTitle,
    authorCredentials,
    medicalReviewer,
    reviewerTitle,
    reviewDate,
    lastModified,
    publishDate,
    status = 'published',
    referenceCount = 0,
} = Astro.props;

const statusConfig = {
    draft: { label: 'Taslak', icon: 'edit_note', color: 'text-gray-500 bg-gray-100' },
    in_review: { label: 'İncelemede', icon: 'pending', color: 'text-amber-700 bg-amber-50' },
    published: { label: 'Yayında', icon: 'check_circle', color: 'text-mint-700 bg-mint-50' },
};

const sc = statusConfig[status];
---

<div class="eeat-badge bg-white border border-gray-200 rounded-2xl overflow-hidden">
    <!-- Top Row: Author + Reviewer -->
    <div class="flex flex-col sm:flex-row">
        <!-- Author -->
        <div class="flex-1 p-4 sm:p-5">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-primary-600 text-xl" style="font-variation-settings: 'FILL' 1;">person</span>
                </div>
                <div class="min-w-0">
                    <p class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-0.5">Yazar</p>
                    <p class="text-sm font-bold text-gray-900 truncate">{author}</p>
                    {authorTitle && <p class="text-xs text-gray-500 truncate">{authorTitle}</p>}
                    {authorCredentials && (
                        <p class="text-[11px] text-mint-700 font-semibold flex items-center gap-1 mt-0.5">
                            <span class="material-symbols-outlined text-[12px]">workspace_premium</span>
                            {authorCredentials}
                        </p>
                    )}
                </div>
            </div>
        </div>

        <!-- Divider -->
        <div class="hidden sm:block w-px bg-gray-200"></div>
        <div class="sm:hidden h-px bg-gray-200 mx-4"></div>

        <!-- Medical Reviewer -->
        <div class="flex-1 p-4 sm:p-5">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full bg-mint-50 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-mint-600 text-xl" style="font-variation-settings: 'FILL' 1;">verified</span>
                </div>
                <div class="min-w-0">
                    <p class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold mb-0.5">Yayın Kurulu</p>
                    {medicalReviewer ? (
                        <>
                            <p class="text-sm font-bold text-gray-900 truncate">{medicalReviewer}</p>
                            {reviewerTitle && <p class="text-xs text-gray-500 truncate">{reviewerTitle}</p>}
                            {reviewDate && <p class="text-[11px] text-gray-400 mt-0.5">{reviewDate}</p>}
                        </>
                    ) : (
                        <p class="text-xs text-gray-400 italic">İnceleme bekleniyor</p>
                    )}
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Meta Badges -->
    <div class="flex flex-wrap items-center gap-3 px-4 sm:px-5 py-3 bg-gray-50 border-t border-gray-200 text-xs">
        <!-- Status -->
        <span class:list={["inline-flex items-center gap-1 px-2.5 py-1 rounded-full font-semibold", sc.color]}>
            <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">{sc.icon}</span>
            {sc.label}
        </span>

        <!-- Last Modified -->
        {lastModified && (
            <span class="inline-flex items-center gap-1 text-gray-500">
                <span class="material-symbols-outlined text-[14px]">update</span>
                Güncelleme: {lastModified}
            </span>
        )}

        <!-- Publish Date -->
        {publishDate && (
            <span class="inline-flex items-center gap-1 text-gray-500">
                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                {publishDate}
            </span>
        )}

        <!-- Reference Count -->
        {referenceCount > 0 && (
            <span class="inline-flex items-center gap-1 text-primary-600 font-semibold">
                <span class="material-symbols-outlined text-[14px]">science</span>
                {referenceCount} Kaynak
            </span>
        )}
    </div>
</div>
