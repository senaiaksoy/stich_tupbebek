---
/**
 * ArticleSchema — Makale bazli JSON-LD yapilandirilmis veri
 *
 * Her makale icin MedicalWebPage + Article + reviewedBy + citation
 * schema.org markup'i uretir. BaseLayout'taki genel MedicalWebPage
 * semasinin uzerine makaleye ozel detaylar ekler.
 *
 * Kullanim:
 *   <ArticleSchema entry={entry} url={articleUrl} />
 */

interface Reference {
    title: string;
    authors?: string;
    journal?: string;
    year?: number;
    url?: string;
    doi?: string;
}

interface Props {
    entry: {
        data: {
            title: string;
            description: string;
            author: string | { name: string; title?: string; credentials?: string; url?: string };
            authorTitle?: string;
            authorCredentials?: string;
            medicalReviewer?: string;
            reviewerTitle?: string;
            publishDate?: Date;
            lastModified?: Date;
            reviewDate?: Date;
            category: string;
            image?: string;
            references?: Reference[];
        };
    };
    url: string;
}

const { entry, url } = Astro.props;
const d = entry.data;

// Resolve author
const authorName = typeof d.author === 'string' ? d.author : d.author.name;
const authorTitle = typeof d.author === 'string' ? d.authorTitle : d.author.title;
const authorCredentials = typeof d.author === 'string' ? d.authorCredentials : d.author.credentials;

// Build author schema
const authorSchema: Record<string, unknown> = {
    "@type": "Person",
    "name": authorName,
};
if (authorTitle) authorSchema["jobTitle"] = authorTitle;
if (authorCredentials) authorSchema["qualifications"] = authorCredentials;

// Build reviewer schema
const reviewerSchema = d.medicalReviewer ? {
    "@type": d.medicalReviewer.includes('Kurul') ? "Organization" : "Person",
    "name": d.medicalReviewer,
    ...(d.reviewerTitle ? { "jobTitle": d.reviewerTitle } : {}),
} : undefined;

// Build citations from references
const citations = d.references?.map(ref => {
    const citation: Record<string, unknown> = {
        "@type": "ScholarlyArticle",
        "name": ref.title,
    };
    if (ref.authors) citation["author"] = ref.authors;
    if (ref.journal) citation["isPartOf"] = { "@type": "Periodical", "name": ref.journal };
    if (ref.year) citation["datePublished"] = String(ref.year);
    if (ref.url) citation["url"] = ref.url;
    if (ref.doi) citation["sameAs"] = `https://doi.org/${ref.doi}`;
    return citation;
}) || [];

// Main Article + MedicalWebPage schema
const articleSchema = {
    "@context": "https://schema.org",
    "@type": ["MedicalWebPage", "Article"],
    "headline": d.title,
    "description": d.description,
    "url": url,
    "inLanguage": "tr-TR",
    ...(d.image ? { "image": d.image.startsWith('http') ? d.image : `https://tupbebek.com${d.image}` } : {}),
    ...(d.publishDate ? { "datePublished": d.publishDate.toISOString().split('T')[0] } : {}),
    ...(d.lastModified ? { "dateModified": d.lastModified.toISOString().split('T')[0] } : {}),
    "author": authorSchema,
    ...(reviewerSchema ? { "reviewedBy": reviewerSchema } : {}),
    ...(d.reviewDate ? { "lastReviewed": d.reviewDate.toISOString().split('T')[0] } : {}),
    "publisher": {
        "@type": "Organization",
        "name": "tupbebek.com",
        "url": "https://tupbebek.com",
        "logo": {
            "@type": "ImageObject",
            "url": "https://tupbebek.com/favicon.svg",
        },
    },
    "isPartOf": {
        "@type": "WebSite",
        "name": "tupbebek.com",
        "url": "https://tupbebek.com",
    },
    "about": {
        "@type": "MedicalCondition",
        "name": d.category,
    },
    "medicalAudience": {
        "@type": "MedicalAudience",
        "audienceType": "Patient",
    },
    "specialty": {
        "@type": "MedicalSpecialty",
        "name": "Reproductive Medicine",
    },
    ...(citations.length > 0 ? { "citation": citations } : {}),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
