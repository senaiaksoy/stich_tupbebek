---
interface Props {
  placeholder?: string;
  ariaLabel?: string;
}

const { placeholder = "Bir konu arayın...", ariaLabel = "Sayfada ara" } = Astro.props;
---

<form class="w-full max-w-md" role="search">
  <div class="relative">
    <input
      type="search"
      placeholder={placeholder}
      aria-label={ariaLabel}
      class="w-full px-4 py-3 pr-12 rounded-lg border border-outline bg-surface text-on-surface placeholder-on-surface-variant focus:outline-none focus:ring-2 focus:ring-primary"
    />
    <button
      type="submit"
      class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors"
      aria-label="Ara"
    >
      <span class="material-symbols-outlined">search</span>
    </button>
  </div>
</form>

<style>
  input::placeholder {
    color: var(--color-on-surface-variant);
  }
</style>
