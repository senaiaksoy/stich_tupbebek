---
import { getCollection } from 'astro:content';
import LoadingSkeletons from './LoadingSkeletons.astro';

let articles = null;
let error = null;

try {
    articles = (await getCollection('articles'))
        .sort((a, b) => {
            const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
            const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
            return dateB - dateA;
        })
        .slice(0, 5);
} catch (e) {
    error = e;
}
---

<section class="py-24 bg-surface-container-low overflow-hidden">
    <div class="max-w-7xl mx-auto px-8">
        <div class="flex justify-between items-end mb-12">
            <div>
                <span class="text-primary font-label uppercase tracking-widest text-xs font-bold mb-4 block">GÜNCEL YAYINLAR</span>
                <h2 class="text-4xl font-headline text-on-surface">Bilimsel Makale Vitrini</h2>
            </div>
            <a href="/makaleler" class="text-primary font-bold hover:underline flex items-center gap-2">
                Tüm Arşivi Gör <span class="material-symbols-outlined">arrow_right_alt</span>
            </a>
        </div>

        <!-- Loading State -->
        {articles === null && !error && (
            <LoadingSkeletons type="carousel" count={5} />
        )}

        <!-- Error State -->
        {error && (
            <div class="p-8 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl block mb-4 opacity-50">error</span>
                <p class="font-medium">Makaleler yüklenemedi</p>
            </div>
        )}

        <!-- Carousel Container (Horizontal Scroll) -->
        {articles && articles.length > 0 && (
        <div class="flex gap-8 overflow-x-auto pb-12 snap-x no-scrollbar">
            {articles.map((article) => (
                <article class="min-w-[320px] md:min-w-[400px] snap-start bg-white rounded-3xl p-6 shadow-sm hover:shadow-xl transition-all duration-500 border border-outline-variant/10 group">
                    <div class="aspect-video rounded-2xl overflow-hidden mb-6 relative">
                        <img 
                            src={article.data.image} 
                            alt={article.data.imageAlt} 
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
                        />
                        <div class="absolute top-4 left-4 px-3 py-1 bg-white/90 backdrop-blur-md rounded-full text-[10px] font-bold uppercase tracking-widest text-primary">
                            {article.data.category}
                        </div>
                    </div>
                    <a href={`/makaleler/${article.slug}`}>
                        <h3 class="text-xl font-headline text-on-surface mb-4 line-clamp-2 hover:text-primary transition-colors">
                            {article.data.title}
                        </h3>
                    </a>
                    <p class="text-secondary text-sm line-clamp-3 mb-6 leading-relaxed">
                        {article.data.description}
                    </p>
                    <div class="flex items-center justify-between pt-6 border-t border-outline-variant/10">
                        <span class="text-[10px] font-bold text-outline uppercase tracking-tighter italic">DR. SENAI AKSOY ONAYLI</span>
                        <span class="material-symbols-outlined text-primary group-hover:translate-x-2 transition-transform">trending_flat</span>
                    </div>
                </article>
            ))}
        </div>
        )}
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
