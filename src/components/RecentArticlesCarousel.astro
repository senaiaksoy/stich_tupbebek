---
/**
 * Recent Articles — Healthline-inspired clean card grid
 * No carousel, clean 3-column grid with subtle styling
 */
import { getPublishedArticles } from '../utils/articles';

const articles = (await getPublishedArticles())
    .sort((a, b) => {
        const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
        const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
        return dateB - dateA;
    })
    .slice(0, 6);
---

<section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">

        <!-- Section Header -->
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 lg:mb-14">
            <div>
                <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-2">Güncel Makaleler</h2>
                <p class="text-base text-gray-500">Bilimsel, güncel ve yayın kurulu onaylı içerikler.</p>
            </div>
            <a href="/makaleler" class="text-primary-600 font-semibold text-sm hover:underline flex items-center gap-1.5 shrink-0">
                Tüm Makaleler <span class="material-symbols-outlined text-base">arrow_forward</span>
            </a>
        </div>

        <!-- Articles Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {articles.map((article) => (
                <article class="group flex flex-col bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md hover:border-primary-100 transition-all duration-300">
                    <!-- Image -->
                    <a href={`/makaleler/${article.slug}`} class="block aspect-[16/10] overflow-hidden">
                        <img
                            src={article.data.image}
                            alt={article.data.imageAlt || article.data.title}
                            class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                            loading="lazy"
                        />
                    </a>

                    <!-- Content -->
                    <div class="flex flex-col gap-3 p-5 flex-1">
                        <!-- Category -->
                        <span class="text-xs font-bold uppercase tracking-wide text-primary-600">
                            {article.data.category}
                        </span>

                        <!-- Title -->
                        <a href={`/makaleler/${article.slug}`}>
                            <h3 class="text-lg font-bold text-gray-900 leading-snug line-clamp-2 group-hover:text-primary-700 transition-colors">
                                {article.data.title}
                            </h3>
                        </a>

                        <!-- Excerpt -->
                        <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 flex-1">
                            {article.data.description}
                        </p>

                        <!-- Meta -->
                        <div class="flex items-center gap-2 text-xs text-gray-400 pt-2 border-t border-gray-100 mt-auto">
                            <span>{typeof article.data.author === 'string' ? article.data.author : article.data.author?.name}</span>
                        </div>
                    </div>
                </article>
            ))}
        </div>
        )}
    </div>
</section>
