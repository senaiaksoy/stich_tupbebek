---
interface Props {
  items: Array<{
    label: string;
    href: string;
    icon?: string;
  }>;
  title?: string;
}

const { items, title = "Hızlı Erişim" } = Astro.props;
---

<section class="bg-surface-container-low py-8 my-12">
  <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
    {title && <h2 class="font-headline text-xl text-on-surface mb-6">{title}</h2>}
    <div class="flex flex-wrap gap-4">
      {items.map((item) => (
        <a
          href={item.href}
          class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-outline rounded-full text-sm font-medium text-primary hover:bg-primary hover:text-on-primary transition-colors"
        >
          {item.icon && <span class="material-symbols-outlined text-base">{item.icon}</span>}
          <span>{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  p {
    margin: 0;
  }
</style>
