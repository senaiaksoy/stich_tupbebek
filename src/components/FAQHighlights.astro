---
const faqs = [
  {
    question: "Tüp bebek başarısını etkileyen en önemli faktör nedir?",
    answer: "Kadın yaşı en belirleyici faktördür. Ancak kişiselleştirilmiş protokoller ve laboratuvar kalitesi bu başarıyı optimize edebilir."
  },
  {
    question: "Tedavi süreci ne kadar sürer?",
    answer: "Genellikle yumurta uyarımı ve toplama süreci 15-20 gün sürer. Embriyo transferi protokolüne göre bu süre değişebilir."
  },
  {
    question: "Hamilelik şansım yüzde kaç?",
    answer: "Bu oran yaşa, infertilite nedenine ve klinik verilere göre değişir. Bireysel analizinizi başarı oranları panelimizden yapabilirsiniz."
  }
];
---

<section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-8">
        <div class="grid lg:grid-cols-12 gap-16 items-center">
            <div class="lg:col-span-4">
                <span class="text-primary-600 font-label uppercase tracking-widest text-xs font-bold mb-4 block">SIKÇA SORULANLAR</span>
                <h2 class="text-4xl font-headline text-gray-900 mb-8">Öne Çıkan <br/>Sorular</h2>
                <p class="text-gray-600 leading-relaxed mb-10">Zihninizdeki soruları bilimsel verilerle yanıtlıyoruz.</p>
                <a href="/sss" class="px-8 py-4 bg-primary-600 text-white rounded-2xl font-bold hover:scale-105 transition-all shadow-lg inline-block">TÜM SORULARI GÖR</a>
            </div>

            <div class="lg:col-span-8 space-y-6">
                {faqs.map((faq) => (
                    <div class="bg-gray-100 p-8 rounded-3xl border border-gray-200 hover:border-primary-200 transition-all group">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 group-hover:text-primary-600 transition-colors flex items-center gap-3">
                           <span class="material-symbols-outlined text-primary-600 scale-75">help</span> {faq.question}
                        </h3>
                        <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
