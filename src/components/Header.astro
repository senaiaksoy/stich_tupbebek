---
---
<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm group/header">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div id="header-inner" class="flex justify-between items-center h-20 transition-all duration-500">
            <!-- Logo Section -->
            <div class="flex-shrink-0">
                <a href="/" class="text-2xl font-serif font-bold text-slate-900 tracking-tight flex items-center gap-2 group/logo transition-all">
                    <span id="logo-icon" class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-base transition-all group-hover/logo:rotate-12">tb</span>
                    <span id="logo-text" class="transition-all origin-left">tupbebek.com</span>
                </a>
            </div>

            <!-- Desktop Navigation (Mega-Menu) -->
            <nav class="hidden lg:flex items-center space-x-1 h-full">
                {/* 1. İnfertilite Nedenleri */}
                <div class="group h-full flex items-center">
                    <button class="px-4 py-3 min-h-[48px] text-sm font-bold text-slate-800 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-primary/5 rounded-lg">
                        İnfertilite Nedenleri <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-3 gap-8">
                            <!-- SOL: Linkler -->
                            <div class="border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-primary font-bold mb-4">
                                    <span class="material-symbols-outlined text-[14px] align-text-bottom mr-1">woman</span>Nedenler
                                </h4>
                                <div class="space-y-1">
                                    <a href="/kadin-infertilitesi" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Kadın Faktörleri</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">PCOS, tubal, endometriozis</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                    <a href="/erkek-infertilitesi" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Erkek Faktörleri</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">Azospermi, varikosel</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>

                                    <hr class="my-2 border-slate-100" />
                                    <h4 class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2 px-3">
                                        <span class="material-symbols-outlined text-[12px] align-text-bottom mr-0.5">group</span>Diğer
                                    </h4>
                                    <a href="/aciklanamayan-infertilite" class="group/link flex p-3 hover:bg-slate-50 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-semibold text-slate-700 group-hover/link:text-primary">Açıklanamayan</span>
                                            <span class="block text-xs text-slate-400 mt-0.5">Stratejik tanı yolları</span>
                                        </div>
                                    </a>
                                    <a href="/yas-ve-fertilite" class="group/link flex p-3 hover:bg-slate-50 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-semibold text-slate-700 group-hover/link:text-primary">Yaş ve Fertilite</span>
                                            <span class="block text-xs text-slate-400 mt-0.5">Zamanlama &amp; koruma</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <!-- ORTA: Açıklama + Görsel -->
                            <div class="space-y-4">
                                <h4 class="text-xs uppercase tracking-widest text-slate-400 font-bold">Neden Önemli?</h4>
                                <p class="text-sm text-slate-600 italic italic">"İnfertilite vakalarının 3'ünde kadın faktörü, 3'ünde erkek faktörü, 3'ünde ise birlikte veya açıklanamayan nedenler rol oynar."</p>
                                <div class="bg-slate-50 rounded-xl p-4 text-center">
                                    <span class="block text-2xl font-bold text-primary">~1/6</span>
                                    <span class="text-xs text-slate-500">çift infertilite ile karşı karşıya</span>
                                </div>
                            </div>
                            <!-- SAĞ: Öne Çıkan Makale -->
                            <div class="bg-primary/5 rounded-2xl p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-primary uppercase tracking-widest">Öne Çıkan</span>
                                    <a href="/makaleler/iyi-tup-bebek-merkezi" class="block mt-3 text-sm font-headline font-bold text-slate-800 hover:text-primary transition-colors">Doğru Merkez Seçimi</a>
                                    <p class="text-xs text-slate-500 mt-2">Tüp bebek merkezi seçerken dikkat etmeniz gereken kriterler.</p>
                                </div>
                                <a href="/makaleler" class="text-xs font-semibold text-primary hover:underline mt-3 inline-block">Tüm Makaleler →</a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 2. Tanı ve Değerlendirme */}
                <div class="group h-full flex items-center">
                    <button class="px-4 py-3 min-h-[48px] text-sm font-bold text-slate-800 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-primary/5 rounded-lg">
                        Tanı ve Değerlendirme <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-3 gap-8">
                            <!-- SOL: Linkler -->
                            <div class="border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-primary font-bold mb-4">
                                    <span class="material-symbols-outlined text-[14px] align-text-bottom mr-1">psychology</span>Ana Hizmetler
                                </h4>
                                <div class="space-y-1">
                                    <a href="/tani-sureci" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Genel Tanı Süreci</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">Kadın &amp; erkek değerlendirmesi</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                    <a href="/genetik-testler" class="group/link flex p-3 hover:bg-slate-50 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Genetik Testler</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">Kromozomal tarama</span>
                                        </div>
                                    </a>
                                </div>

                                <hr class="my-3 border-slate-100" />
                                <h4 class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2 px-3">
                                    <span class="material-symbols-outlined text-[12px] align-text-bottom mr-0.5">lab</span>Tanı Araçları
                                </h4>
                                <div class="space-y-1">
                                    <a href="/hormon-paneli" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Hormon Paneli</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">AMH, FSH, E2 değerleri</span>
                                    </a>
                                    <a href="/makaleler/laboratuvar-sorunu-yorumlama" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Lab Raporu Yorumlama</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Hormon &amp; semen analizi</span>
                                    </a>
                                </div>
                            </div>
                            <!-- ORTA: Açıklama -->
                            <div class="space-y-4">
                                <h4 class="text-xs uppercase tracking-widest text-slate-400 font-bold">Tanı Neden Kritik?</h4>
                                <p class="text-sm text-slate-600 italic">"Doğru tedavi, titiz ve eksiksiz bir tanı süreciyle başlar. Hormon paneli, genetik tarama ve ultrason değerlendirmesi ilk adımdır."</p>
                                <div class="bg-slate-50 rounded-xl p-4 text-center">
                                    <span class="block text-2xl font-bold text-primary">3-6 ay</span>
                                    <span class="text-xs text-slate-500">tanı süreci ortalama süresi</span>
                                </div>
                            </div>
                            <!-- SAĞ: Öne Çıkan Makale -->
                            <div class="bg-primary/5 rounded-2xl p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-primary uppercase tracking-widest">Öne Çıkan</span>
                                    <a href="/makaleler/laboratuvar-raporu-yorumlama" class="block mt-3 text-sm font-headline font-bold text-slate-800 hover:text-primary transition-colors">Laboratuvar Raporu Yorumlama</a>
                                    <p class="text-xs text-slate-500 mt-2">Tahlil sonuçlarınızı nasıl okuyacağınızı öğrenin.</p>
                                </div>
                                <a href="/tani-sureci" class="text-xs font-semibold text-primary hover:underline mt-3 inline-block">Tanı Sürecine Başlayın →</a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 3. Tedavi Yöntemleri */}
                <div class="group h-full flex items-center">
                    <button class="px-4 py-3 min-h-[48px] text-sm font-bold text-slate-800 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-primary/5 rounded-lg">
                        Tedavi Yöntemleri <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-3 gap-8">
                            <!-- SOL: Linkler -->
                            <div class="border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-primary font-bold mb-4">
                                    <span class="material-symbols-outlined text-[14px] align-text-bottom mr-1">medical_services</span>Temel Tedaviler
                                </h4>
                                <div class="space-y-1">
                                    <a href="/tedavi-yontemleri" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Tüm Tedavi Yöntemleri</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">IVF, ICSI, IUI ve diğerleri</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                    <a href="/fertilite-koruma" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Fertilite Koruma</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Yumurta, sperm dondurma</span>
                                    </a>
                                </div>

                                <hr class="my-3 border-slate-100" />
                                <h4 class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2 px-3">
                                    <span class="material-symbols-outlined text-[12px] align-text-bottom mr-0.5">biotech</span>İleri Seçenekler
                                </h4>
                                <div class="space-y-1">
                                    <a href="/pgt-merkezi" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">PGT Genetik Test</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">PGT-A, PGT-M, PGT-SR</span>
                                    </a>
                                </div>
                            </div>
                            <!-- ORTA: Açıklama -->
                            <div class="space-y-4">
                                <h4 class="text-xs uppercase tracking-widest text-slate-400 font-bold">Tedavi Seçenekleri</h4>
                                <p class="text-sm text-slate-600 italic">"Dünya standartlarında yardımcı üreme teknikleri ve kişiselleştirilmiş tedavi protokolleri ile her çiftin umudu vardır."</p>
                                <div class="bg-slate-50 rounded-xl p-4 text-center">
                                    <span class="block text-2xl font-bold text-primary">%54</span>
                                    <span class="text-xs text-slate-500">IVF canlı doğum oranı (35 yaş altı)</span>
                                </div>
                            </div>
                            <!-- SAĞ: Öne Çıkan Makale -->
                            <div class="bg-primary/5 rounded-2xl p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-primary uppercase tracking-widest">Öne Çıkan</span>
                                    <a href="/pgt-merkezi" class="block mt-3 text-sm font-headline font-bold text-slate-800 hover:text-primary transition-colors">PGT Bilgi Merkezi</a>
                                    <p class="text-xs text-slate-500 mt-2">Preimplantasyon genetik test ile sağlıklı embriyo seçimi.</p>
                                </div>
                                <a href="/tedavi-yontemleri" class="text-xs font-semibold text-primary hover:underline mt-3 inline-block">Tüm Tedaviler →</a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 4. Rehberler */}
                <div class="group h-full flex items-center">
                    <button class="px-4 py-3 min-h-[48px] text-sm text-slate-500 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg font-medium">
                        Rehberler <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-3 gap-8">
                            <!-- SOL: Linkler -->
                            <div class="border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-primary font-bold mb-4">
                                    <span class="material-symbols-outlined text-[14px] align-text-bottom mr-1">description</span>Temel Rehberler
                                </h4>
                                <div class="space-y-1">
                                    <a href="/rehberler" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Tedavi Rehberi</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">Adım adım IVF süreci</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                </div>

                                <hr class="my-3 border-slate-100" />
                                <h4 class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2 px-3">
                                    <span class="material-symbols-outlined text-[12px] align-text-bottom mr-0.5">medication</span>Destek
                                </h4>
                                <div class="space-y-1">
                                    <a href="/ilac-rehberi" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">İlaç Rehberi</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Gonadotropinler, GnRH</span>
                                    </a>
                                    <a href="/beslenme-yasam" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Beslenme &amp; Yaşam</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Akdeniz diyeti, takviyeler</span>
                                    </a>
                                </div>
                            </div>
                            <!-- ORTA: Açıklama -->
                            <div class="space-y-4">
                                <h4 class="text-xs uppercase tracking-widest text-slate-400 font-bold">Hasta Yolculuğu</h4>
                                <p class="text-sm text-slate-600 italic">"Psikolojik ve fiziksel hazırlıktan tedavi sürecine ve eve dönüşe kadar her adımı sizinle birlikte yürürüz."</p>
                                <div class="bg-slate-50 rounded-xl p-4 text-center">
                                    <span class="block text-2xl font-bold text-primary">6 adım</span>
                                    <span class="text-xs text-slate-500">IVF sürecinin temel aşaması</span>
                                </div>
                            </div>
                            <!-- SAĞ: Öne Çıkan Makale -->
                            <div class="bg-primary/5 rounded-2xl p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-primary uppercase tracking-widest">Öne Çıkan</span>
                                    <a href="/ilac-rehberi" class="block mt-3 text-sm font-headline font-bold text-slate-800 hover:text-primary transition-colors">IVF İlaç Rehberi</a>
                                    <p class="text-xs text-slate-500 mt-2">Kullanılan tüm ilaçlar, dozlar ve yan etkileri hakkında A'dan Z'ye.</p>
                                </div>
                                <a href="/rehberler" class="text-xs font-semibold text-primary hover:underline mt-3 inline-block">Rehberlere Göz Atın →</a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 5. Bilgi Kütüphanesi */}
                <div class="group h-full flex items-center">
                    <button class="px-4 py-3 min-h-[48px] text-sm text-slate-500 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg font-medium">
                        Bilgi Kütüphanesi <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-3 gap-8">
                            <!-- SOL: Linkler -->
                            <div class="border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-primary font-bold mb-4">
                                    <span class="material-symbols-outlined text-[14px] align-text-bottom mr-1">article</span>Bilimsel İçerik
                                </h4>
                                <div class="space-y-1">
                                    <a href="/makaleler" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-bold text-slate-800 group-hover/link:text-primary">Tüm Makaleler</span>
                                            <span class="block text-xs text-slate-500 mt-0.5">Bilimsel kütüphane</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                    <a href="/tbbi-sozluk" class="group/link flex p-3 hover:bg-primary/5 rounded-lg transition-colors">
                                        <div>
                                            <span class="text-sm font-semibold text-slate-700 group-hover/link:text-primary">Tıbbi Sözlük</span>
                                            <span class="block text-xs text-slate-400 mt-0.5">A-Z terimler</span>
                                        </div>
                                        <span class="material-symbols-outlined text-xs text-slate-300 group-hover/link:text-primary transition-colors mt-1.5 ml-auto">arrow_forward</span>
                                    </a>
                                </div>

                                <hr class="my-3 border-slate-100" />
                                <h4 class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-2 px-3">
                                    <span class="material-symbols-outlined text-[12px] align-text-bottom mr-0.5">support_agent</span>Hasta Desteği
                                </h4>
                                <div class="space-y-1">
                                    <a href="/sss" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">SSS</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Sık sorulan sorular</span>
                                    </a>
                                    <a href="/psikolojik-destek" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Duygusal Destek</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Psikolojik rehberlik</span>
                                    </a>
                                    <a href="/basari-oranlari" class="block p-3 hover:bg-slate-50/70 rounded-lg transition-colors">
                                        <span class="text-sm font-semibold text-slate-700">Başarı Oranları</span>
                                        <span class="block text-xs text-slate-400 mt-0.5">Veri panelleri</span>
                                    </a>
                                </div>
                            </div>
                            <!-- ORTA: Açıklama -->
                            <div class="space-y-4">
                                <h4 class="text-xs uppercase tracking-widest text-slate-400 font-bold">Bilgi Arşivi</h4>
                                <p class="text-sm text-slate-600 italic">"Akademik veriler, güncel klinik çalışmalar ve tarafsız bilgilendirme. Doç. Dr. Senai Aksoy denetiminde hazırlanan içerikler."</p>
                                <div class="bg-slate-50 rounded-xl p-4 text-center">
                                    <span class="block text-2xl font-bold text-primary">15+</span>
                                    <span class="text-xs text-slate-500">bilimsel makale</span>
                                </div>
                            </div>
                            <!-- SAĞ: Öne Çıkan -->
                            <div class="bg-primary/5 rounded-2xl p-6 flex flex-col justify-between">
                                <div>
                                    <span class="text-xs font-bold text-primary uppercase tracking-widest">Öne Çıkan</span>
                                    <a href="/tbbi-sozluk" class="block mt-3 text-sm font-headline font-bold text-slate-800 hover:text-primary transition-colors">Tıbbi Sözlük</a>
