---
---
<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm group/header">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div id="header-inner" class="flex justify-between items-center h-20 transition-all duration-500">
            <!-- Logo Section -->
            <div class="flex-shrink-0">
                <a href="/" class="text-2xl font-serif font-bold text-slate-900 tracking-tight flex items-center gap-2 group/logo transition-all">
                    <span id="logo-icon" class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-base transition-all group-hover/logo:rotate-12">tb</span>
                    <span id="logo-text" class="transition-all origin-left">tupbebek.com</span>
                </a>
            </div>

            <!-- Desktop Navigation (Mega-Menu) -->
            <nav class="hidden lg:flex items-center space-x-1 h-full">
                {/* 1. İnfertilite Rehberi */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        İnfertilite Rehberi <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <!-- Mega Menu Panel -->
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">I Want to Know</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Kişiselleştirilmiş bir anlayışla, üreme sağlığınızın derinliklerini keşfedin."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/sorunlar#kadin" class="group/item flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold text-slate-900 group-hover/item:text-primary">Kadın Faktörleri</span>
                                    <span class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Hormonal & Yapısal Dengeler</span>
                                </a>
                                <a href="/erkek-infertilitesi" class="group/item flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold text-slate-900 group-hover/item:text-primary">Erkek Faktörleri</span>
                                    <span class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Semen Analizi & Sağlık</span>
                                </a>
                                <a href="/sorunlar#aciklanamayan" class="group/item flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold text-slate-900 group-hover/item:text-primary">Açıklanamayan</span>
                                    <span class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Stratejik Tanı Yolları</span>
                                </a>
                                <a href="/sorunlar#yas" class="group/item flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold text-slate-900 group-hover/item:text-primary">Yaş ve Fertilite</span>
                                    <span class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Zamanlama & Koruma</span>
                                </a>
                                <a href="/erkek-infertilitesi#genetik" class="group/item flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold text-slate-900 group-hover/item:text-primary">Genetik Faktörler</span>
                                    <span class="text-xs text-slate-500 mt-1 uppercase tracking-tighter">Klinik Tarama Analizi</span>
                                </a>
                                <div class="p-4 bg-primary/5 rounded-2xl flex flex-col justify-center">
                                    <span class="text-xs font-bold text-primary mb-1 uppercase tracking-widest">Featured Report</span>
                                    <a href="/makaleler/iyi-tup-bebek-merkezi" class="text-sm font-headline font-bold hover:underline">Doğru Merkez Seçimi</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 2. Tanı Süreci */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        Tanı Süreci <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">Diagnostics</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Doğru tedavi, titiz ve hatasız bir tanı süreciyle başlar."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/tani-sureci#kadin" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Kadın Değerlendirmesi</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">HSG, Ultrason & Hormonlar</span>
                                </a>
                                <a href="/tani-sureci#erkek" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Erkek Değerlendirmesi</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">İleri Spermiogram Analizi</span>
                                </a>
                                <a href="/makaleler/genetik-testler" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Genetik Testler</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Kromozomal Tarama</span>
                                </a>
                                <a href="/makaleler/laboratuvar-raporu-yorumlama" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Hormon Paneli Okuma</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">AMH, FSH & E2 Verileri</span>
                                </a>
                                <a href="/tani-sureci#algoritma" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Tanı Algoritması</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Adım Adım Yol Haritası</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 3. Tedaviler */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        Tedaviler <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">Methodology</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Dünya standartlarında yardımcı üreme teknikleri ve cerrahi uzmanlık."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/tedavi-yontemleri" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Tüp Bebek (IVF/ICSI)</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">İleri Fertilizasyon</span>
                                </a>
                                <a href="/tedavi-yontemleri#iui" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Aşılama (IUI)</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Minimal İnvaziv Başlangıç</span>
                                </a>
                                <a href="/tedavi-yontemleri#ovulasyon" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Ovülasyon İndüksiyonu</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Yumurta Takibi & Uyarım</span>
                                </a>
                                <a href="/makaleler/genetik-testler" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">PGT</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Embriyo Seçiminde Bilim</span>
                                </a>
                                <a href="/makaleler/ivf-oncesi-histeroskopi" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Cerrahi Tedaviler</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Laparoskopi & Histeroskopi</span>
                                </a>
                                <a href="/tedavi-yontemleri#koruma" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Fertilite Koruma</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Yumurta & Sperm Dondurma</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 4. Tedavi Rehberi */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        Tedavi Rehberi <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">Patient Path</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Psikolojik ve fiziksel hazırlıktan eve dönüş sürecine kadar tam rehberlik."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/rehberler#adim-adim" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Adım Adım IVF</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Süreç Yol Haritası</span>
                                </a>
                                <a href="/rehberler#hazirlik" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Hazırlık Dönemi</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Tedavi Öncesi Hazırlık</span>
                                </a>
                                <a href="/makaleler/dondurulmus-embriyo-transferi" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Transfer Sonrası</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Tutunma & Bekleme Süreci</span>
                                </a>
                                <a href="/rehberler#ilaç" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">İlaç Rehberi</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Uygulama & Yan Etkiler</span>
                                </a>
                                <a href="/makaleler/alkol-ve-fertilite" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Beslenme & Yaşam</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Bütüncül Sağlık Optimizasyonu</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 5. Bilgi Merkezi */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        Bilgi Merkezi <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">Knowledge Base</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Akademik veriler, güncel çalışmalar ve tarafsız bilgilendirme arşivi."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/makaleler" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Tüm Makaleler</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Bilimsel Kütüphane</span>
                                </a>
                                <a href="/makaleler?filter=research" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Bilimsel Araştırmalar</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">İleri Klinik Veriler</span>
                                </a>
                                <a href="/makaleler?filter=stories" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Hasta Hikayeleri</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Deneyim Paylaşımları</span>
                                </a>
                                <a href="/sss" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Sık Sorulan Sorular</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Pratik Bilgiler</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {/* 6. Hakkımızda */}
                <div class="group h-full flex items-center">
                    <button class="px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors flex items-center gap-1 group-hover:bg-slate-50 rounded-lg">
                        Hakkımızda <span class="material-symbols-outlined text-xs group-hover:rotate-180 transition-transform">expand_more</span>
                    </button>
                    <div class="absolute top-[100%] left-0 w-full bg-white shadow-2xl border-b border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                        <div class="max-w-7xl mx-auto px-8 py-10 grid grid-cols-4 gap-8">
                            <div class="col-span-1 border-r border-slate-100 pr-8">
                                <h4 class="text-xs uppercase tracking-widest text-[#c5a059] font-bold mb-4">Editorial</h4>
                                <p class="text-sm text-slate-500 leading-relaxed italic">"Şeffaflık, bağımsızlık ve bilimsel doğruluk taahhüdümüz."</p>
                            </div>
                            <div class="col-span-3 grid grid-cols-3 gap-y-6 gap-x-12">
                                <a href="/hakkimizda#misyon" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Misyonumuz</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Neden Buradayız?</span>
                                </a>
                                <a href="/hakkimizda#editor" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Editöryal Politika</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">İçerik Standartları</span>
                                </a>
                                <a href="/hakkimizda#dr-senai" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">Dr. Senai Aksoy</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Medikal İnceleme Kurulu</span>
                                </a>
                                <a href="/hakkimizda#contact" class="flex flex-col p-3 hover:bg-slate-50 rounded-xl transition-colors">
                                    <span class="text-sm font-bold">İletişim</span>
                                    <span class="text-xs text-slate-500 uppercase tracking-tighter">Bize Ulaşın</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Right Side: Search & Tooltip -->
            <div class="hidden lg:flex items-center gap-4">
                <button id="header-search-btn" class="p-2 text-slate-500 hover:text-primary hover:bg-slate-50 rounded-full transition-all">
                    <span class="material-symbols-outlined">search</span>
                </button>
                <a href="/hakkimizda#contact" class="px-6 py-2 bg-primary text-white text-sm font-bold rounded-full shadow-lg shadow-primary/20 hover:scale-105 transition-all">
                    İletişime Geç
                </a>
            </div>

            <!-- Mobile Menu Toggle -->
            <div class="lg:hidden flex items-center">
                <button id="mobile-menu-toggle" class="p-2 text-slate-900 border-none bg-transparent">
                    <span id="menu-icon" class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Redesigned Mobile Navigation Overlay -->
    <div id="mobile-menu" class="lg:hidden fixed inset-0 z-[110] bg-white translate-x-full transition-transform duration-500 ease-in-out overflow-y-auto">
        <div class="flex items-center justify-between p-6 border-b border-slate-100">
            <span class="font-serif font-bold text-xl">tupbebek.com</span>
            <button id="mobile-close" class="p-2 text-slate-900 border-none bg-transparent">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <div class="p-6 space-y-6">
            {/* Search in Mobile */}
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input type="text" placeholder="Rehberlerde ara..." class="w-full bg-slate-100 border-none rounded-2xl pl-12 pr-4 py-4 text-sm" />
            </div>

            {/* Mobile Accordion Menu */}
            <div class="space-y-2">
                <div class="mobile-accordion">
                    <button class="w-full flex items-center justify-between py-4 text-lg font-bold border-b border-slate-50">
                        İnfertilite Rehberi <span class="material-symbols-outlined text-slate-400 transition-transform">expand_more</span>
                    </button>
                    <div class="hidden py-4 pl-4 space-y-4">
                        <a href="/sorunlar#kadin" class="block text-slate-600">Kadın Faktörleri</a>
                        <a href="/sorunlar#erkek" class="block text-slate-600">Erkek Faktörleri</a>
                        <a href="/sorunlar#aciklanamayan" class="block text-slate-600">Açıklanamayan</a>
                        <a href="/sorunlar#yas" class="block text-slate-600">Yaş ve Fertilite</a>
                    </div>
                </div>
                <div class="mobile-accordion">
                    <button class="w-full flex items-center justify-between py-4 text-lg font-bold border-b border-slate-50">
                        Tanı Süreci <span class="material-symbols-outlined text-slate-400 Transition-transform">expand_more</span>
                    </button>
                    <div class="hidden py-4 pl-4 space-y-4">
                        <a href="/tani-sureci#kadin" class="block text-slate-600">Kadın Değerlendirmesi</a>
                        <a href="/tani-sureci#erkek" class="block text-slate-600">Erkek Değerlendirmesi</a>
                    </div>
                </div>
                {/* Simplified for demo, repeat for others */}
                <a href="/tedavi-yontemleri" class="block py-4 text-lg font-bold border-b border-slate-50">Tedaviler</a>
                <a href="/rehberler" class="block py-4 text-lg font-bold border-b border-slate-50">Tedavi Rehberi</a>
                <a href="/makaleler" class="block py-4 text-lg font-bold border-b border-slate-50">Bilgi Merkezi</a>
                <a href="/hakkimizda" class="block py-4 text-lg font-bold border-b border-slate-50">Hakkımızda</a>
            </div>
        </div>
    </div>
</header>

{/* Mobile Quick Access Bar */}
<div class="lg:hidden fixed bottom-0 w-full z-[120] bg-white/90 backdrop-blur-xl border-t border-slate-100 flex items-center justify-around py-4 px-6 shadow-[0_-4px_12px_rgba(0,0,0,0.05)]">
    <a href="/" class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors">
        <span class="material-symbols-outlined">home</span>
        <span class="text-[10px] font-bold uppercase tracking-tighter">Ana Sayfa</span>
    </a>
    <button class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors border-none bg-transparent">
        <span class="material-symbols-outlined">search</span>
        <span class="text-[10px] font-bold uppercase tracking-tighter">Ara</span>
    </button>
    <button id="mobile-menu-trigger" class="flex flex-col items-center gap-1 text-primary border-none bg-transparent">
        <span class="material-symbols-outlined">apps</span>
        <span class="text-[10px] font-bold uppercase tracking-tighter">Menü</span>
    </button>
    <a href="/sss" class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors">
        <span class="material-symbols-outlined">help</span>
        <span class="text-[10px] font-bold uppercase tracking-tighter">SSS</span>
    </a>
</div>

<script is:inline>
    (function() {
        // Sticky/Compact Logic
        const header = document.getElementById('main-header');
        const headerInner = document.getElementById('header-inner');
        const logoIcon = document.getElementById('logo-icon');
        const logoText = document.getElementById('logo-text');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.classList.add('py-0', 'shadow-lg');
                header.classList.remove('bg-white/80');
                header.classList.add('bg-white/95');
                headerInner.classList.remove('h-20');
                headerInner.classList.add('h-16');
                logoIcon.classList.remove('w-8', 'h-8');
                logoIcon.classList.add('w-6', 'h-6', 'text-xs');
                logoText.classList.add('scale-90');
            } else {
                header.classList.remove('py-0', 'shadow-lg');
                header.classList.add('bg-white/80');
                header.classList.remove('bg-white/95');
                headerInner.classList.add('h-20');
                headerInner.classList.remove('h-16');
                logoIcon.classList.add('w-8', 'h-8');
                logoIcon.classList.remove('w-6', 'h-6', 'text-xs');
                logoText.classList.remove('scale-90');
            }
        });

        // Mobile Menu Logic
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuTrigger = document.getElementById('mobile-menu-trigger'); // From bottom bar
        const closeBtn = document.getElementById('mobile-close');
        const menu = document.getElementById('mobile-menu');

        const toggleMenu = () => {
            menu.classList.toggle('translate-x-full');
            document.body.style.overflow = menu.classList.contains('translate-x-full') ? 'auto' : 'hidden';
        };

        if(menuToggle) menuToggle.addEventListener('click', toggleMenu);
        if(menuTrigger) menuTrigger.addEventListener('click', toggleMenu);
        if(closeBtn) closeBtn.addEventListener('click', toggleMenu);

        // Accordion Logic
        document.querySelectorAll('.mobile-accordion button').forEach(btn => {
            btn.addEventListener('click', () => {
                const content = btn.nextElementSibling;
                const icon = btn.querySelector('span');
                content.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            });
        });
    })();
</script>
