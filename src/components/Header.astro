<script is:inline>
    (function() {
        // Sticky/Compact Logic
        const header = document.getElementById('main-header');
        const headerInner = document.getElementById('header-inner');
        const logoIcon = document.getElementById('logo-icon');
        const logoText = document.getElementById('logo-text');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.classList.add('py-0', 'shadow-lg');
                header.classList.remove('bg-white/80');
                header.classList.add('bg-white/95');
                headerInner.classList.remove('h-20');
                headerInner.classList.add('h-16');
                logoIcon.classList.remove('w-8', 'h-8');
                logoIcon.classList.add('w-6', 'h-6', 'text-xs');
                logoText.classList.add('scale-90');
            } else {
                header.classList.remove('py-0', 'shadow-lg');
                header.classList.add('bg-white/80');
                header.classList.remove('bg-white/95');
                headerInner.classList.add('h-20');
                headerInner.classList.remove('h-16');
                logoIcon.classList.add('w-8', 'h-8');
                logoIcon.classList.remove('w-6', 'h-6', 'text-xs');
                logoText.classList.remove('scale-90');
            }
        });

        // Mobile Menu Logic
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuTrigger = document.getElementById('mobile-menu-trigger'); // From bottom bar
        const closeBtn = document.getElementById('mobile-close');
        const menu = document.getElementById('mobile-menu');

        const toggleMenu = () => {
            menu.classList.toggle('translate-x-full');
            document.body.style.overflow = menu.classList.contains('translate-x-full') ? 'auto' : 'hidden';
        };

        if(menuToggle) menuToggle.addEventListener('click', toggleMenu);
        if(menuTrigger) menuTrigger.addEventListener('click', toggleMenu);
        if(closeBtn) closeBtn.addEventListener('click', toggleMenu);

        // Accordion Logic
        document.querySelectorAll('.mobile-accordion button').forEach(btn => {
            btn.addEventListener('click', () => {
                const content = btn.nextElementSibling;
                const icon = btn.querySelector('span');
                content.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            });
        });
    })();
</script>
