---
import MegaMenuItem from './header/MegaMenuItem.astro';
import MobileAccordion from './MobileAccordion.astro';
import { navigationMenus } from '../data/navigation';

// Transform menu data into accordion format
const accordionItems = navigationMenus.map((menu) => ({
  title: menu.label,
  items: menu.submenu || []
}));
---

<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-gray-100 shadow-sm group/header">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div id="header-inner" class="flex justify-between items-center h-20 transition-all duration-500">
            <!-- Logo Section -->
            <div class="flex-shrink-0">
                <a href="/" class="text-2xl font-bold text-gray-900 tracking-tight flex items-center gap-2 group/logo transition-all" style="font-family: var(--font-headline);">
                    <span id="logo-icon" class="w-8 h-8 rounded-lg bg-primary-600 flex items-center justify-center text-white text-base transition-all group-hover/logo:rotate-12">tb</span>
                    <span id="logo-text" class="transition-all origin-left">tupbebek.com</span>
                </a>
            </div>

            <!-- Desktop Navigation (Mega-Menu) -->
            <nav class="hidden lg:flex items-center space-x-1 h-full" aria-label="Ana navigasyon">
                {navigationMenus.map((menu) => (
                    <MegaMenuItem menu={menu} />
                ))}
            </nav>

            <!-- Right Actions -->
            <div class="flex items-center gap-3 ml-auto">
                <!-- Desktop Search Icon -->
                <button id="desktop-search-btn" class="hidden md:flex min-w-[44px] min-h-[44px] items-center justify-center rounded-lg hover:bg-gray-100 transition-colors group" aria-label="Ara">
                    <span class="material-symbols-outlined text-gray-600 group-hover:text-primary-600">search</span>
                </button>

                <!-- Mobile Menu Toggle -->
                <button id="mobile-menu-toggle" class="lg:hidden min-w-[44px] min-h-[44px] flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors group" aria-label="Menüyü aç" aria-expanded="false" aria-controls="mobile-menu">
                    <span class="material-symbols-outlined text-gray-600 group-hover:text-primary-600">menu</span>
                </button>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Sidebar Menu -->
<div id="mobile-menu" class="fixed right-0 top-20 h-[calc(100vh-80px)] w-80 bg-white shadow-2xl border-l border-gray-100 transform translate-x-full transition-transform duration-300 z-40 overflow-y-auto" role="dialog" aria-label="Mobil menü">
    <div class="p-6 space-y-2">
        <button id="mobile-close" class="absolute top-4 right-4 min-w-[44px] min-h-[44px] flex items-center justify-center hover:bg-gray-100 rounded-lg transition-colors" aria-label="Menüyü kapat">
            <span class="material-symbols-outlined">close</span>
        </button>

        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mt-8 mb-4">Menü</h3>

        <!-- Mobile Menu Items -->
        <MobileAccordion items={accordionItems} />

        <hr class="my-4 border-gray-200" />

        <a href="/sss" class="block w-full p-3 min-h-[44px] rounded-lg hover:bg-primary-50 text-left font-semibold text-gray-800 transition-colors">
            SSS
        </a>
        <a href="/iletisim" class="block w-full p-3 min-h-[44px] rounded-lg hover:bg-primary-50 text-left font-semibold text-gray-800 transition-colors">
            İletişim
        </a>
    </div>
</div>

<!-- Mobile Bottom Bar -->
<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40" aria-label="Mobil navigasyon">
    <div class="flex items-center justify-around h-16">
        <a href="/" class="flex flex-col items-center justify-center gap-1 min-w-[44px] min-h-[44px] text-primary-600 transition-colors">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Ana Sayfa</span>
        </a>
        <button id="mobile-menu-trigger" class="flex flex-col items-center justify-center gap-1 min-w-[44px] min-h-[44px] text-gray-400 hover:text-primary-600 transition-colors" aria-label="Ara">
            <span class="material-symbols-outlined">search</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Ara</span>
        </button>
        <button class="flex flex-col items-center justify-center gap-1 min-w-[44px] min-h-[44px] text-gray-400 hover:text-primary-600 transition-colors" aria-label="Menü">
            <span class="material-symbols-outlined">menu</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Menü</span>
        </button>
        <a href="/sss" class="flex flex-col items-center justify-center gap-1 min-w-[44px] min-h-[44px] text-gray-400 hover:text-primary-600 transition-colors">
            <span class="material-symbols-outlined">help</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">SSS</span>
        </a>
    </div>
</nav>

<script is:inline>
    (function() {
        // Sticky/Compact Logic
        const header = document.getElementById('main-header');
        const headerInner = document.getElementById('header-inner');
        const logoIcon = document.getElementById('logo-icon');
        const logoText = document.getElementById('logo-text');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.classList.add('py-0', 'shadow-lg');
                header.classList.remove('bg-white/80');
                header.classList.add('bg-white/95');
                headerInner.classList.remove('h-20');
                headerInner.classList.add('h-16');
                logoIcon.classList.remove('w-8', 'h-8');
                logoIcon.classList.add('w-6', 'h-6', 'text-xs');
                logoText.classList.add('scale-90');
            } else {
                header.classList.remove('py-0', 'shadow-lg');
                header.classList.add('bg-white/80');
                header.classList.remove('bg-white/95');
                headerInner.classList.add('h-20');
                headerInner.classList.remove('h-16');
                logoIcon.classList.add('w-8', 'h-8');
                logoIcon.classList.remove('w-6', 'h-6', 'text-xs');
                logoText.classList.remove('scale-90');
            }
        });

        // Mobile Menu Logic
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuTrigger = document.getElementById('mobile-menu-trigger');
        const closeBtn = document.getElementById('mobile-close');
        const menu = document.getElementById('mobile-menu');

        const toggleMenu = () => {
            const isOpen = !menu.classList.contains('translate-x-full');
            menu.classList.toggle('translate-x-full');
            const nowOpen = !menu.classList.contains('translate-x-full');
            document.body.style.overflow = nowOpen ? 'hidden' : 'auto';
            if (menuToggle) menuToggle.setAttribute('aria-expanded', String(nowOpen));
            if (nowOpen) {
                menu.setAttribute('aria-modal', 'true');
                closeBtn && closeBtn.focus();
            } else {
                menu.removeAttribute('aria-modal');
                menuToggle && menuToggle.focus();
            }
        };

        if(menuToggle) menuToggle.addEventListener('click', toggleMenu);
        if(menuTrigger) menuTrigger.addEventListener('click', toggleMenu);
        if(closeBtn) closeBtn.addEventListener('click', toggleMenu);

        // Escape key closes mobile menu
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && menu && !menu.classList.contains('translate-x-full')) {
                toggleMenu();
            }
        });

        // Accordion Logic
        document.querySelectorAll('.mobile-accordion button').forEach(btn => {
            btn.addEventListener('click', () => {
                const content = btn.nextElementSibling;
                const icon = btn.querySelector('span');
                const isOpen = !content.classList.contains('hidden');
                content.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
                btn.setAttribute('aria-expanded', String(!isOpen));
            });
        });
    })();
</script>
