---
import MegaMenuItem from './header/MegaMenuItem.astro';
import MobileAccordion from './MobileAccordion.astro';
import { navigationMenus } from '../data/navigation';

// Transform menu data into accordion format
const accordionItems = navigationMenus.map((menu) => ({
  title: menu.label,
  items: menu.submenu || []
}));
---

<header id="main-header" class="fixed top-0 w-full z-[100] transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-100 shadow-sm group/header">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div id="header-inner" class="flex justify-between items-center h-20 transition-all duration-500">
            <!-- Logo Section -->
            <div class="flex-shrink-0">
                <a href="/" class="text-2xl font-serif font-bold text-slate-900 tracking-tight flex items-center gap-2 group/logo transition-all">
                    <span id="logo-icon" class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-base transition-all group-hover/logo:rotate-12">tb</span>
                    <span id="logo-text" class="transition-all origin-left">tupbebek.com</span>
                </a>
            </div>

            <!-- Desktop Navigation (Mega-Menu) -->
            <nav class="hidden lg:flex items-center space-x-1 h-full">
                {navigationMenus.map((menu) => (
                    <MegaMenuItem menu={menu} />
                ))}
            </nav>

            <!-- Right Actions -->
            <div class="flex items-center gap-3 ml-auto">
                <!-- Desktop Search Icon -->
                <button id="desktop-search-btn" class="hidden md:flex w-10 h-10 items-center justify-center rounded-lg hover:bg-slate-100 transition-colors group">
                    <span class="material-symbols-outlined text-slate-600 group-hover:text-primary">search</span>
                </button>

                <!-- Mobile Menu Toggle -->
                <button id="mobile-menu-toggle" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-lg hover:bg-slate-100 transition-colors group">
                    <span class="material-symbols-outlined text-slate-600 group-hover:text-primary">menu</span>
                </button>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Sidebar Menu -->
<div id="mobile-menu" class="fixed right-0 top-20 h-[calc(100vh-80px)] w-80 bg-white shadow-2xl border-l border-slate-100 transform translate-x-full transition-transform duration-300 z-40 overflow-y-auto">
    <div class="p-6 space-y-2">
        <button id="mobile-close" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center hover:bg-slate-100 rounded-lg transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>

        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mt-8 mb-4">Menü</h3>

        <!-- Mobile Menu Items -->
        <MobileAccordion items={accordionItems} />

        <hr class="my-4 border-slate-200" />

        <a href="/sss" class="block w-full p-3 rounded-lg hover:bg-primary/5 text-left font-semibold text-slate-800 transition-colors">
            SSS
        </a>
        <a href="/iletisim" class="block w-full p-3 rounded-lg hover:bg-primary/5 text-left font-semibold text-slate-800 transition-colors">
            İletişim
        </a>
    </div>
</div>

<!-- Mobile Bottom Bar -->
<div class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 z-40">
    <div class="flex items-center justify-around h-16">
        <a href="/" class="flex flex-col items-center gap-1 text-primary transition-colors">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Ana Sayfa</span>
        </a>
        <button id="mobile-menu-trigger" class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors">
            <span class="material-symbols-outlined">search</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Ara</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors">
            <span class="material-symbols-outlined">menu</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">Menü</span>
        </button>
        <a href="/sss" class="flex flex-col items-center gap-1 text-slate-400 hover:text-primary transition-colors">
            <span class="material-symbols-outlined">help</span>
            <span class="text-[10px] font-bold uppercase tracking-tighter">SSS</span>
        </a>
    </div>
</div>

<script is:inline>
    (function() {
        // Sticky/Compact Logic
        const header = document.getElementById('main-header');
        const headerInner = document.getElementById('header-inner');
        const logoIcon = document.getElementById('logo-icon');
        const logoText = document.getElementById('logo-text');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                header.classList.add('py-0', 'shadow-lg');
                header.classList.remove('bg-white/80');
                header.classList.add('bg-white/95');
                headerInner.classList.remove('h-20');
                headerInner.classList.add('h-16');
                logoIcon.classList.remove('w-8', 'h-8');
                logoIcon.classList.add('w-6', 'h-6', 'text-xs');
                logoText.classList.add('scale-90');
            } else {
                header.classList.remove('py-0', 'shadow-lg');
                header.classList.add('bg-white/80');
                header.classList.remove('bg-white/95');
                headerInner.classList.add('h-20');
                headerInner.classList.remove('h-16');
                logoIcon.classList.add('w-8', 'h-8');
                logoIcon.classList.remove('w-6', 'h-6', 'text-xs');
                logoText.classList.remove('scale-90');
            }
        });

        // Mobile Menu Logic
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuTrigger = document.getElementById('mobile-menu-trigger');
        const closeBtn = document.getElementById('mobile-close');
        const menu = document.getElementById('mobile-menu');

        const toggleMenu = () => {
            menu.classList.toggle('translate-x-full');
            document.body.style.overflow = menu.classList.contains('translate-x-full') ? 'auto' : 'hidden';
        };

        if(menuToggle) menuToggle.addEventListener('click', toggleMenu);
        if(menuTrigger) menuTrigger.addEventListener('click', toggleMenu);
        if(closeBtn) closeBtn.addEventListener('click', toggleMenu);

        // Accordion Logic
        document.querySelectorAll('.mobile-accordion button').forEach(btn => {
            btn.addEventListener('click', () => {
                const content = btn.nextElementSibling;
                const icon = btn.querySelector('span');
                content.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            });
        });
    })();
</script>
