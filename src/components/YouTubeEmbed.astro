---
/**
 * YouTubeEmbed — Makale içi eğitsel video bloğu
 *
 * Markdown makalelerinde ve Astro sayfalarında kullanılır.
 * Geniş beyaz boşluklar (white space) ile ferahlatılmış tasarım.
 * Lazy-load: tıklanana kadar iframe yüklenmez.
 *
 * Kullanım (Astro):
 *   <YouTubeEmbed id="dQw4w9WgXcQ" title="AMH Nedir?" />
 *
 * Kullanım (Markdown — MDX veya components ile):
 *   Bu bileşen doğrudan .mdx dosyalarında kullanılabilir.
 */
interface Props {
    /** YouTube video ID */
    id: string;
    /** Video başlığı (erişilebilirlik + görsel) */
    title?: string;
    /** Kısa açıklama (isteğe bağlı) */
    caption?: string;
    /** Video formatı */
    format?: 'landscape' | 'shorts';
}

const {
    id,
    title,
    caption,
    format = 'landscape',
} = Astro.props;

const isShorts = format === 'shorts';
const thumbnailUrl = `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
---

<figure class={`yt-embed my-12 md:my-16 ${isShorts ? 'max-w-sm mx-auto' : ''}`} data-yt-id={id} role="figure" aria-label={title || 'YouTube video'}>

    {/* Title bar */}
    {title && (
        <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-red-600 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
            </div>
            <h4 class="font-headline text-base font-bold text-gray-900">{title}</h4>
        </div>
    )}

    {/* Video container */}
    <div class={`yt-embed__player relative overflow-hidden rounded-2xl bg-gray-900 shadow-lg group cursor-pointer ${isShorts ? 'aspect-[9/16]' : 'aspect-video'}`}>
        <img
            src={thumbnailUrl}
            alt={title ? `${title} — video önizleme` : 'Video önizleme'}
            loading="lazy"
            width={isShorts ? 405 : 1280}
            height={isShorts ? 720 : 720}
            class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
        />

        {/* Play overlay */}
        <button
            class="yt-embed__play absolute inset-0 flex items-center justify-center z-10"
            aria-label={title ? `${title} videosunu oynat` : 'Videoyu oynat'}
            type="button"
        >
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-red-600/90 flex items-center justify-center shadow-2xl group-hover:bg-red-600 group-hover:scale-110 transition-all duration-300">
                <svg class="w-7 h-7 md:w-8 md:h-8 text-white ml-1" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                </svg>
            </div>
        </button>

        {/* Duration hint */}
        {isShorts && (
            <div class="absolute bottom-3 right-3 z-10 px-2 py-1 bg-black/70 rounded text-white text-xs font-semibold flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">timer</span>
                Shorts
            </div>
        )}
    </div>

    {/* Caption */}
    {caption && (
        <figcaption class="mt-3 text-xs text-gray-500 text-center leading-relaxed italic">
            {caption}
        </figcaption>
    )}
</figure>

<script>
    function initYTEmbeds() {
        document.querySelectorAll('.yt-embed__play').forEach(btn => {
            if ((btn as HTMLElement).dataset.initialized) return;
            (btn as HTMLElement).dataset.initialized = 'true';

            btn.addEventListener('click', () => {
                const figure = btn.closest('.yt-embed') as HTMLElement;
                const player = figure?.querySelector('.yt-embed__player') as HTMLElement;
                const videoId = figure?.dataset.ytId;
                if (!player || !videoId) return;

                player.innerHTML = `
                    <iframe
                        src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0"
                        title="${figure.getAttribute('aria-label') || 'YouTube video'}"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        class="absolute inset-0 w-full h-full border-0"
                    ></iframe>
                `;
            });
        });
    }

    initYTEmbeds();
    document.addEventListener('astro:after-swap', initYTEmbeds);
</script>
