---
// LoadingSkeletons.astro
// Reusable skeleton screens for different content types
// Usage: <LoadingSkeletons type="article" count={3} />

export interface Props {
  type: 'article' | 'carousel' | 'list' | 'grid' | 'card';
  count?: number;
}

const { type = 'article', count = 3 } = Astro.props;
---

{type === 'article' && (
  <div class="space-y-8 animate-pulse">
    {[...Array(count)].map(() => (
      <article class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
        <!-- Image skeleton -->
        <div class="w-full h-48 bg-slate-200 rounded-xl mb-6"></div>

        <!-- Title skeleton -->
        <div class="space-y-3 mb-4">
          <div class="h-4 bg-slate-200 rounded w-3/4"></div>
          <div class="h-4 bg-slate-200 rounded w-5/6"></div>
        </div>

        <!-- Description skeleton -->
        <div class="space-y-2 mb-6">
          <div class="h-3 bg-slate-200 rounded"></div>
          <div class="h-3 bg-slate-200 rounded"></div>
          <div class="h-3 bg-slate-200 rounded w-4/5"></div>
        </div>

        <!-- Footer skeleton -->
        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
          <div class="h-3 bg-slate-200 rounded w-1/4"></div>
          <div class="h-4 w-4 bg-slate-200 rounded"></div>
        </div>
      </article>
    ))}
  </div>
)}

{type === 'carousel' && (
  <div class="flex gap-8 overflow-x-auto pb-12 snap-x animate-pulse">
    {[...Array(count)].map(() => (
      <div class="min-w-[320px] md:min-w-[400px] bg-white rounded-3xl p-6 shadow-sm border border-slate-100">
        <!-- Image -->
        <div class="aspect-video rounded-2xl overflow-hidden mb-6 bg-slate-200"></div>

        <!-- Category tag -->
        <div class="h-6 w-24 bg-slate-200 rounded-full mb-4"></div>

        <!-- Title -->
        <div class="space-y-2 mb-4">
          <div class="h-4 bg-slate-200 rounded"></div>
          <div class="h-4 bg-slate-200 rounded w-4/5"></div>
        </div>

        <!-- Description -->
        <div class="space-y-2 mb-6">
          <div class="h-3 bg-slate-200 rounded"></div>
          <div class="h-3 bg-slate-200 rounded"></div>
        </div>

        <!-- Footer -->
        <div class="flex justify-between pt-4 border-t border-slate-100">
          <div class="h-3 bg-slate-200 rounded w-1/3"></div>
          <div class="h-4 w-4 bg-slate-200 rounded"></div>
        </div>
      </div>
    ))}
  </div>
)}

{type === 'list' && (
  <div class="space-y-4 animate-pulse">
    {[...Array(count)].map(() => (
      <div class="flex gap-4 p-4 bg-white rounded-lg border border-slate-100">
        <!-- Icon/Image -->
        <div class="w-12 h-12 bg-slate-200 rounded-lg flex-shrink-0"></div>

        <!-- Content -->
        <div class="flex-1 space-y-2">
          <div class="h-4 bg-slate-200 rounded w-1/2"></div>
          <div class="h-3 bg-slate-200 rounded w-3/4"></div>
        </div>

        <!-- Action -->
        <div class="w-6 h-6 bg-slate-200 rounded flex-shrink-0"></div>
      </div>
    ))}
  </div>
)}

{type === 'grid' && (
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 animate-pulse">
    {[...Array(count)].map(() => (
      <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
        <!-- Image -->
        <div class="w-full h-40 bg-slate-200 rounded-lg mb-4"></div>

        <!-- Title -->
        <div class="h-4 bg-slate-200 rounded w-3/4 mb-3"></div>

        <!-- Description -->
        <div class="space-y-2 mb-4">
          <div class="h-3 bg-slate-200 rounded"></div>
          <div class="h-3 bg-slate-200 rounded w-5/6"></div>
        </div>

        <!-- Button -->
        <div class="h-8 bg-slate-200 rounded-lg"></div>
      </div>
    ))}
  </div>
)}

{type === 'card' && (
  <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 animate-pulse">
    <!-- Header -->
    <div class="flex justify-between items-start mb-6">
      <div class="space-y-2">
        <div class="h-4 bg-slate-200 rounded w-1/3"></div>
        <div class="h-6 bg-slate-200 rounded w-1/2"></div>
      </div>
      <div class="w-12 h-12 bg-slate-200 rounded-lg"></div>
    </div>

    <!-- Content -->
    <div class="space-y-3 mb-6">
      <div class="h-3 bg-slate-200 rounded"></div>
      <div class="h-3 bg-slate-200 rounded"></div>
      <div class="h-3 bg-slate-200 rounded w-4/5"></div>
    </div>

    <!-- Footer -->
    <div class="flex gap-2 pt-6 border-t border-slate-100">
      <div class="h-8 bg-slate-200 rounded-lg flex-1"></div>
      <div class="h-8 bg-slate-200 rounded-lg flex-1"></div>
    </div>
  </div>
)}

<style>
  @keyframes shimmer {
    0% {
      background-position: -1000px 0;
    }
    100% {
      background-position: 1000px 0;
    }
  }

  .animate-pulse {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    background-size: 1000px 100%;
    animation: shimmer 2s infinite;
  }
</style>
