---
/**
 * Editorial Hero Section — Healthline-inspired
 * Featured article with large image, category badge, bold title, excerpt
 * Clean, content-focused layout with generous whitespace
 */
import { getPublishedArticles } from '../../utils/articles';

const articles = await getPublishedArticles();
const featured = articles.find(a => a.data.featured) || articles[0];
const featuredDate = featured?.data.lastModified || featured?.data.publishDate;
const formattedDate = featuredDate ? new Date(featuredDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---

<section class="pt-28 pb-8 lg:pb-12">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">

    <!-- Featured Article Hero -->
    {featured && (
      <a href={`/makaleler/${featured.slug}`} class="group block">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">

          <!-- Image -->
          <div class="relative rounded-2xl overflow-hidden aspect-[16/10] lg:aspect-[4/3]">
            <img
              src={featured.data.image}
              alt={featured.data.imageAlt || featured.data.title}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
              width="720"
              height="540"
            />
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-4 lg:gap-5">
            <!-- Category Badge -->
            <span class="inline-flex items-center self-start px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide bg-primary-50 text-primary-700 border border-primary-100">
              {featured.data.category}
            </span>

            <!-- Title -->
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-gray-900 leading-tight group-hover:text-primary-700 transition-colors duration-300">
              {featured.data.title}
            </h2>

            <!-- Excerpt -->
            <p class="text-base lg:text-lg text-gray-500 leading-relaxed line-clamp-3">
              {featured.data.description}
            </p>

            <!-- Meta -->
            <div class="flex items-center gap-3 text-sm text-gray-400 pt-1">
              <span class="font-medium text-gray-600">{typeof featured.data.author === 'string' ? featured.data.author : featured.data.author?.name}</span>
              {formattedDate && (
                <>
                  <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                  <time datetime={featuredDate instanceof Date ? featuredDate.toISOString() : ''}>{formattedDate}</time>
                </>
              )}
            </div>

            <!-- Read More -->
            <span class="inline-flex items-center gap-2 text-primary-600 font-bold text-sm pt-2 group-hover:gap-3 transition-all duration-300">
              Devamını Oku
              <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </span>
          </div>
        </div>
      </a>
    )}

    <!-- Trust Bar -->
    <div class="mt-10 lg:mt-14 pt-8 border-t border-gray-100">
      <div class="flex flex-wrap items-center justify-between gap-6">
        <p class="text-sm text-gray-500 max-w-md">
          1996'dan beri bağımsız, reklamsız, bilimsel bir üreme sağlığı rehberi.
        </p>
        <div class="flex items-center gap-4">
          <span class="text-xs font-bold text-gray-400 border border-gray-200 px-2.5 py-1 rounded-md">ESHRE</span>
          <span class="text-xs font-bold text-gray-400 border border-gray-200 px-2.5 py-1 rounded-md">ASRM</span>
          <span class="text-xs font-bold text-gray-400 border border-gray-200 px-2.5 py-1 rounded-md">WHO</span>
          <span class="text-xs font-bold text-gray-400 border border-gray-200 px-2.5 py-1 rounded-md">0 Reklam</span>
        </div>
      </div>
    </div>
  </div>
</section>
