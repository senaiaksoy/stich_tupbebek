---
/**
 * Modern Hero Section for Homepage
 * Features:
 * - Glassmorphism design
 * - Gradient text
 * - CTA buttons
 * - Search bar with filters
 */

import HeroSearch from '../HeroSearch.astro';

// Get search data from collection
const { getPublishedArticles } = await import('../../utils/articles');
const articles = await getPublishedArticles();

const searchData = articles.map(article => ({
  id: article.id,
  title: article.data.title,
  description: article.data.description,
  url: `/makaleler/${article.slug}`,
  category: article.data.category || 'makale',
  type: 'article' as const
}));
---

<section class="pt-28 pb-12 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100/50 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-50 rounded-full blur-3xl animate-pulse" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-8 lg:pr-8 animate-fade-in-up">
        <!-- Main Heading with Animated Gradient -->
        <div class="space-y-4">
          <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tighter">
            <span class="bg-gradient-to-r from-gray-900 via-primary to-gray-900 bg-clip-text text-transparent animate-gradient">
              Bilimsel Derinlik,
            </span>
            <br/>
            <span class="text-gray-900 drop-shadow-sm">Insani Hassasiyet</span>
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed max-w-lg font-medium">
            1996'dan beri bagimsiz, reklamsiz, bilimsel bir infertilite rehberi. Her ciftin bir umudu, her sorunun bir cevabi vardir.
          </p>
        </div>

        <!-- CTA Buttons with Enhanced Hovers -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="/tani-sureci"
            class="inline-flex items-center justify-center px-8 py-4 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-all hover:scale-105 hover-glow gap-3 group shadow-lg shadow-primary-600/20"
          >
            Tani Sureci
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
              arrow_forward
            </span>
          </a>
          <a
            href="/tedavi-yontemleri"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-900 font-bold rounded-xl hover:bg-gray-50 transition-all border border-gray-200 hover:border-primary-200 gap-3 group"
          >
            Tedavi Yontemleri
            <span class="material-symbols-outlined text-xl group-hover:rotate-12 transition-transform">
              biotech
            </span>
          </a>
        </div>

        <!-- Quick Trust Indicators -->
        <div class="flex items-center gap-6 pt-4 border-t border-gray-100 max-w-sm">
           <div class="flex flex-col">
              <span class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Standardizasyon</span>
              <div class="flex gap-3 opacity-60 grayscale hover:grayscale-0 transition-all cursor-default">
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">ESHRE</span>
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">ASRM</span>
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">WHO</span>
              </div>
           </div>
        </div>
      </div>

      <!-- Right: Search & Visual -->
      <div class="relative lg:ml-auto w-full max-w-lg animate-fade-in-up" style="animation-delay: 0.2s;">
        <!-- Hero Image Card -->
        <div class="w-full rounded-2xl overflow-hidden shadow-lg mb-6 hover:shadow-xl transition-shadow duration-500 group">
          <img
            src="/images/home/luxury-embryo.webp"
            alt="Embryo gelisimi - IVF tedavisi"
            class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform duration-700"
          />
        </div>

        <!-- Glowing Search Container -->
        <div class="glass-card rounded-[2.5rem] p-8 relative z-10 overflow-hidden hover-glow transition-all duration-500 group">
          <!-- Background decoration in search card -->
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-50/50 rounded-full blur-3xl group-hover:bg-primary-50 transition-colors"></div>

          <div class="relative z-20">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-bold text-gray-900">Rehberlerde Ara</h2>
              <span class="material-symbols-outlined text-primary animate-pulse-soft">search_spark</span>
            </div>

            <!-- Hero Inline Search -->
            <HeroSearch searchData={searchData} placeholder="PCOS, IVF, AMH Testi..." />

            <!-- Quick Category Filters with Modern Style -->
            <div class="flex flex-wrap gap-2 mt-6" id="category-filters">
              <button
                type="button"
                data-category="kadin"
                class="category-filter px-4 py-2 text-xs font-bold text-gray-600 bg-gray-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-gray-200/50"
                onclick="dispatchCategoryFilter('kadin')"
              >
                <span class="material-symbols-outlined text-[16px]">female</span>Kadin
              </button>
              <button
                type="button"
                data-category="erkek"
                class="category-filter px-4 py-2 text-xs font-bold text-gray-600 bg-gray-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-gray-200/50"
                onclick="dispatchCategoryFilter('erkek')"
              >
                <span class="material-symbols-outined text-[16px]">male</span>Erkek
              </button>
              <button
                type="button"
                data-category="tedavi"
                class="category-filter px-4 py-2 text-xs font-bold text-gray-600 bg-gray-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-gray-200/50"
                onclick="dispatchCategoryFilter('tedavi')"
              >
                <span class="material-symbols-outined text-[16px]">medical_services</span>Tedavi
              </button>
            </div>
          </div>
        </div>

        <!-- Decorative background glow for the whole right col -->
        <div class="absolute -inset-4 bg-primary-50/50 blur-3xl -z-10 rounded-full animate-pulse-soft"></div>
      </div>

        <!-- Featured Stats Card -->
        <div class="bg-gradient-to-br from-primary-50 to-primary-100/50 rounded-2xl p-6 border border-primary-200">
          <div class="space-y-4">
            <div>
              <p class="text-4xl font-bold text-primary">60+</p>
              <p class="text-sm text-gray-600 mt-1">Bilimsel Makale</p>
            </div>
            <div class="border-t border-primary-200 pt-4">
              <p class="text-2xl font-bold text-gray-900">40-50%</p>
              <p class="text-sm text-gray-600 mt-1">IVF Basari Orani (35 yas alti)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Glassmorphism effect */
  .backdrop-blur-xl {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
  }
</style>

<script is:inline>
  function dispatchCategoryFilter(category) {
    // Visual active state
    document.querySelectorAll('.category-filter').forEach(btn => {
      btn.classList.remove('bg-primary', 'text-white');
    });
    event?.target?.closest('button')?.classList.add('bg-primary', 'text-white');

    // Dispatch event for HeroSearch
    window.dispatchEvent(new CustomEvent('hero-filter-change', {
      detail: { category }
    }));
  }
</script>
