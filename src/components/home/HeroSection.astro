---
/**
 * Modern Hero Section for Homepage
 * Features:
 * - Glassmorphism design
 * - Gradient text
 * - CTA buttons
 * - Search bar with filters
 */

import SearchAutocomplete from '../SearchAutocomplete.astro';
import type { Props as SearchProps } from '../SearchAutocomplete.astro';

// Get search data from collection
const { getCollection } = await import('astro:content');
const articles = await getCollection('articles');

const searchData = articles.map(article => ({
  id: article.id,
  title: article.data.title,
  description: article.data.description,
  url: `/makaleler/${article.slug}`,
  category: article.data.category || 'makale',
  type: 'article' as const
}));
---

<section class="pt-28 pb-12 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/15 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-8 lg:pr-8 animate-fade-in-up">
        <!-- Main Heading with Animated Gradient -->
        <div class="space-y-4">
          <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tighter">
            <span class="bg-gradient-to-r from-slate-900 via-primary to-slate-900 bg-clip-text text-transparent animate-gradient">
              Bilimsel Derinlik,
            </span>
            <br/>
            <span class="text-slate-900 drop-shadow-sm">İnsani Hassasiyet</span>
          </h1>
          <p class="text-xl text-slate-600 leading-relaxed max-w-lg font-medium">
            1996'dan beri bağımsız, reklamsız, bilimsel bir infertilite rehberi. Her çiftin bir umudu, her sorunun bir cevabı vardır.
          </p>
        </div>

        <!-- CTA Buttons with Enhanced Hovers -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="/tani-sureci"
            class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition-all hover:scale-105 hover-glow gap-3 group shadow-lg shadow-primary/20"
          >
            Tanı Süreci
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
              arrow_forward
            </span>
          </a>
          <a
            href="/tedavi-yontemleri"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-xl hover:bg-slate-50 transition-all border border-slate-200 hover:border-primary/30 gap-3 group"
          >
            Tedavi Yöntemleri
            <span class="material-symbols-outlined text-xl group-hover:rotate-12 transition-transform">
              biotech
            </span>
          </a>
        </div>
        
        <!-- Quick Trust Indicators -->
        <div class="flex items-center gap-6 pt-4 border-t border-slate-100 max-w-sm">
           <div class="flex flex-col">
              <span class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-1">Standardizasyon</span>
              <div class="flex gap-3 opacity-60 grayscale hover:grayscale-0 transition-all cursor-default">
                 <span class="text-xs font-bold text-slate-900 border border-slate-300 px-1.5 py-0.5 rounded">ESHRE</span>
                 <span class="text-xs font-bold text-slate-900 border border-slate-300 px-1.5 py-0.5 rounded">ASRM</span>
                 <span class="text-xs font-bold text-slate-900 border border-slate-300 px-1.5 py-0.5 rounded">WHO</span>
              </div>
           </div>
        </div>
      </div>

      <!-- Right: Search & Visual -->
      <div class="relative lg:ml-auto w-full max-w-lg animate-fade-in-up" style="animation-delay: 0.2s;">
        <!-- Hero Image Card -->
        <div class="w-full rounded-2xl overflow-hidden shadow-lg mb-6 hover:shadow-xl transition-shadow duration-500 group">
          <img
            src="/images/home/luxury-embryo.webp"
            alt="Embryo gelişimi - IVF tedavisi"
            class="w-full h-64 object-cover transform group-hover:scale-105 transition-transform duration-700"
          />
        </div>

        <!-- Glowing Search Container -->
        <div class="glass-card rounded-[2.5rem] p-8 relative z-10 overflow-hidden hover-glow transition-all duration-500 group">
          <!-- Background decoration in search card -->
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/5 rounded-full blur-3xl group-hover:bg-primary/10 transition-colors"></div>
          
          <div class="relative z-20">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-bold text-slate-900">Rehberlerde Ara</h2>
              <span class="material-symbols-outlined text-primary animate-pulse-soft">search_spark</span>
            </div>

            <!-- Integrated Search Autocomplete -->
            <div id="hero-search-container" class="relative group/input">
              <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-primary/0 rounded-2xl blur opacity-0 group-focus-within/input:opacity-100 transition duration-500"></div>
              <SearchAutocomplete
                searchData={searchData}
                placeholder="PCOS, IVF, AMH Testi..."
                class="max-w-none relative"
              />
            </div>

            <!-- Quick Category Filters with Modern Style -->
            <div class="flex flex-wrap gap-2 mt-6" id="category-filters">
              <button
                type="button"
                data-category="kadin"
                class="category-filter px-4 py-2 text-xs font-bold text-slate-600 bg-slate-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-slate-200/50"
              >
                <span class="material-symbols-outlined text-[16px]">female</span>Kadın
              </button>
              <button
                type="button"
                data-category="erkek"
                class="category-filter px-4 py-2 text-xs font-bold text-slate-600 bg-slate-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-slate-200/50"
              >
                <span class="material-symbols-outlined text-[16px]">male</span>Erkek
              </button>
              <button
                type="button"
                data-category="tedavi"
                class="category-filter px-4 py-2 text-xs font-bold text-slate-600 bg-slate-100/50 rounded-full hover:bg-primary hover:text-white transition-all inline-flex items-center gap-1.5 border border-slate-200/50"
              >
                <span class="material-symbols-outlined text-[16px]">medical_services</span>Tedavi
              </button>
            </div>
          </div>
        </div>

        <!-- Decorative background glow for the whole right col -->
        <div class="absolute -inset-4 bg-primary/5 blur-3xl -z-10 rounded-full animate-pulse-soft"></div>
      </div>

        <!-- Featured Stats Card -->
        <div class="bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl p-6 border border-primary/20">
          <div class="space-y-4">
            <div>
              <p class="text-4xl font-bold text-primary">60+</p>
              <p class="text-sm text-slate-600 mt-1">Bilimsel Makale</p>
            </div>
            <div class="border-t border-primary/20 pt-4">
              <p class="text-2xl font-bold text-slate-900">40-50%</p>
              <p class="text-sm text-slate-600 mt-1">IVF Başarı Oranı (35 yaş altı)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Glassmorphism effect */
  .backdrop-blur-xl {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
  }
</style>

<script is:inline>
  // Hero search: onclick handler for the Keşfet button
  // Returns false to prevent default <a> navigation when JS works,
  // falls back to /makaleler if JS is disabled (since it's an <a>).
  function heroSearch() {
    var input = document.getElementById('hero-search-input');
    var query = input && input.value.trim();
    if (query) {
      document.getElementById('hero-search-btn').href = '/makaleler?q=' + encodeURIComponent(query);
    }
    // Return true so the <a> follows the (possibly updated) href
    return true;
  }

  // Enter key support
  var searchInput = document.getElementById('hero-search-input');
  if (searchInput) {
    searchInput.onkeydown = function(e) {
      if (e.key === 'Enter' || e.keyCode === 13) {
        e.preventDefault();
        heroSearch();
        var btn = document.getElementById('hero-search-btn');
        if (btn) btn.click();
      }
    };
  }
</script>

