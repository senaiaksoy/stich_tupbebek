---
/**
 * Modern Hero Section for Homepage
 * Features:
 * - Glassmorphism design
 * - Gradient text
 * - CTA buttons
 * - Simplified visual layout (Search removed as requested)
 */

// Get published articles (for stats or featured if needed - keeping it for future use or removing if completely unused)
// const { getPublishedArticles } = await import('../../utils/articles');
---

<section class="pt-28 pb-12 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100/50 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-50 rounded-full blur-3xl animate-pulse" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-8 lg:pr-8 animate-fade-in-up">
        <!-- Main Heading with Animated Gradient -->
        <div class="space-y-4">
          <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tighter">
            <span class="bg-gradient-to-r from-gray-900 via-primary to-gray-900 bg-clip-text text-transparent animate-gradient">
              Bilimsel Derinlik,
            </span>
            <br/>
            <span class="text-gray-900 drop-shadow-sm">Insani Hassasiyet</span>
          </h1>
          <p class="text-xl text-gray-600 leading-relaxed max-w-lg font-medium">
            1996'dan beri bagimsiz, reklamsiz, bilimsel bir infertilite rehberi. Her ciftin bir umudu, her sorunun bir cevabi vardir.
          </p>
        </div>

        <!-- CTA Buttons with Enhanced Hovers -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="/tani-sureci"
            class="inline-flex items-center justify-center px-8 py-4 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-all hover:scale-105 hover-glow gap-3 group shadow-lg shadow-primary-600/20"
          >
            Tani Sureci
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
              arrow_forward
            </span>
          </a>
          <a
            href="/tedavi-yontemleri"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-900 font-bold rounded-xl hover:bg-gray-50 transition-all border border-gray-200 hover:border-primary-200 gap-3 group"
          >
            Tedavi Yontemleri
            <span class="material-symbols-outlined text-xl group-hover:rotate-12 transition-transform">
              biotech
            </span>
          </a>
        </div>

        <!-- Quick Trust Indicators -->
        <div class="flex items-center gap-6 pt-4 border-t border-gray-100 max-w-sm">
           <div class="flex flex-col">
              <span class="text-[10px] uppercase tracking-widest text-gray-400 font-bold mb-1">Standardizasyon</span>
              <div class="flex gap-3 opacity-60 grayscale hover:grayscale-0 transition-all cursor-default">
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">ESHRE</span>
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">ASRM</span>
                 <span class="text-xs font-bold text-gray-900 border border-gray-300 px-1.5 py-0.5 rounded">WHO</span>
              </div>
           </div>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="relative lg:ml-auto w-full max-w-lg animate-fade-in-up" style="animation-delay: 0.2s;">
        <!-- Hero Image Card - Enlarged since search is removed -->
        <div class="w-full rounded-[2.5rem] overflow-hidden shadow-2xl mb-8 hover:shadow-primary-600/10 transition-shadow duration-700 group relative">
          <img
            src="/images/home/luxury-embryo.webp"
            alt="Embryo gelisimi - IVF tedavisi"
            class="w-full h-80 object-cover transform group-hover:scale-105 transition-transform duration-1000"
          />
          <!-- Decorative Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-primary-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        </div>

        <!-- Featured Stats Card -->
        <div class="bg-white/70 backdrop-blur-md rounded-[2rem] p-10 border border-white shadow-xl relative z-10 overflow-hidden group hover:border-primary-200 transition-all duration-500">
          <div class="absolute -top-12 -right-12 w-24 h-24 bg-primary-50 rounded-full blur-2xl opacity-50 group-hover:opacity-100 transition-opacity"></div>
          
          <div class="grid grid-cols-2 gap-8 relative z-20">
            <div>
              <p class="text-4xl lg:text-5xl font-extrabold text-primary-600 mb-2">30+</p>
              <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Yıllık Tecrübe</p>
            </div>
            <div class="border-l border-gray-100 pl-8">
              <p class="text-4xl lg:text-5xl font-extrabold text-gray-900 mb-2">40-50%</p>
              <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Başarı Oranı</p>
            </div>
          </div>
        </div>

        <!-- Decorative background glow -->
        <div class="absolute -inset-10 bg-primary-50/30 blur-3xl -z-10 rounded-full animate-pulse-soft"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Glassmorphism effect */
  .backdrop-blur-xl {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
  }
</style>
