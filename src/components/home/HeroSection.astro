---
/**
 * Modern Hero Section for Homepage
 * Features:
 * - Glassmorphism design
 * - Gradient text
 * - CTA buttons
 * - Search bar with filters
 */

import SearchAutocomplete from '../SearchAutocomplete.astro';
import type { Props as SearchProps } from '../SearchAutocomplete.astro';

// Get search data from collection
const { getCollection } = await import('astro:content');
const articles = await getCollection('articles');

const searchData = articles.map(article => ({
  id: article.id,
  title: article.data.title,
  description: article.data.description,
  url: `/makaleler/${article.slug}`,
  category: article.data.category || 'makale',
  type: 'article' as const
}));
---

<section class="pt-28 pb-12 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-6 lg:pr-8">
        <!-- Main Heading with Gradient -->
        <div>
          <h1 class="text-5xl lg:text-6xl font-bold tracking-tight">
            <span class="bg-gradient-to-r from-slate-900 via-primary to-slate-900 bg-clip-text text-transparent">
              Bilimsel Derinlik,
            </span>
            <br/>
            <span class="text-slate-900">İnsani Hassasiyet</span>
          </h1>
        </div>

        <!-- Subtitle -->
        <p class="text-lg text-slate-600 leading-relaxed max-w-md">
          1996'dan beri bağımsız, reklamsız, bilimsel bir infertilite rehberi. Her çiftin umudu vardır.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 pt-4">
          <a
            href="/tani-sureci"
            class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors gap-2 group"
          >
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
              arrow_forward
            </span>
            Tanı Süreci
          </a>
          <a
            href="/tedavi-yontemleri"
            class="inline-flex items-center justify-center px-6 py-3 bg-slate-100 text-slate-900 font-bold rounded-lg hover:bg-slate-200 transition-colors gap-2 group"
          >
            <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
              lab_profile
            </span>
            Tedavi Yöntemleri
          </a>
          <a
            href="/sss"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-slate-200 text-slate-900 font-bold rounded-lg hover:bg-slate-50 transition-colors gap-2"
          >
            <span class="material-symbols-outlined text-xl">help</span>
            SSS
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="flex flex-col gap-3 pt-4 border-t border-slate-200">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-xl">verified</span>
            </div>
            <div class="text-sm">
              <p class="font-bold text-slate-900">1996'dan Beri</p>
              <p class="text-slate-600">Güvenilir bilimsel rehberlik</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-xl">school</span>
            </div>
            <div class="text-sm">
              <p class="font-bold text-slate-900">Akademik Danışmanlar</p>
              <p class="text-slate-600">Yayın kurulu tarafından denetlenmiş</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Search & Visual -->
      <div class="space-y-6">
        <!-- Search Section -->
        <div class="bg-white/50 backdrop-blur-xl rounded-2xl p-6 border border-white/20 shadow-xl">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Hızlı Rehber Bul</h2>

          <!-- Search Bar -->
          <div class="relative mb-4">
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-3.5 text-slate-400">
                search
              </span>
              <input
                id="hero-search"
                type="text"
                placeholder="PCOS, Endometriozis, IVF..."
                class="w-full pl-12 pr-4 py-3 rounded-lg border border-slate-200 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
              />
            </div>
          </div>

          <!-- Quick Category Filter -->
          <div class="grid grid-cols-3 gap-2">
            <button class="hero-filter px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 rounded-lg hover:bg-primary hover:text-white transition-colors" data-category="kadin">
              <span class="material-symbols-outlined inline text-[16px] mr-1 align-text-bottom">female</span>Kadın
            </button>
            <button class="hero-filter px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 rounded-lg hover:bg-primary hover:text-white transition-colors" data-category="erkek">
              <span class="material-symbols-outlined inline text-[16px] mr-1 align-text-bottom">male</span>Erkek
            </button>
            <button class="hero-filter px-3 py-2 text-xs font-semibold text-slate-600 bg-slate-100 rounded-lg hover:bg-primary hover:text-white transition-colors" data-category="tedavi">
              <span class="material-symbols-outlined inline text-[16px] mr-1 align-text-bottom">medical_services</span>Tedavi
            </button>
          </div>
        </div>

        <!-- Featured Stats Card -->
        <div class="bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl p-6 border border-primary/20">
          <div class="space-y-4">
            <div>
              <p class="text-4xl font-bold text-primary">60+</p>
              <p class="text-sm text-slate-600 mt-1">Bilimsel Makale</p>
            </div>
            <div class="border-t border-primary/20 pt-4">
              <p class="text-2xl font-bold text-slate-900">40-50%</p>
              <p class="text-sm text-slate-600 mt-1">IVF Başarı Oranı (35 yaş altı)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Glassmorphism effect */
  .backdrop-blur-xl {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
  }
</style>

<script>
  // Hero search and filter functionality
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('hero-search');
    const filterButtons = document.querySelectorAll('.hero-filter');

    // Search functionality
    if (searchInput) {
      searchInput.addEventListener('keyup', (e) => {
        if (e.key === 'Enter') {
          const query = searchInput.value.trim();
          if (query) {
            window.location.href = `/makaleler?search=${encodeURIComponent(query)}`;
          }
        }
      });
    }

    // Category filter functionality
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const category = btn.dataset.category;
        window.location.href = `/makaleler?category=${category}`;
      });
    });
  });
</script>
