---
/**
 * Editorial Magazine — Rehberler & Kaynaklar
 * 2 large hero cards (image-dominant) + 4 compact cards (color-coded icons)
 * Replaces both old QuickGuideCards and "Temel Eğitim Rehberleri" sections
 */
import { guideCategories, getColorScheme } from '../../data/guideCategories';

// Hero cards — the two most important guides (with images)
const heroCards = [
  {
    href: '/kadin-infertilitesi',
    image: '/images/home/kadin-infertilitesi.webp',
    imageAlt: 'Kadın infertilitesi - üreme sağlığı değerlendirmesi',
    category: 'Kadın Sağlığı',
    title: 'Kadın İnfertilitesi Rehberi',
    description: 'PCOS, endometriozis, tubal faktörler ve tedavi seçenekleri hakkında kapsamlı bilimsel rehber.',
  },
  {
    href: '/erkek-infertilitesi',
    image: '/images/home/erkek-infertilitesi.webp',
    imageAlt: 'Erkek infertilitesi değerlendirmesi - doktor ve hasta görüşmesi',
    category: 'Erkek Sağlığı',
    title: 'Erkek İnfertilitesi Rehberi',
    description: 'Sperm sağlığı, azospermi, varikosel ve hormonal dengesizlikler hakkında bilgi edinin.',
  },
];

// Compact cards — remaining guides with color-coded icons
const compactCards = [
  {
    ...guideCategories.find(g => g.id === 'tani-sureci')!,
    subtitle: 'Hormon paneli, genetik testler ve ultrason',
  },
  {
    ...guideCategories.find(g => g.id === 'tedavi-yontemleri')!,
    subtitle: 'IVF, IUI, cerrahi ve diğer seçenekler',
  },
  {
    ...guideCategories.find(g => g.id === 'fertilite-koruma')!,
    subtitle: 'Yumurta dondurma ve sperm saklama',
  },
  {
    ...guideCategories.find(g => g.id === 'psikolojik-destek')!,
    subtitle: 'Stres yönetimi ve psikolojik rehber',
  },
];
---

<section class="py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-10 lg:mb-14">
      <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-3">
        Rehberler & Kaynaklar
      </h2>
      <p class="text-base text-gray-500 max-w-xl">
        İnfertilite yolculuğunuzun her aşaması için kapsamlı, bilimsel rehberler.
      </p>
    </div>

    <!-- Hero Cards — 2 large image-dominant cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      {heroCards.map((card) => (
        <a
          href={card.href}
          class="group relative flex flex-col bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md hover:border-primary-100 transition-all duration-300"
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={card.image}
              alt={card.imageAlt}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              width="640" height="360" loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6 flex flex-col gap-2 flex-1">
            <span class="text-[10px] font-bold uppercase tracking-widest text-primary-600">{card.category}</span>
            <h3 class="text-lg lg:text-xl font-bold text-gray-900 leading-snug group-hover:text-primary-700 transition-colors">
              {card.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed flex-1">
              {card.description}
            </p>
            <span class="inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold pt-1 group-hover:gap-2.5 transition-all">
              Rehbere Git <span class="material-symbols-outlined text-base">arrow_forward</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Compact Cards — 4 color-coded icon cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {compactCards.map((card) => {
        const colors = getColorScheme(card.color);
        return (
          <a
            href={card.href}
            class:list={[
              "group flex items-start gap-4 p-5 bg-white rounded-xl border hover:shadow-md transition-all duration-300",
              colors.border,
              `hover:${colors.bg}`,
            ]}
          >
            <div class:list={[
              "w-10 h-10 rounded-lg flex items-center justify-center shrink-0 transition-colors",
              colors.bg,
            ]}>
              <span class:list={["material-symbols-outlined text-lg", colors.icon]}>{card.icon}</span>
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-primary-700 transition-colors leading-snug mb-1">
                {card.title}
              </h3>
              <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">
                {card.subtitle}
              </p>
            </div>
            <span class="material-symbols-outlined text-gray-300 group-hover:text-primary-600 group-hover:translate-x-0.5 transition-all text-base mt-0.5 shrink-0">arrow_forward</span>
          </a>
        );
      })}
    </div>
  </div>
</section>
