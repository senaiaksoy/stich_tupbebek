---
/**
 * Quick Guide Cards — Healthline-inspired clean editorial cards
 * White backgrounds, subtle borders, generous whitespace
 */
import { guideCategories } from '../../data/guideCategories';
---

<section class="py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-10 lg:mb-14">
      <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-3">
        Rehberler & Kaynaklar
      </h2>
      <p class="text-base text-gray-500 max-w-xl">
        İnfertilite yolculuğunuzun her aşaması için kapsamlı, bilimsel rehberler.
      </p>
    </div>

    <!-- Guide Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {guideCategories.map((guide) => (
        <a
          href={guide.href}
          class="group flex flex-col gap-4 p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-200 hover:shadow-md transition-all duration-300"
        >
          <!-- Icon -->
          <div class="w-11 h-11 rounded-lg bg-primary-50 flex items-center justify-center group-hover:bg-primary-100 transition-colors">
            <span class="material-symbols-outlined text-primary-600 text-xl">{guide.icon}</span>
          </div>

          <!-- Title -->
          <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary-700 transition-colors leading-snug">
            {guide.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 flex-1">
            {guide.description}
          </p>

          <!-- Arrow -->
          <span class="inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold group-hover:gap-2.5 transition-all duration-300">
            Detaylı Rehber
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
