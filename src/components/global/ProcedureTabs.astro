---
/**
 * ProcedureTabs — Cerrahi/tibbi prosedur sekmeleri
 *
 * Uzun tibbi metinleri "Nedir?", "Islem Sureci", "Iyilesme" gibi
 * sekmelere bolen WCAG uyumlu tab bileseni.
 *
 * Kullanim:
 *   <ProcedureTabs
 *     id="laparoskopi"
 *     tabs={[
 *       { label: "Nedir?", icon: "info", content: "..." },
 *       { label: "Islem Sureci", icon: "surgical", content: "..." },
 *       { label: "Iyilesme", icon: "healing", content: "..." },
 *     ]}
 *   />
 *
 * Veya slot ile:
 *   <ProcedureTabs id="hsg" tabs={tabsMeta}>
 *     <div slot="tab-0">Custom HTML content...</div>
 *   </ProcedureTabs>
 */
interface TabItem {
    label: string;
    icon?: string;
    content?: string;
}

interface Props {
    id: string;
    tabs: TabItem[];
    color?: 'primary' | 'mint' | 'apricot';
}

const { id, tabs, color = 'primary' } = Astro.props;

const colorMap = {
    primary: {
        activeBg: 'bg-primary-600',
        activeText: 'text-white',
        activeBorder: 'border-primary-600',
        iconBg: 'bg-primary-50',
        iconText: 'text-primary-600',
    },
    mint: {
        activeBg: 'bg-mint-600',
        activeText: 'text-white',
        activeBorder: 'border-mint-600',
        iconBg: 'bg-mint-50',
        iconText: 'text-mint-600',
    },
    apricot: {
        activeBg: 'bg-apricot-500',
        activeText: 'text-white',
        activeBorder: 'border-apricot-500',
        iconBg: 'bg-apricot-50',
        iconText: 'text-apricot-600',
    },
};

const c = colorMap[color];
---

<div class="procedure-tabs-wrapper" data-procedure-tabs={id}>
    <!-- Tab Buttons -->
    <div
        class="flex flex-wrap gap-2 mb-6 border-b border-gray-200 pb-4"
        role="tablist"
        aria-label="Prosedur asamalari"
    >
        {tabs.map((tab, index) => (
            <button
                role="tab"
                id={`${id}-tab-${index}`}
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`${id}-panel-${index}`}
                data-tab-index={index}
                class:list={[
                    "proc-tab flex items-center gap-2 px-5 py-3 min-h-[44px] rounded-lg text-sm font-semibold transition-all duration-200 border-2 cursor-pointer",
                    index === 0
                        ? `${c.activeBg} ${c.activeText} ${c.activeBorder} shadow-sm`
                        : "bg-white text-gray-600 border-gray-200 hover:border-gray-300 hover:bg-gray-50"
                ]}
            >
                {tab.icon && (
                    <span class="material-symbols-outlined text-base">{tab.icon}</span>
                )}
                {tab.label}
            </button>
        ))}
    </div>

    <!-- Tab Panels -->
    {tabs.map((tab, index) => (
        <div
            role="tabpanel"
            id={`${id}-panel-${index}`}
            aria-labelledby={`${id}-tab-${index}`}
            data-panel-index={index}
            class:list={[
                "proc-panel transition-all duration-300",
                index === 0 ? "" : "hidden"
            ]}
        >
            <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8">
                <!-- Panel Header -->
                <div class="flex items-center gap-3 mb-5">
                    {tab.icon && (
                        <div class:list={["w-10 h-10 rounded-xl flex items-center justify-center shrink-0", c.iconBg]}>
                            <span class:list={["material-symbols-outlined text-xl", c.iconText]}>{tab.icon}</span>
                        </div>
                    )}
                    <h3 class="font-headline text-lg font-bold text-gray-900">{tab.label}</h3>
                </div>

                <!-- Panel Content -->
                <div class="prose prose-sm max-w-none prose-gray
                    prose-headings:font-headline prose-headings:text-gray-900
                    prose-p:text-gray-600 prose-p:leading-[1.75]
                    prose-li:text-gray-600 prose-li:leading-[1.75]
                    prose-ul:space-y-2
                    prose-strong:text-gray-900">
                    {tab.content ? (
                        <Fragment set:html={tab.content} />
                    ) : (
                        <slot name={`tab-${index}`} />
                    )}
                </div>
            </div>
        </div>
    ))}
</div>

<script is:inline>
(function() {
    document.querySelectorAll('[data-procedure-tabs]').forEach(function(wrapper) {
        var tabs = wrapper.querySelectorAll('.proc-tab');
        var panels = wrapper.querySelectorAll('.proc-panel');
        var id = wrapper.getAttribute('data-procedure-tabs');

        // Find active color classes from first tab
        var firstTab = tabs[0];
        var activeClasses = [];
        var inactiveClasses = ['bg-white', 'text-gray-600', 'border-gray-200'];
        if (firstTab) {
            firstTab.classList.forEach(function(cls) {
                if (cls.startsWith('bg-') && cls !== 'bg-white') activeClasses.push(cls);
                if (cls.startsWith('text-') && cls !== 'text-gray-600') activeClasses.push(cls);
                if (cls.startsWith('border-') && cls !== 'border-gray-200') activeClasses.push(cls);
                if (cls === 'shadow-sm') activeClasses.push(cls);
            });
        }

        function activateTab(index) {
            tabs.forEach(function(tab, i) {
                var isActive = i === index;
                tab.setAttribute('aria-selected', String(isActive));
                if (isActive) {
                    inactiveClasses.forEach(function(c) { tab.classList.remove(c); });
                    activeClasses.forEach(function(c) { tab.classList.add(c); });
                } else {
                    activeClasses.forEach(function(c) { tab.classList.remove(c); });
                    inactiveClasses.forEach(function(c) { tab.classList.add(c); });
                }
            });

            panels.forEach(function(panel, i) {
                if (i === index) {
                    panel.classList.remove('hidden');
                    panel.style.opacity = '0';
                    panel.style.transform = 'translateY(8px)';
                    requestAnimationFrame(function() {
                        panel.style.transition = 'opacity 300ms ease, transform 300ms ease';
                        panel.style.opacity = '1';
                        panel.style.transform = 'translateY(0)';
                    });
                } else {
                    panel.classList.add('hidden');
                }
            });
        }

        tabs.forEach(function(tab, i) {
            tab.addEventListener('click', function() { activateTab(i); });

            // Keyboard navigation
            tab.addEventListener('keydown', function(e) {
                var tabsArr = Array.from(tabs);
                var next = -1;
                if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                    next = (i + 1) % tabsArr.length;
                } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                    next = (i - 1 + tabsArr.length) % tabsArr.length;
                }
                if (next >= 0) {
                    e.preventDefault();
                    tabsArr[next].focus();
                    activateTab(next);
                }
            });
        });
    });
})();
</script>
