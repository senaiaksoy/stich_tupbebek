---
/**
 * MedicalTooltip — Tibbi terim tooltip bileseni
 *
 * Metin icerisinde tibbi terimlerin uzerine gelindiginde
 * anlamini sik bir baloncukta gosterir.
 *
 * Kullanim:
 *   <MedicalTooltip term="PGT" definition="Preimplantasyon Genetik Test. Embriyo transferi oncesinde genetik anomalileri taramak icin yapilan test." />
 *   <MedicalTooltip term="AMH" definition="Anti-Mullerian Hormon. Over rezervinin olculmesinde kullanilan bir hormon degeri." href="/hormon-paneli" />
 */
interface Props {
    term: string;
    definition: string;
    href?: string;
}

const { term, definition, href } = Astro.props;
const tooltipId = `tooltip-${term.toLowerCase().replace(/[^a-z0-9]/g, '-')}`;
---

<span class="medical-tooltip-wrapper relative inline-block">
    <button
        type="button"
        class="medical-term inline-flex items-center gap-0.5 text-primary-600 font-semibold border-b border-dashed border-primary-300 hover:border-primary-600 cursor-help transition-colors"
        aria-describedby={tooltipId}
        data-tooltip-target={tooltipId}
    >
        {term}
        <span class="material-symbols-outlined text-[12px] opacity-60">info</span>
    </button>
    <span
        id={tooltipId}
        role="tooltip"
        class="medical-tooltip-bubble absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-72 p-4 bg-gray-900 text-white text-xs leading-relaxed rounded-xl shadow-2xl opacity-0 invisible pointer-events-none transition-all duration-200 z-50"
    >
        <strong class="block text-sm text-primary-300 mb-1">{term}</strong>
        <span class="text-gray-300">{definition}</span>
        {href && (
            <a href={href} class="block mt-2 text-primary-400 hover:text-primary-300 text-[11px] font-semibold">
                Detayli bilgi &rarr;
            </a>
        )}
        <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-px w-0 h-0 border-l-[6px] border-r-[6px] border-t-[6px] border-l-transparent border-r-transparent border-t-gray-900"></span>
    </span>
</span>

<style>
    .medical-tooltip-wrapper:hover .medical-tooltip-bubble,
    .medical-tooltip-wrapper:focus-within .medical-tooltip-bubble {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateX(-50%) translateY(-4px);
    }
</style>
