---
/**
 * AuthorBox — Yazar guvenilirlik bileseni
 *
 * Makale veya sayfa yazarinin kimlik bilgilerini,
 * tibbi inceleme durumunu ve yeterliliklerini gosterir.
 *
 * Kullanim:
 *   <AuthorBox
 *     name="Dr. Ayse Yilmaz"
 *     title="Ureme Endokrinolojisi Uzmani"
 *     credentials="ESHRE Uyeligi"
 *     reviewedBy="Prof. Dr. Mehmet Demir"
 *   />
 */
interface Props {
    name: string;
    title?: string;
    credentials?: string;
    reviewedBy?: string;
    reviewDate?: string;
    avatarIcon?: string;
}

const {
    name,
    title,
    credentials,
    reviewedBy,
    reviewDate,
    avatarIcon = 'person',
} = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-2xl p-5 md:p-6">
    <div class="flex flex-col sm:flex-row items-start gap-4">
        <!-- Avatar -->
        <div class="w-14 h-14 rounded-full bg-primary-50 flex items-center justify-center shrink-0 ring-2 ring-primary-100">
            <span class="material-symbols-outlined text-primary-600 text-2xl" style="font-variation-settings: 'FILL' 1;">{avatarIcon}</span>
        </div>

        <!-- Author Info -->
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
                <h4 class="font-headline text-base font-bold text-gray-900">{name}</h4>
                <span class="material-symbols-outlined text-primary-600 text-lg" style="font-variation-settings: 'FILL' 1;" title="Dogrulanmis yazar">verified</span>
            </div>
            {title && (
                <p class="text-sm text-gray-600 mb-1">{title}</p>
            )}
            {credentials && (
                <p class="text-xs text-mint-700 font-semibold flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">workspace_premium</span>
                    {credentials}
                </p>
            )}
        </div>

        <!-- Medical Review Badge -->
        {reviewedBy && (
            <div class="sm:ml-auto shrink-0 bg-mint-50 border border-mint-200 rounded-xl px-4 py-3 text-center">
                <p class="text-[10px] text-gray-500 uppercase tracking-wider font-semibold mb-1">Tibbi Inceleme</p>
                <p class="text-xs font-bold text-mint-700">{reviewedBy}</p>
                {reviewDate && (
                    <p class="text-[10px] text-gray-400 mt-0.5">{reviewDate}</p>
                )}
            </div>
        )}
    </div>
</div>
