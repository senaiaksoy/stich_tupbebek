---
/**
 * MedicalDisclaimer — Otomatik yasal uyari modulu
 *
 * Her tibbi icerik sayfasinin altina otomatik eklenen
 * sticky yasal uyari. BaseLayout veya ArticleLayout
 * icinde kullanilir.
 *
 * Kullanim:
 *   <MedicalDisclaimer />
 *   <MedicalDisclaimer variant="compact" />
 *   <MedicalDisclaimer sticky />
 */
interface Props {
    variant?: 'full' | 'compact';
    sticky?: boolean;
}

const { variant = 'full', sticky = false } = Astro.props;
---

{variant === 'full' ? (
    <aside
        class:list={[
            "medical-disclaimer",
            sticky && "sticky bottom-0 z-40",
        ]}
        role="note"
        aria-label="Tıbbi sorumluluk reddi"
    >
        <div class="max-w-4xl mx-auto px-6">
            <div class="bg-gray-50 border border-gray-200 rounded-2xl p-5 md:p-6 shadow-sm">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-amber-600 text-xl">gavel</span>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-gray-900 mb-2">Tıbbi Sorumluluk Reddi</h4>
                        <p class="text-xs text-gray-600 leading-relaxed mb-3">
                            Bu içerik, <strong>tupbebek.com yayın kurulu</strong> tarafından tıbbi doğruluk ve güncel klinik protokoller açısından incelenmiş ve onaylanmıştır. Sunulan bilgiler <strong>genel bilgilendirme amaçlıdır</strong>; kişisel tıbbi tanı veya tedavi yerine geçmez.
                        </p>
                        <p class="text-xs text-gray-700 font-semibold flex items-center gap-1.5 bg-amber-50 px-3 py-2 rounded-lg border border-amber-100">
                            <span class="material-symbols-outlined text-amber-600 text-[16px]">warning</span>
                            Sağlık kararları için mutlaka bir hekime danışınız. Bu içerik tıbbi tanı ve tedavi yerine geçmez.
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-4 mt-4 pt-3 border-t border-gray-200 text-[10px] text-gray-400 uppercase tracking-wider">
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">balance</span>
                        T.C. Sağlık Bakanlığı Yönetmeliğine Uygun
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">verified</span>
                        TTB Etik Kurallarına Uygun
                    </span>
                </div>
            </div>
        </div>
    </aside>
) : (
    <aside
        class:list={[
            "medical-disclaimer-compact",
            sticky && "sticky bottom-0 z-40",
        ]}
        role="note"
        aria-label="Tıbbi sorumluluk reddi"
    >
        <div class="max-w-4xl mx-auto px-6">
            <div class="flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 text-xs text-amber-800">
                <span class="material-symbols-outlined text-amber-600 text-[18px] shrink-0">warning</span>
                <p>
                    <strong>Yasal Uyarı:</strong> Bu içerik genel bilgilendirme amaçlıdır. Tıbbi tanı ve tedavi yerine geçmez. Sağlık kararları için mutlaka bir hekime danışınız.
                </p>
            </div>
        </div>
    </aside>
)}
