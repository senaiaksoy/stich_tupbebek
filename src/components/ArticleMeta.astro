---
interface Props {
  reviewedBy?: string;
  reviewDate?: string;
  source?: string;
  lastUpdated?: string;
}

const { reviewedBy = "tupbebek.com Yayın Kurulu", reviewDate, source, lastUpdated } = Astro.props;
---

<div class="flex flex-col md:flex-row items-start md:items-center gap-4 p-4 bg-blue-50 border-l-4 border-primary rounded-lg text-sm">
  <div class="flex items-center gap-2 flex-1">
    <span class="material-symbols-outlined text-primary-600 text-lg">verified_user</span>
    <div>
      <p class="font-semibold text-gray-800">Tıbbi İnceleme</p>
      <p class="text-xs text-gray-600">
        {reviewedBy}
        {reviewDate && ` • ${reviewDate}`}
      </p>
    </div>
  </div>

  <div class="text-xs text-gray-500 md:border-l md:border-gray-300 md:pl-4">
    {source && <p>Kaynak: <span class="font-semibold">{source}</span></p>}
    {lastUpdated && <p>Son Güncelleme: {lastUpdated}</p>}
    {!source && !lastUpdated && <p>Güncel literatüre dayanmaktadır</p>}
  </div>
</div>

<style>
  p {
    margin: 0;
  }
</style>
