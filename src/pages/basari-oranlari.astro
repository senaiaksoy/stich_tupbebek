---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Tüp Bebek Başarı Oranları ve Klinik İstatistikler | tupbebek.com" description="Yaş gruplarına göre tüp bebek başarı oranları, döngüye göre kümülatif başarı, tedavi yöntemlerine göre karşılaştırmalar ve uluslararası veriler.">
    <Header />

    <main class="pb-24">
        <!-- Hero Section -->
        <header class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-semibold uppercase tracking-wider mb-6">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">verified</span>
                        Klinik İstatistik
                    </div>
                    <h1 class="font-headline text-5xl md:text-6xl text-on-surface leading-tight mb-8">
                        Başarı Oranları: <span class="text-primary italic">Verilerle</span> Gerçekler
                    </h1>
                    <div class="flex items-center gap-4 p-4 bg-surface-container-low rounded-xl border-l-4 border-primary">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-dim">
                            <img class="w-full h-full object-cover" src="/images/senai-aksoy.jpg" alt="Dr. Senai Aksoy" width="512" height="512" loading="eager" fetchpriority="high"/>
                        </div>
                        <div>
                            <p class="font-headline italic text-on-surface text-sm">Tıbbi İnceleme:</p>
                            <p class="font-bold text-primary">Dr. Senai Aksoy</p>
                        </div>
                    </div>
                </div>
                <div class="hidden md:block w-72 shrink-0 aspect-[4/5] bg-surface-container-highest rounded-2xl overflow-hidden shadow-2xl">
                    <img class="w-full h-full object-cover grayscale opacity-80" src="/images/sorunlar/cell-biology.jpg" alt="Başarı oranları" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
            </div>
        </header>

        <!-- Scientific Introduction -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed font-body italic mb-12">
                Tüp bebek (IVF) başarı oranları, birçok faktöre bağlıdır: yaş, embriyo kalitesi, over rezervi, erkek faktörleri ve klinik deneyimi. Aşağıdaki veriler, güncel literatür ve uluslararası veritabanlarına dayalı genel tahminlerdir; bireysel durumunuz için doktorunuza danışınız.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">trending_up</span>
                    <h3 class="font-bold text-sm mb-2">%40-45</h3>
                    <p class="text-xs text-on-surface-variant mb-0">Genel IVF canlı doğum oranı (35 yaş altı)</p>
                </div>
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">monitoring</span>
                    <h3 class="font-bold text-sm mb-2">%30-35</h3>
                    <p class="text-xs text-on-surface-variant mb-0">35-38 yaş arası canlı doğum oranı</p>
                </div>
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">science</span>
                    <h3 class="font-bold text-sm mb-2">%15-20</h3>
                    <p class="text-xs text-on-surface-variant mb-0">&gt;40 yaş canlı doğum oranı</p>
                </div>
            </div>
        </section>

        <!-- Quick-Nav Bar -->
        <nav id="quick-nav" class="sticky top-20 z-40 bg-white/90 backdrop-blur-sm border-b border-slate-100 shadow-sm mb-16">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 overflow-x-auto whitespace-nowrap">
                <div class="flex items-center gap-1 py-3">
                    <a href="#yas" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Yaşa Göre</a>
                    <a href="#cumulative" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Kümülatif Başarı</a>
                    <a href="#comparison" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Karşılaştırma</a>
                    <a href="#international" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Uluslararası</a>
                    <a href="#factors" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Faktörler</a>
                </div>
            </div>
        </nav>

        <!-- Section 1: Yaşa Göre Başarı Oranları -->
        <section id="yas" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">1. Yaşa Göre Başarı Oranları</h2>
                        <div class="space-y-6 text-on-surface-variant">
                            <p>
                                Kadın yaşı, tüp bebek (IVF) başarısını belirleyen en önemli faktördür. Yaşla birlikte oosit sayısı ve kalitesi düşer; bu da embriyo kalitesini ve implantasyon potansiyelini doğrudan etkiler. Her yıl yaşlanma, oosit rezervi ve kromozomal normal oranlarını olumsuz etkiler.
                            </p>
                            <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                                <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">biotech</span>
                                    Yaş Grubu ve Başarı Oranları (Canlı Doğum / Transfer)
                                </h4>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="border-b border-outline-variant/20">
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Yaş Grubu</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Oosit Başkalım</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Pregnant/Oosit</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">İns Oosit Sayısı</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">&lt;30</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%90-97</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%8-10</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">10-15</td>
                                            </tr>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">30-34</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%90-95</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%6-8</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">15-20</td>
                                            </tr>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">35-37</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%85-90</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%4-6</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">20-25</td>
                                            </tr>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">38-40</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%80-85</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%2-4</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">25-30</td>
                                            </tr>
                                            <tr>
                                                <td class="py-2 pr-4 font-semibold text-on-surface">&gt;40</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%75-80</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%1-2</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">Bireysel</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Yaşa göre başarı" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">İns Oosit</p>
                                <p class="text-2xl font-headline">15-20</p>
                                <p class="text-[10px] text-on-surface-variant">35 yaş hedefi canlı doğum için</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 2: Kümülatif Başarı -->
        <section id="cumulative" class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-on-surface mb-6">2. Döngüye Göre Kümülatif Başarı</h2>
                    <div class="space-y-6 text-on-surface-variant">
                        <p>
                            Tek döngüde gebelik oranı düşük görünebilir; ancak kümülatif (toplam) başarı oranı, birden fazla deneme sonrasında çok daha yüksektir. Her döngü, bir öncekinin deneyimiyle optimize edilir.
                        </p>
                        <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                            <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">monitoring</span>
                                Kümülatif Gebelik ve Canlı Doğum Oranları
                            </h4>
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-outline-variant/20">
                                        <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Döngü</th>
                                        <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">&lt;35 yaş</th>
                                        <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">35-38 yaş</th>
                                        <th class="text-left py-2 font-semibold text-on-surface-variant">&gt;38 yaş</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-outline-variant/10">
                                        <td class="py-2 pr-4 font-semibold text-on-surface">1. Döngü</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%35-40</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%25-30</td>
                                        <td class="py-2 text-on-surface-variant">%15-20</td>
                                    </tr>
                                    <tr class="border-b border-outline-variant/10">
                                        <td class="py-2 pr-4 font-semibold text-on-surface">2. Döngü</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%55-60</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%45-50</td>
                                        <td class="py-2 text-on-surface-variant">%25-30</td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 pr-4 font-semibold text-on-surface">3. Döngü</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%65-70</td>
                                        <td class="py-2 pr-4 text-on-surface-variant">%55-60</td>
                                        <td class="py-2 text-on-surface-variant">%30-35</td>
                                    </tr>
                                </tbody>
                            </table>
                            <p class="text-xs text-on-surface-variant mt-3">Kaynak: McLernan et al., ESHRE, 2020</p>
                        </div>
                        <p class="text-sm text-on-surface-variant">
                            Kümülatif gebelik oranları, taze ve dondurulmuş embryo transferlerinin (FET) kombinasyonu ile hesaplanmıştır. Bu veri, "kaç döngüye denemeliyim" sorusuna en iyi cevabı verir.
                        </p>
                    </div>
                </div>
                <div class="md:w-1/2">
                    <div class="relative group">
                        <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Kümülatif başarı oranları" width="512" height="512" loading="lazy"/>
                        <div class="absolute -bottom-6 -left-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                            <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                            <p class="text-2xl font-headline">~70%</p>
                            <p class="text-[10px] text-on-surface-variant">3. döngüde canlı doğum</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 3: Tedavi Yöntemine Göre Karşılaştırma -->
        <section id="comparison" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">3. Tedavi Yöntemine Göre Karşılaştırma</h2>
                        <div class="space-y-6 text-on-surface-variant">
                            <p>
                                IVF, ICSI ve dondurulmuş embryio transferleri (FET) farklı prosedürlerdir ve farklı başarı profillerine sahiptir. Aşağıdaki karşılaştırma, her yöntemin genel klinik verilerini gösterir.
                            </p>
                            <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                                <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">biotech</span>
                                    Karşılaştırma: IVF vs ICSI vs FET
                                </h4>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="border-b border-outline-variant/20">
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Parametre</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">IVF</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">ICSI</th>
                                                <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">FET</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">Canlı Doğum / Transfer</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%35-40</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%35-42</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%40-45</td>
                                            </tr>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">Gebelik Oranı</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%33-38</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%35-40</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%40-50</td>
                                            </tr>
                                            <tr class="border-b border-outline-variant/10">
                                                <td class="py-2 pr-4 font-semibold text-on-surface">Düşük Oranı</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%15-20</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%12-18</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">%10-15</td>
                                            </tr>
                                            <tr>
                                                <td class="py-2 pr-4 font-semibold text-on-surface">En İyi Kullanım</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">Normal sperm</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">Erkek faktör</td>
                                                <td class="py-2 pr-4 text-on-surface-variant">Önceki başarısız IVF</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <p class="text-sm text-on-surface-variant">
                                Veriler, ortalama klinik verilerdir. Bireysel durumunuz doktorunuz tarafından daha doğru değerlendirilebilir.
                            </p>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Tedavi karşılaştırma" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                                <p class="text-2xl font-headline">%45</p>
                                <p class="text-[10px] text-on-surface-variant">FET canlı doğum oranı</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 4: Uluslararası Karşılaştırma -->
        <section id="international" class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-on-surface mb-6">4. Uluslararası Karşılaştırma</h2>
                    <div class="space-y-6 text-on-surface-variant">
                        <p>
                            Farklı ülkelerdeki IVF başarı oranları, hasta profilleri, klinik protokol ve yasal çerçeveler nedeniyle değişiklik gösterebilir. Türkiye, Avrupa ortalamasına yakın veriler sunmaktadır.
                        </p>
                        <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                            <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">public</span>
                                Türkiye vs Diğer Ülkeler (Canlı Doğum / Transfer)
                            </h4>
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="border-b border-outline-variant/20">
                                            <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">Ülke</th>
                                            <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">&lt;35 yaş</th>
                                            <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">35-38 yaş</th>
                                            <th class="text-left py-2 pr-4 font-semibold text-on-surface-variant">&gt;38 yaş</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="border-b border-outline-variant/10">
                                            <td class="py-2 pr-4 font-semibold text-on-surface">Türkiye</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%35-40</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%25-30</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%15-20</td>
                                        </tr>
                                        <tr class="border-b border-outline-variant/10">
                                            <td class="py-2 pr-4 font-semibold text-on-surface">ABD</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%40-45</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%30-35</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%20-25</td>
                                        </tr>
                                        <tr class="border-b border-outline-variant/10">
                                            <td class="py-2 pr-4 font-semibold text-on-surface">İspanya</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%38-43</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%28-33</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%18-22</td>
                                        </tr>
                                        <tr>
                                            <td class="py-2 pr-4 font-semibold text-on-surface">İngiltere</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%32-37</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%23-28</td>
                                            <td class="py-2 pr-4 text-on-surface-variant">%12-18</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="md:w-1/2">
                    <div class="relative group">
                        <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Uluslararası karşılaştırma" width="512" height="512" loading="lazy"/>
                        <div class="absolute -bottom-6 -left-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                            <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                            <p class="text-2xl font-headline">40-45</p>
                            <p class="text-[10px] text-on-surface-variant">ABD en yüksek oranları</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 5: Başarıyı Etkileyen Faktörler -->
        <section id="factors" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">5. Başarıyı Etkileyen Faktörler</h2>
