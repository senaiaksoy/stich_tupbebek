---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StatsStrip from '../components/StatsStrip.astro';
import RelatedContent from '../components/RelatedContent.astro';
import DisclaimerBar from '../components/DisclaimerBar.astro';
---

<BaseLayout title="İnfertilite ve Duygusal Destek | tupbebek.com" description="İnfertilite tedavi sürecinde duygusal destek, stres yönetimi, psikolojik zorluklar ve baş etme stratejileri.">
    <Header />

    <main id="main-content" tabindex="-1" class="pb-24">
        <!-- Hero Section -->
        <header class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-mint-100 text-mint-700 rounded-full text-xs font-semibold uppercase tracking-wider mb-6">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">psychology</span>
                        Rehber
                    </div>
                    <h1 class="font-headline text-5xl md:text-6xl text-gray-900 leading-tight mb-8">
                        İnfertilite ve <span class="text-primary-600 italic">Duygusal Destek</span>
                    </h1>
                    <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border-l-4 border-primary">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-200">
                            <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                        </div>
                        <div>
                            <p class="font-headline italic text-gray-900 text-sm">İnceleme:</p>
                            <p class="font-bold text-primary-600">Doç. Yayın Kurulu</p>
                        </div>
                    </div>
                </div>
                <div class="hidden md:block w-72 shrink-0 aspect-[4/5] bg-gray-100 rounded-2xl overflow-hidden shadow-2xl">
                    <img class="w-full h-full object-cover grayscale opacity-80" src="/images/sorunlar/hormonal-cycles.webp" alt="Duygusal destek" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
            </div>
        </header>

        <!-- Scientific Introduction -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <p class="text-lg md:text-xl text-gray-600 leading-relaxed font-body italic mb-12">
                İnfertilite tedavisi fiziksel kadar duygusal bir yolculuktur. İnfertilite tanısı, tedavi süreci ve başarısızlık deneyimleri çiftlerde anksiyete, depresyon, ilişki sorunları ve kimlik krizi yaratabilir. Bu rehberde duygusal destek ve baş etme stratejilerini inceleyeceğiz.
            </p>
            <StatsStrip items={[
              { icon: 'favorite', heading: '%40-50', text: 'İnfertilite hastalarında klinik depresyon veya anksiyete' },
              { icon: 'groups', heading: 'Destek', text: 'Profesyonel rehber ve topluluk desteği kritik' },
              { icon: 'check_circle', heading: 'Bilimsel', text: 'Terapi sonuçları tedavi başarı oranını artırıyor' }
            ]} />
        </section>

        <!-- Quick-Nav -->
        <nav id="quick-nav" class="sticky top-20 z-40 bg-white/90 backdrop-blur-sm border-b border-gray-100 shadow-sm mb-16">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 overflow-x-auto whitespace-nowrap">
                <div class="flex items-center gap-1 py-3">
                    <a href="#duygusal-etki" class="quick-nav-link px-4 py-2 text-sm font-semibold text-gray-500 hover:text-primary-600 rounded-lg transition-colors shrink-0">Duygusal Etki</a>
                    <a href="#yasam-kalitesi" class="quick-nav-link px-4 py-2 text-sm font-semibold text-gray-500 hover:text-primary-600 rounded-lg transition-colors shrink-0">Yaşam Kalitesi</a>
                    <a href="#iletisim" class="quick-nav-link px-4 py-2 text-sm font-semibold text-gray-500 hover:text-primary-600 rounded-lg transition-colors shrink-0">İletişim</a>
                    <a href="#basetme" class="quick-nav-link px-4 py-2 text-sm font-semibold text-gray-500 hover:text-primary-600 rounded-lg transition-colors shrink-0">Baş Etme</a>
                    <a href="#kaynaklar" class="quick-nav-link px-4 py-2 text-sm font-semibold text-gray-500 hover:text-primary-600 rounded-lg transition-colors shrink-0">Kaynaklar</a>
                </div>
            </div>
        </nav>

        <!-- Section 1: Duygusal Etki -->
        <section id="duygusal-etki" class="bg-gray-50 py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-gray-900 mb-6">1. İnfertilite Teşhisinin Duygusal Etkisi</h2>
                        <div class="space-y-4 text-gray-600">
                            <p>
                                İnfertilite tanısı beklenmeyen bir krizdir. Geleceğe dair beklentiler değişir, kendine dair varsayımlar sorgulanır. Çiftler sırasıyla inkar, öfke, pazarlık, depresyon ve kabul aşamalarından geçerler.
                            </p>
                            <div class="space-y-4 text-sm">
                                <div class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm">
                                    <span class="font-mono font-bold text-red-600 shrink-0">1</span>
                                    <span class="text-gray-600"><strong>İnkar:</strong> "Bunu yapamaz. Kesinlikle yanlış bir teşhis olmalı."</span>
                                </div>
                                <div class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm">
                                    <span class="font-mono font-bold text-amber-600 shrink-0">2</span>
                                    <span class="text-gray-600"><strong>Öfke:</strong> "Neden ben? Bu adil değil. Hiç haklı değilim."</span>
                                </div>
                                <div class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm">
                                    <span class="font-mono font-bold text-primary-600 shrink-0">3</span>
                                    <span class="text-gray-600"><strong>Pazarlık:</strong> "Eğer bu sayede gebelik olursa, hiç şikayet etmeyeceğim."</span>
                                </div>
                                <div class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm">
                                    <span class="font-mono font-bold text-primary-600 shrink-0">4</span>
                                    <span class="text-gray-600"><strong>Depresyon:</strong> Umut kaybı, yalnızlık ve boşluk hissi</span>
                                </div>
                                <div class="flex items-start gap-4 bg-white rounded-xl p-4 shadow-sm">
                                    <span class="font-mono font-bold text-primary-600 shrink-0">5</span>
                                    <span class="text-gray-600"><strong>Kabul:</strong> Durum kabul edilir ve yeni bir plan yapılır</span>
                                </div>
                            </div>
                            <p>
                                Bu sürecin hızı ve şiddeti kişiden kişiye değişir. <a href="/kadin-infertilitesi" class="text-primary-600 hover:underline">Kadın faktörü</a> veya <a href="/erkek-infertilitesi" class="text-primary-600 hover:underline">erkek faktörü</a> olması farklı duygusal tepkilere neden olabilir.
                            </p>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.webp" alt="Duygusal destek" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-gray-100 p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary-600 tracking-widest uppercase mb-1">Gerçek</p>
                                <p class="text-2xl font-headline">5 Aşama</p>
                                <p class="text-[10px] text-gray-600">Duygusal işleme süreci</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 2: Yaşam Kalitesi -->
        <section id="yasam-kalitesi" class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-gray-900 mb-6">2. İnfertilite Tedavisi Sırasında Yaşam Kalitesi</h2>
                    <div class="space-y-4 text-gray-600">
                        <p>
                            IVF ve diğer tedavi dönemleri yoğun ve streslidir. Aylık döngüler, enjeksiyonlar, muayaneler, bekleme ve belki de başarısızlık - her şey ruh halini etkiler.
                        </p>
                        <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                            <div class="space-y-4 text-sm">
                                <div>
                                    <strong class="text-gray-900">Fiziksel Etkiler:</strong>
                                    <p class="text-xs text-gray-600 mt-1">İlaç yan etkileri, uyku bozukluğu, libido değişiklikleri, testis ağrısı</p>
                                </div>
                                <div>
                                    <strong class="text-gray-900">Psikolojik Etkiler:</strong>
                                    <p class="text-xs text-gray-600 mt-1">Anksiyete, depresyon, obsesif düşünceler, kontrol kaybı hissi</p>
                                </div>
                                <div>
                                    <strong class="text-gray-900">Sosyal Etkiler:</strong>
                                    <p class="text-xs text-gray-600 mt-1">İzolasyon, hamile kadınlardan kaçınma, geri çekilme</p>
                                </div>
                                <div>
                                    <strong class="text-gray-900">Finansal Etkiler:</strong>
                                    <p class="text-xs text-gray-600 mt-1">Tedavi maliyeti, iş kaybı, finansal stres</p>
                                </div>
                            </div>
                        </div>
                        <p>
                            <a href="/rehberler" class="text-primary-600 hover:underline">Tedavi rehberlerimiz</a> sayfasında her aşamada neler bekleneceğini anlatmıştık. Bilinenlerin stres azaltmaya yardımcı olduğunu biliyoruz.
                        </p>
                    </div>
                </div>
                <div class="md:w-1/2">
                    <div class="relative group">
                        <img class="rounded-2xl shadow-xl w-full" src="/images/rehberler/clinical-prep.webp" alt="Yaşam kalitesi" width="512" height="512" loading="lazy"/>
                        <div class="absolute -bottom-6 -left-6 bg-gray-100 p-4 rounded-lg hidden md:block">
                            <p class="text-xs font-bold text-primary-600 tracking-widest uppercase mb-1">Önemli</p>
                            <p class="text-2xl font-headline">Bilgi</p>
                            <p class="text-[10px] text-gray-600">Kaygı azaltmaya yardımcı</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 3: İletişim -->
        <section id="iletisim" class="bg-gray-50 py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="max-w-3xl mx-auto">
                    <h2 class="font-headline text-3xl text-gray-900 mb-6">3. Çift İletişimi ve İlişki</h2>
                    <div class="space-y-4 text-gray-600">
                        <p>
                            İnfertilite, ilişkileri zorlayabilir. Kadın ve erkek farklı şekillerde tepki verirler. Seks tedaviye bağlı hale gelir, içgüdüsel bir eylem olmaktan çıkar. Kulüpler paylaşımlar hesaplamaya dönüşür.
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-white border-l-4 border-red-500 rounded-xl p-4">
                                <strong class="text-red-600 text-sm block mb-2">❌ Etkili Olmayan İletişim</strong>
                                <ul class="text-xs text-gray-600 space-y-1">
                                    <li>• Suçlama ve öfke gösterme</li>
                                    <li>• Duygularınızı gizleme</li>
                                    <li>• Seks hakkında şikayet etme</li>
                                    <li>• Diğer kararları kontrol etmeye çalışma</li>
                                </ul>
                            </div>
                            <div class="bg-white border-l-4 border-green-500 rounded-xl p-4">
                                <strong class="text-green-600 text-sm block mb-2">✓ Etkili İletişim</strong>
                                <ul class="text-xs text-gray-600 space-y-1">
                                    <li>• Duygularınızı açık söyleyin</li>
                                    <li>• Partnerinizi dinleyin</li>
                                    <li>• Yardımcı olduğu aktiviteler bulun</li>
                                    <li>• Birlikte kararlar alın</li>
                                </ul>
                            </div>
                        </div>
                        <p>
                            <strong>Özel anlar:</strong> Tedavi süreci sırasında cinsel ilişki zorlayıcı hale gelebilir. Alternatif yakınlık formlarını keşfetmek ilişkiyi güçlendirebilir.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 4: Baş Etme Stratejileri -->
        <section id="basetme" class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <h2 class="font-headline text-3xl text-gray-900 mb-6">4. Duygusal Baş Etme Stratejileri</h2>
            <div class="space-y-6 text-gray-600">
                <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">groups</span>
                        <h3 class="font-bold text-gray-900">Destek Grupları ve Topluluklar</h3>
                    </div>
                    <p class="text-sm mb-3">
                        Benzer deneyimleri yaşayan diğer çiftler ile bağlantı kurmak çok güçlüdür. Online veya yüz yüze destek grupları:
                    </p>
                    <ul class="text-sm space-y-1 list-disc list-inside text-gray-600">
                        <li>Normalizasyon (siz yalnız değilsiniz)</li>
                        <li>Pratik ipuçları ve deneyim paylaşımı</li>
                        <li>Duygusal doğrulama ve anlayış</li>
                        <li>Umut ve cesaret</li>
                    </ul>
                </div>

                <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">psychology</span>
                        <h3 class="font-bold text-gray-900">Profesyonel Psikolojik Destek</h3>
                    </div>
                    <p class="text-sm mb-3">
                        Bilişsel davranışçı terapi (CBT), kabul ve taahhüt terapisi (ACT), ve terapist danışmanlığı infertilite kaygısında etkilidir.
                    </p>
                    <ul class="text-sm space-y-1 list-disc list-inside text-gray-600">
                        <li>Olumsuz düşünceler saptama ve değiştirme</li>
                        <li>Mindfullness ve meditasyon teknikleri</li>
                        <li>Çift terapisi (ilişki sorunları için)</li>
                        <li><a href="/psikolojik-destek" class="text-primary-600 hover:underline">Psikolojik destek kaynakları</a></li>
                    </ul>
                </div>

                <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">spa</span>
                        <h3 class="font-bold text-gray-900">Kendine Bakım ve Yaşam Tarzı</h3>
                    </div>
                    <p class="text-sm mb-3">
                        Fiziksel sağlık, zihinsel sağlığı destekler. <a href="/beslenme-yasam" class="text-primary-600 hover:underline">Beslenme ve yaşam tarzı</a> önemlidir:
                    </p>
                    <ul class="text-sm space-y-1 list-disc list-inside text-gray-600">
                        <li>Düzenli egzersiz (stress hormonu azaltır)</li>
                        <li>Meditasyon, yoga, tai-chi</li>
                        <li>Yeterli uyku ve dinlenme</li>
                        <li>Hobi ve eğlenceli aktiviteler</li>
                        <li>Beden çalışması ve masaj</li>
                    </ul>
                </div>

                <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">book</span>
                        <h3 class="font-bold text-gray-900">Bilgi ve Empowerment</h3>
                    </div>
                    <p class="text-sm mb-3">
                        Durumunuzu anlamak kontrol hissi verir:
                    </p>
                    <ul class="text-sm space-y-1 list-disc list-inside text-gray-600">
                        <li><a href="/tani-sureci" class="text-primary-600 hover:underline">Tanı süreci</a> hakkında bilgi edinin</li>
                        <li><a href="/rehberler" class="text-primary-600 hover:underline">Tedavi rehberlerini</a> okuyun</li>
                        <li><a href="/sss" class="text-primary-600 hover:underline">Sık sorulan soruların</a> cevaplarına bakın</li>
                        <li>Doktor ile açık iletişim kurun</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Section 5: Kaynaklar -->
        <section id="kaynaklar" class="bg-gray-50 py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="max-w-3xl mx-auto">
                    <h2 class="font-headline text-3xl text-gray-900 mb-6">5. Kaynaklar ve İlerleyen Adımlar</h2>
                    <div class="space-y-4 text-gray-600">
                        <p>
                            Duygusal destek alan çiftler, daha iyi tedavi seçimleri ve yaşam kalitesi rapor ederler. Tedavi başarısı da artar - çünkü cortisol (stress hormonu) infertilite tedavisini olumsuz etkiler.
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <a href="/rehberler" class="border rounded-xl p-6 hover:shadow-lg transition-shadow">
                                <span class="material-symbols-outlined text-primary-600 mb-2">assignment</span>
                                <h3 class="font-bold text-gray-900 text-sm">Tedavi Rehberleri</h3>
                                <p class="text-xs text-gray-600 mt-1">Her tedavi aşamasında neler bekleneceğini öğrenin</p>
                            </a>
                            <a href="/psikolojik-destek" class="border rounded-xl p-6 hover:shadow-lg transition-shadow">
                                <span class="material-symbols-outlined text-primary-600 mb-2">psychology</span>
                                <h3 class="font-bold text-gray-900 text-sm">Psikolojik Destek</h3>
                                <p class="text-xs text-gray-600 mt-1">Profesyonel yardım ve terapi seçenekleri</p>
                            </a>
                            <a href="/sss" class="border rounded-xl p-6 hover:shadow-lg transition-shadow">
                                <span class="material-symbols-outlined text-primary-600 mb-2">help</span>
                                <h3 class="font-bold text-gray-900 text-sm">Sık Sorulan Sorular</h3>
                                <p class="text-xs text-gray-600 mt-1">Duygusal ve praktik sorulara cevaplar</p>
                            </a>
                            <a href="/kadin-infertilitesi" class="border rounded-xl p-6 hover:shadow-lg transition-shadow">
                                <span class="material-symbols-outlined text-primary-600 mb-2">woman</span>
                                <h3 class="font-bold text-gray-900 text-sm">Kadın Faktörleri</h3>
                                <p class="text-xs text-gray-600 mt-1">Kadın infertilitesinin duygusal etkileri</p>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Related Pages -->
        <RelatedContent items={[
          { href: '/psikolojik-destek', icon: 'psychology', title: 'Psikolojik Destek', description: 'Terapi ve profesyonel kaynaklar' },
          { href: '/rehberler', icon: 'assignment', title: 'Tedavi Rehberleri', description: 'Her aşama adım adım açıklanmıştır' },
          { href: '/sss', icon: 'help', title: 'Sık Sorulan Sorular', description: 'Sorularınızın yanıtları' },
          { href: '/kadin-infertilitesi', icon: 'woman', title: 'Kadın Faktörleri', description: 'Kadın infertilitesinin nedenleri' },
          { href: '/erkek-infertilitesi', icon: 'man', title: 'Erkek Faktörleri', description: 'Erkek infertilitesinin nedenleri' },
          { href: '/beslenme-yasam', icon: 'nutrition', title: 'Beslenme ve Yaşam', description: 'Yaşam tarzı optimizasyonu' }
        ]} />

        <!-- Doktor Onay Bandı -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <div class="bg-gray-50 p-8 rounded-2xl border-l-4 border-primary flex flex-col md:flex-row items-center gap-8">
                <div class="w-20 h-20 rounded-full overflow-hidden bg-gray-200 shrink-0">
                    <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                </div>
                <div>
                    <p class="font-headline text-lg text-gray-900 mb-1">Doç. Yayın Kurulu</p>
                    <p class="text-sm text-gray-600">
                        Bu rehber, üreme sağlığı alanında uzman <strong class="text-primary-600">tupbebek.com yayın kurulu</strong> tarafından tıbbi açıdan incelenmiş ve onaylanmıştır. İçerik, psikiyatrik ve psikolojik yönergeler doğrultusunda hazırlanmıştır.
                    </p>
                </div>
            </div>
        </section>

        <!-- Yasal Uyarı -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8">
            <DisclaimerBar title="Yasal Uyarı">
                Bu rehber yalnızca genel bilgilendirme amaçlıdır. Duygusal zorluklar veya zihinsel sağlık endişeleriniz varsa, lütfen bir psikiyatrist veya psikologa danışınız. tupbebek.com, bu bilgilere dayanılarak alınan kararlardan sorumlu tutulamaz.
            </DisclaimerBar>
        </section>
    </main>

    <Footer />

<script is:inline>
(function() {
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.quick-nav-link');

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                navLinks.forEach(link => {
                    link.classList.remove('text-primary-600', 'border-b-2', 'border-primary');
                    link.classList.add('text-gray-500');
                });
                const activeLink = document.querySelector(`.quick-nav-link[href="#${entry.target.id}"]`);
                if (activeLink) {
                    activeLink.classList.add('text-primary-600', 'border-b-2', 'border-primary');
                    activeLink.classList.remove('text-gray-500');
                }
            }
        });
    }, { rootMargin: '-20% 0px -70% 0px' });

    sections.forEach(section => observer.observe(section));
})();
</script>
</BaseLayout>
