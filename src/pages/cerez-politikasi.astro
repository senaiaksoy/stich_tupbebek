---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Çerez Politikası | tupbebek.com" description="Web sitemizde kullanılan çerezler ve veri toplama politikası">
    <Header />
    <main class="py-24">
        <section class="max-w-5xl mx-auto px-8">
            <h1 class="font-headline text-4xl text-on-surface mb-8">Çerez Politikası</h1>
            <p class="text-on-surface-variant">İçerik yakında eklenecek.</p>
        </section>
    </main>
    <Footer />
</BaseLayout>
