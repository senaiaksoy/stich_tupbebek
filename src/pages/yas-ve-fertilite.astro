---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StatsStrip from '../components/StatsStrip.astro';
import RelatedContent from '../components/RelatedContent.astro';
import DisclaimerBar from '../components/DisclaimerBar.astro';
---

<BaseLayout title="Yaş ve Fertilite: Üreme Başarısı Üzerinde Yaşın Etkileri | tupbebek.com" description="Kadın ve erkek yaşının fertilite ve tüp bebek başarısı üzerindeki etkisi, yaşlanma ve oosit kalitesi, erkek yaşının sperm parametrelerine etkisi.">
    <Header />

    <main id="main-content" tabindex="-1" class="pb-24">
        <!-- Hero Section -->
        <header class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-mint-100 text-mint-700 rounded-full text-xs font-semibold uppercase tracking-wider mb-6">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">schedule</span>
                        Biyolojik Faktör
                    </div>
                    <h1 class="font-headline text-5xl md:text-6xl text-gray-900 leading-tight mb-8">
                        Yaş ve Fertilite: <span class="text-primary-600 italic">Zaman</span> Kritikal Faktör
                    </h1>
                    <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border-l-4 border-primary">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-200">
                            <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                        </div>
                        <div>
                            <p class="font-headline italic text-gray-900 text-sm">İnceleme:</p>
                            <p class="font-bold text-primary-600">Yayın Kurulu</p>
                        </div>
                    </div>
                </div>
                <div class="hidden md:block w-72 shrink-0 aspect-[4/5] bg-gray-100 rounded-2xl overflow-hidden shadow-2xl">
                    <img class="w-full h-full object-cover grayscale opacity-80" src="/images/sorunlar/cell-biology.webp" alt="Yaş ve fertilite" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
            </div>
        </header>

        <!-- Introduction -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <p class="text-lg md:text-xl text-gray-600 leading-relaxed font-body italic mb-12">
                Üreme sağlığında yaş, en kritik faktörlerden biridir. Kadınlar sınırlı sayıda yumurta ile doğarlar ve bu reserve zamanla azalır, kalitesi düşer. Erkeklerde ise yaş, sperm parametrelerini ve DNA fragmentasyonunu etkiler. Bu rehberde yaşın üreme başarısı üzerindeki bilimsel etkisini inceleyeceğiz.
            </p>
            <StatsStrip items={[
              { icon: 'fertile', heading: 'En Verimli', text: '20-30 yaş arası en yüksek doğal fertilite' },
              { icon: 'trending_down', heading: '35+ Kırılma', text: '35 yaşından sonra başarı oranları düşüş gösterir' },
              { icon: 'science', heading: 'DNA', text: 'Yaş arttıkça oosit DNA fragmentasyonu artıyor' }
            ]} />
        </section>

        <!-- Kadın Yaşı -->
        <section class="bg-gray-50 py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <h2 class="font-headline text-3xl text-gray-900 mb-12">Kadın Yaşının Etkisi</h2>
                <div class="space-y-6 text-gray-600">
                    <p>
                        Kadının yaşı, tüp bebek (IVF) başarısındaki en güçlü bağımsız değişkendir. Bunun nedeni, kadınların doğumda sahip oldukları yumurta (oosit) sayısının yaş ilerledikçe hem sayıca azalması hem de kalitesinin düşmesidir. Bu biyolojik gerçek, hormon tedavisi ile değiştirilemez.
                    </p>
                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-gray-900 mb-4">Yaşa Göre Doğal Gebelik Oranları:</h4>
                        <ul class="space-y-2 text-sm">
                            <li>• <strong>20-25 yaş:</strong> Aylık doğal gebelik şansı ~25%</li>
                            <li>• <strong>30-34 yaş:</strong> Aylık doğal gebelik şansı ~15%</li>
                            <li>• <strong>35-39 yaş:</strong> Aylık doğal gebelik şansı ~10%</li>
                            <li>• <strong>40+ yaş:</strong> Aylık doğal gebelik şansı ~3-5%</li>
                        </ul>
                    </div>
                    <p>
                        IVF başarısı da benzer trend gösterir. <a href="/basari-oranlari" class="text-primary-600 hover:underline">Başarı oranları sayfamız</a>da yaşa göre ayrıntılı veriler bulabilirsiniz. <a href="/kadin-infertilitesi" class="text-primary-600 hover:underline">Kadın infertilitesi</a> hakkında daha fazla bilgi için ilgili sayfamızı ziyaret edin.
                    </p>
                </div>
            </div>
        </section>

        <!-- Erkek Yaşı -->
        <section class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <h2 class="font-headline text-3xl text-gray-900 mb-12">Erkek Yaşının Etkisi</h2>
            <div class="space-y-6 text-gray-600">
                <p>
                    Erkek yaşı, kadın yaşı kadar kritik değildir, ancak göz ardı edilmemelidir. Yaş ilerledikçe, sperm motilitesi, morfolojisi ve DNA bütünlüğü etkilenebilir. Özellikle 50 yaşından sonra bu etkiler daha belirgin hale gelir.
                </p>
                <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                    <h4 class="font-bold text-gray-900 mb-4">Yaş ve Sperm Parametreleri:</h4>
                    <ul class="space-y-2 text-sm">
                        <li>• <strong>20-30 yaş:</strong> Optimal sperm parametreleri, düşük DNA fragmentasyonu</li>
                        <li>• <strong>30-40 yaş:</strong> Minimal değişim, genellikle normal parametreler</li>
                        <li>• <strong>40-50 yaş:</strong> DNA fragmentasyonunda hafif artış mümkün</li>
                        <li>• <strong>50+ yaş:</strong> Motilite ve morfoloji bozulması, DNA fragmentasyonunda artış</li>
                    </ul>
                </div>
                <p>
                    Erkek faktörleri hakkında daha fazla bilgi için <a href="/erkek-infertilitesi" class="text-primary-600 hover:underline">erkek infertilitesi rehberimiz</a>i ziyaret edin.
                </p>
            </div>
        </section>

        <!-- İlgili Kaynaklar -->
        <RelatedContent items={[
          { href: '/kadin-infertilitesi', icon: 'woman', title: 'Kadın İnfertilitesi', description: 'Yaşın nedenler üzerindeki etkisi' },
          { href: '/erkek-infertilitesi', icon: 'man', title: 'Erkek İnfertilitesi', description: 'Erkek yaşının etkisi' },
          { href: '/basari-oranlari', icon: 'trending_up', title: 'Başarı Oranları', description: 'Yaşa göre IVF başarı verileri' }
        ]} />

        <!-- Doktor Onay -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <div class="bg-gray-50 p-8 rounded-2xl border-l-4 border-primary flex flex-col md:flex-row items-center gap-8">
                <div class="w-20 h-20 rounded-full overflow-hidden bg-gray-200 shrink-0">
                    <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                </div>
                <div>
                    <p class="font-headline text-lg text-gray-900 mb-1">Yayın Kurulu</p>
                    <p class="text-sm text-gray-600">
                        Bu rehber, üreme sağlığı alanında uzman <strong class="text-primary-600">tupbebek.com yayın kurulu</strong> tarafından tıbbi açıdan incelenmiş ve onaylanmıştır.
                    </p>
                </div>
            </div>
        </section>

        <!-- Yasal Uyarı -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8">
            <DisclaimerBar title="Yasal Uyarı">
                Bu rehber genel bilgilendirme amaçlıdır. Yaş ve fertilite hakkında kişisel kararlar için lütfen bir üreme sağlığı uzmanına danışınız. tupbebek.com, bu bilgilere dayanılarak alınan kararlardan sorumlu tutulamaz.
            </DisclaimerBar>
        </section>
    </main>

    <Footer />
</BaseLayout>
