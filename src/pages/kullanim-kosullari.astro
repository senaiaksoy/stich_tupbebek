---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Kullanım Koşulları | tupbebek.com" description="Web sitemizin kullanım koşulları ve hükümleri">
    <Header />
    <main id="main-content" tabindex="-1" class="py-24">
        <section class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
            <h1 class="font-headline text-4xl text-on-surface mb-8">Kullanım Koşulları</h1>
            <p class="text-on-surface-variant">İçerik yakında eklenecek.</p>
        </section>
    </main>
    <Footer />
</BaseLayout>
