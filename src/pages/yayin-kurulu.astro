---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const colorMap = {
  primary: { bg: 'bg-primary-50', icon: 'text-primary-600', badge: 'bg-primary-100 text-primary-700' },
  mint: { bg: 'bg-mint-50', icon: 'text-mint-600', badge: 'bg-mint-100 text-mint-700' },
  purple: { bg: 'bg-purple-50', icon: 'text-purple-600', badge: 'bg-purple-100 text-purple-700' },
  amber: { bg: 'bg-amber-50', icon: 'text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  red: { bg: 'bg-red-50', icon: 'text-red-600', badge: 'bg-red-100 text-red-700' },
  teal: { bg: 'bg-teal-50', icon: 'text-teal-600', badge: 'bg-teal-100 text-teal-700' },
} as const;

const boardMembers = [
  {
    name: 'Doç. Dr. Senai Aksoy',
    role: 'Kurul Editörü',
    title: 'Kadın Hastalıkları ve Doğum Uzmanı, Üreme Tıbbı',
    icon: 'clinical_notes',
    color: 'primary',
    bio: 'Cerrahpaşa Tıp Fakültesi mezunudur (1985). Kadın hastalıkları ve doğum uzmanlığını Fransa Franche-Comté Üniversitesi\'nde tamamlamıştır. Paris René Descartes Üniversitesi\'nden üreme sağlığı ve yardımcı üreme teknikleri diploması, Clermont-Ferrand Üniversitesi\'nden jinekolojik laparoskopik cerrahi diploması ve Strasburg Louis Pasteur Üniversitesi\'nden jinekolojik ve obstetrikal ultrason diploması almıştır. 1994 yılında Ankara Sevgi Hastanesi\'nde Türkiye\'deki ilk mikroenjeksiyon (ICSI) uygulamalarını gerçekleştiren ekibin üyesidir. 1996 yılından itibaren Amerikan Hastanesi Tüp Bebek Ünitesi\'nin kurucu ekibinde yer almıştır. PubMed, ORCID ve Google Scholar\'da yayınları bulunmaktadır. ESHRE ve TSRM üyesidir. tupbebek.com bünyesinde yayımlanan tüm tıbbi içeriklerin bilimsel doğruluğunun ve güncelliğinin nihai sorumluluğunu taşır.',
  },
  {
    name: 'Dr. Alper Mumcu',
    role: 'Kurul Üyesi',
    title: 'Kadın Hastalıkları ve Doğum Uzmanı, Üreme Endokrinolojisi',
    icon: 'science',
    color: 'mint',
    bio: 'Hacettepe Üniversitesi Tıp Fakültesi İngilizce bölümü mezunudur (1992). Kadın hastalıkları ve doğum uzmanlığını Dokuz Eylül Üniversitesi Tıp Fakültesi\'nde tamamlamıştır (1997). 2000–2010 yılları arasında Amerikan Hastanesi Üreme Sağlığı Ünitesi\'nde görev yapmıştır. 2010–2015 yılları arasında Kanada\'da Montreal Reproductive Centre\'da tüp bebek uzmanı olarak çalışmış, McGill Üniversitesi Tıp Fakültesi Araştırma Enstitüsü\'nde yumurtalık kanserlerinin erken teşhisine yönelik araştırma projesinde yer almıştır. Fertility and Sterility, Human Reproduction gibi uluslararası hakemli dergilerde yayınları bulunmaktadır. ESHRE, ASRM, TSRM, TJOD ve Jinekolojik Endoskopi Derneği üyesidir. Halen Lotus Nişantaşı\'ndaki özel muayenehanesinde hasta kabul etmektedir. Sitede yayımlanan klinik protokoller ve tedavi rehberlerinin tıbbi denetimine katkı sağlamaktadır.',
  },
  {
    name: 'Emb. Hasan Benli',
    role: 'Kurul Üyesi',
    title: 'Kıdemli Embriyolog, Laboratuvar Sorumlusu',
    icon: 'biotech',
    color: 'purple',
    bio: 'Acıbadem Fulya Hastanesi Tüp Bebek ve Üreme Sağlığı Merkezi\'nde embriyolog ve laboratuvar sorumlusu olarak görev yapmaktadır. Embriyoloji alanında lisansüstü eğitimini tamamlamış olup ICSI, blastokist kültürü, vitrifikasyon, preimplantasyon genetik test (PGT) biyopsisi ve time-lapse embriyo izleme sistemleri konularında ileri düzey laboratuvar deneyimine sahiptir. ESHRE sertifikalı kıdemli embriyolog unvanını taşımaktadır. Sitede yer alan laboratuvar süreçleri, embriyo değerlendirme ve kriyoprezervasyon içeriklerinin bilimsel doğruluğunu denetlemektedir.',
  },
  {
    name: 'Dr. Alp Aslan Eryılmaz',
    role: 'Kurul Üyesi',
    title: 'Kardiyoloji Uzmanı, Girişimsel Kardiyoloji',
    icon: 'cardiology',
    color: 'red',
    bio: 'Akdeniz Üniversitesi Tıp Fakültesi mezunudur (1997). Kardiyoloji uzmanlığını İstanbul Üniversitesi Çapa Tıp Fakültesi\'nde tamamlamıştır (2002). 2006 yılından bu yana Amerikan Hastanesi Kardiyoloji Bölümü\'nde girişimsel kardiyolog olarak görev yapmaktadır. Hipertansiyon, diyabet ve hiperkolesterolemi ile ilişkili damar sertliği hastalıklarının tanı ve tedavisi, damar tıkanıklıklarının balon ve stent ile açılması ve kalp ritim bozuklukları konularında klinik deneyime sahiptir. Türkiye\'de ilk kez yapılan transkateter aort kapak değişimi ve mitraklip operasyonlarında yer almıştır. Sitede yayımlanan içeriklerde infertilite tedavisi sürecinde kardiyovasküler risk değerlendirmesi, OHSS\'ye bağlı tromboembolik komplikasyonlar ve gebelikte kardiyak izlem konularındaki tıbbi doğruluğa katkı sağlamaktadır.',
  },
  {
    name: 'Dr. Metin Alış',
    role: 'Kurul Üyesi',
    title: 'Endokrinoloji, Diyabet ve Metabolizma Hastalıkları Uzmanı',
    icon: 'endocrinology',
    color: 'teal',
    bio: 'GATA Tıp Fakültesi mezunudur (1995). İç hastalıkları uzmanlığını GATA Ankara\'da (2002), endokrinoloji yan dal uzmanlığını GATA Haydarpaşa\'da (2012) tamamlamıştır. 2017 yılından bu yana Amerikan Hastanesi Endokrinoloji Bölümü\'nde görev yapmaktadır. Tiroid hastalıkları, diyabet, obezite, osteoporoz, hipofiz ve adrenal-gonad hastalıkları konularında klinik deneyime sahiptir. Amerikan Endokrinoloji Derneği, Avrupa Endokrinoloji Derneği ve Türkiye Endokrinoloji ve Metabolizma Derneği üyesidir. Sitede yayımlanan içeriklerde infertiliteyle ilişkili endokrin bozukluklar, polikistik over sendromu (PKOS), tiroid-fertilite ilişkisi ve hormonal tedavilerin metabolik etkileri konularındaki tıbbi doğruluğa katkı sağlamaktadır.',
  },
  {
    name: 'Av. Bahar Özeray',
    role: 'Kurul Üyesi — Hukuk Danışmanı',
    title: 'Sağlık Hukuku ve ÜYTE Mevzuatı',
    icon: 'gavel',
    color: 'amber',
    bio: 'Sağlık hukuku alanında uzmanlaşmış avukattır. Üremeye yardımcı tedavi (ÜYTE) mevzuatı, hasta hakları, kişisel verilerin korunması (KVKK) ve sağlık reklamcılığı düzenlemeleri konularında danışmanlık vermektedir. Türk Tabipleri Birliği etik kuralları, Sağlık Bakanlığı yönetmelikleri ve ÜYTE Yönetmeliği çerçevesinde sitede yayımlanan içeriklerin yasal uyumluluğunu denetlemektedir. Hasta bilgilendirme metinlerinin mevzuata uygunluğunun sağlanmasında aktif rol almaktadır.',
  },
];
---

<BaseLayout title="Yayın Kurulu | tupbebek.com" description="tupbebek.com tıbbi yayın kurulu üyeleri, editöryal sürecimiz ve içerik denetim politikamız hakkında bilgi edinin.">
    <Header />

    <main id="main-content" tabindex="-1" class="pt-32 pb-20">

        <!-- Hero -->
        <section class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8 mb-16 text-center">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-50 text-primary-700 rounded-full text-xs font-bold uppercase tracking-widest mb-6">
                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                Editöryal Şeffaflık
            </span>
            <h1 class="font-headline text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
                Tıbbi Yayın Kurulu
            </h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
                tupbebek.com'da yayımlanan tüm içerikler, alanında uzman bir yayın kurulu tarafından bilimsel doğruluk, güncellik ve yasal uyumluluk açısından denetlenmektedir.
            </p>
        </section>

        <!-- Editöryal Süreç -->
        <section class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 md:p-8">
                <h2 class="font-headline text-xl font-bold text-gray-900 mb-4">Editöryal Sürecimiz</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-primary-600 text-base">edit_note</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-gray-900 mb-1">1. İçerik Hazırlama</p>
                            <p class="text-xs text-gray-500">Güncel kılavuzlar ve hakemli yayınlara dayalı olarak taslak içerik oluşturulur.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-mint-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-mint-600 text-base">fact_check</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-gray-900 mb-1">2. Tıbbi Denetim</p>
                            <p class="text-xs text-gray-500">Her içerik, ilgili uzmanlık alanındaki kurul üyesi tarafından bilimsel doğruluk açısından incelenir.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-amber-600 text-base">gavel</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-gray-900 mb-1">3. Hukuki Uyumluluk</p>
                            <p class="text-xs text-gray-500">TTB etik kuralları, Sağlık Bakanlığı ve ÜYTE Yönetmeliği'ne uygunluk denetlenir.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Kurul Üyeleri -->
        <section class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <h2 class="font-headline text-2xl font-bold text-gray-900 mb-8">Kurul Üyeleri</h2>

            <div class="space-y-6">
                {boardMembers.map((member, index) => {
                    const c = colorMap[member.color as keyof typeof colorMap] || colorMap.primary;
                    return (
                        <div class="bg-white border border-gray-200 rounded-xl p-6 md:p-8 hover:shadow-md transition-shadow">
                            <div class="flex flex-col sm:flex-row items-start gap-5">
                                <div class:list={["w-14 h-14 rounded-xl flex items-center justify-center shrink-0", c.bg]}>
                                    <span class:list={["material-symbols-outlined text-2xl", c.icon]} style="font-variation-settings: 'FILL' 1;">{member.icon}</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                                        <h3 class="font-headline text-lg font-bold text-gray-900">{member.name}</h3>
                                        <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold w-fit", c.badge]}>
                                            {member.role}
                                        </span>
                                    </div>
                                    <p class="text-sm font-medium text-gray-500 mb-3">{member.title}</p>
                                    <p class="text-sm text-gray-600 leading-relaxed">{member.bio}</p>
                                </div>
                            </div>
                        </div>
                    );
                })}
            </div>
        </section>

        <!-- Yasal Uyarı -->
        <section class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 md:p-8">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-gray-400 text-xl mt-0.5 shrink-0">info</span>
                    <div>
                        <h3 class="text-sm font-bold text-gray-900 mb-2">Yasal Bilgilendirme</h3>
                        <p class="text-xs text-gray-500 leading-relaxed mb-3">
                            tupbebek.com bir sağlık kuruluşu değildir. Bu sitede yer alan bilgiler genel bilgilendirme amacıyla hazırlanmış olup profesyonel tıbbi tavsiye, teşhis veya tedavi yerine geçmez. Herhangi bir tıbbi karar vermeden önce mutlaka uzman bir hekime danışınız.
                        </p>
                        <p class="text-xs text-gray-500 leading-relaxed mb-3">
                            Sitede yayımlanan tüm içerikler, Türk Tabipleri Birliği Meslek Etiği Kuralları, Sağlık Bakanlığı düzenlemeleri ve ÜYTE Yönetmeliği hükümlerine uygun olarak hazırlanmaktadır. Türkiye'de üremeye yardımcı tedaviler yasal düzenlemeler çerçevesinde evli çiftlere uygulanmaktadır.
                        </p>
                        <p class="text-xs text-gray-500 leading-relaxed">
                            İçeriklerimiz ticari bir kuruluştan bağımsızdır; reklam, sponsorlu içerik veya ürün tanıtımı barındırmaz. Yayın kurulu üyeleri, site içeriklerinin bilimsel doğruluğu ve yasal uyumluluğu konusunda gönüllü olarak katkı sağlamaktadır.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- İletişim CTA -->
        <section class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
            <div class="text-center">
                <p class="text-sm text-gray-500 mb-4">Editöryal sürecimiz veya yayın kurulumuz hakkında sorularınız için</p>
                <a href="/iletisim" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold text-sm hover:bg-primary-700 transition-colors">
                    <span class="material-symbols-outlined text-base">mail</span>
                    İletişime Geçin
                </a>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
