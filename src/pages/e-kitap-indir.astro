---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="30 Günlük Tüp Bebek Beslenme Planı | Ücretsiz E-Kitap İndir" description="Uzman diyetisyen ve üreme endokrinologları tarafından hazırlanan bilimsel tüp bebek beslenme e-kitabını indir. 4 fazlı beslenme planı, 60+ tarif, vitamin rehberi.">
    <Header hideSearch={true} />
    <main id="main-content" tabindex="-1">

        <!-- Hero Section -->
        <section class="bg-gradient-to-br from-primary-50 via-mint-50 to-white py-16 md:py-24">
            <div class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                    <!-- Left: Book Preview/Info -->
                    <div>
                        <div class="mb-8">
                            <span class="text-mint-600 font-label uppercase tracking-ultra text-xs font-bold mb-4 block">
                                📚 ÜCRETSIZ E-KİTAP
                            </span>
                            <h1 class="text-4xl lg:text-5xl font-headline text-gray-900 leading-tight mb-6">
                                30 Günlük Tüp Bebek Beslenme Planı
                            </h1>
                            <p class="text-lg text-gray-700 leading-relaxed mb-8">
                                Doç. Dr. Senai Aksoy ve uzman diyetisyenler tarafından hazırlanan, bilimsel araştırmalara dayalı, 4 klinik fazlı beslenme rehberi. Tüp bebek tedavisinin her aşamasında beslenmenin rolünü, uygun yiyecekleri ve beslenme stratejilerini öğrenin.
                            </p>
                        </div>

                        <!-- Benefits List -->
                        <div class="space-y-4 mb-10">
                            <div class="flex gap-3 items-start">
                                <span class="text-mint-600 text-xl mt-1">✓</span>
                                <div>
                                    <h4 class="font-semibold text-gray-900">4 Klinik Fazlı Beslenme Planı</h4>
                                    <p class="text-sm text-gray-600">Folikül gelişimi, endometrial kalınlaşma, embriyo transferi ve luteal faz</p>
                                </div>
                            </div>
                            <div class="flex gap-3 items-start">
                                <span class="text-mint-600 text-xl mt-1">✓</span>
                                <div>
                                    <h4 class="font-semibold text-gray-900">30 Günlük Detaylı Beslenme Tablosu</h4>
                                    <p class="text-sm text-gray-600">Her günün kahvaltısından akşam yemeğine kadar planlı menü</p>
                                </div>
                            </div>
                            <div class="flex gap-3 items-start">
                                <span class="text-mint-600 text-xl mt-1">✓</span>
                                <div>
                                    <h4 class="font-semibold text-gray-900">Besin Rehberi & Vitamin Tablosu</h4>
                                    <p class="text-sm text-gray-600">Üreme sağlığı için kritik vitaminler, mineraller ve besin bileşenleri</p>
                                </div>
                            </div>
                            <div class="flex gap-3 items-start">
                                <span class="text-mint-600 text-xl mt-1">✓</span>
                                <div>
                                    <h4 class="font-semibold text-gray-900">Akdeniz Diyeti Temelli</h4>
                                    <p class="text-sm text-gray-600">Fertilitede faydalı olduğu bilimsel olarak kanıtlanmış beslenme tarzı</p>
                                </div>
                            </div>
                            <div class="flex gap-3 items-start">
                                <span class="text-mint-600 text-xl mt-1">✓</span>
                                <div>
                                    <h4 class="font-semibold text-gray-900">Yaşanması Kolay Tarifler</h4>
                                    <p class="text-sm text-gray-600">60+ basit ve lezzetli tarif, yaşanması zor olmayan beslenme sistemi</p>
                                </div>
                            </div>
                        </div>

                        <!-- Author Credit -->
                        <div class="bg-white rounded-2xl p-6 border border-gray-200">
                            <div class="flex gap-4">
                                <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                                    <span class="text-2xl">👨‍⚕️</span>
                                </div>
                                <div>
                                    <h4 class="font-semibold text-gray-900">Doç. Dr. Senai Aksoy</h4>
                                    <p class="text-sm text-gray-600">Kadın Hastalıkları ve Doğum Uzmanı</p>
                                    <p class="text-xs text-gray-500 mt-1">Üreme Tıbbı ve Yardımcı Üreme Teknikleri</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Download Form -->
                    <div class="lg:sticky lg:top-32">
                        <div class="bg-white rounded-3xl shadow-lg p-8 md:p-10 border border-gray-200">
                            <h2 class="text-2xl font-headline text-gray-900 mb-2">E-Kitabı İndir</h2>
                            <p class="text-gray-600 mb-8 text-sm">Bilgi formunu doldurarak PDF'i hemen indirebilirsiniz</p>

                            <form id="ebook-form" class="space-y-6">
                                <!-- Ad Soyad -->
                                <div>
                                    <label for="fullname" class="block text-sm font-semibold text-gray-900 mb-2">
                                        Ad Soyadı <span class="text-red-500">*</span>
                                    </label>
                                    <input
                                        type="text"
                                        id="fullname"
                                        name="fullname"
                                        required
                                        placeholder="Adınız soyadınız"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-mint-600 focus:border-transparent outline-none text-gray-900 placeholder-gray-500"
                                    />
                                </div>

                                <!-- Email -->
                                <div>
                                    <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">
                                        E-posta Adresiniz <span class="text-red-500">*</span>
                                    </label>
                                    <input
                                        type="email"
                                        id="email"
                                        name="email"
                                        required
                                        placeholder="ornek@email.com"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-mint-600 focus:border-transparent outline-none text-gray-900 placeholder-gray-500"
                                    />
                                </div>

                                <!-- Telefon (Opsiyonel) -->
                                <div>
                                    <label for="phone" class="block text-sm font-semibold text-gray-900 mb-2">
                                        Telefon Numarası <span class="text-gray-500 text-xs">(opsiyonel)</span>
                                    </label>
                                    <input
                                        type="tel"
                                        id="phone"
                                        name="phone"
                                        placeholder="+90 5__ ___ __ __"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-mint-600 focus:border-transparent outline-none text-gray-900 placeholder-gray-500"
                                    />
                                </div>

                                <!-- Harita Durumu -->
                                <div>
                                    <label for="status" class="block text-sm font-semibold text-gray-900 mb-2">
                                        Tedavi Durumunuz
                                    </label>
                                    <select
                                        id="status"
                                        name="status"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-mint-600 focus:border-transparent outline-none text-gray-900"
                                    >
                                        <option value="">Seçiniz</option>
                                        <option value="planning">Tedavi planlaması yapıyorum</option>
                                        <option value="preparation">Tedaviye hazırlanıyorum</option>
                                        <option value="ongoing">Tedavi devam ediyor</option>
                                        <option value="support">Destek arıyorum</option>
                                    </select>
                                </div>

                                <!-- KVKK Checkbox -->
                                <div class="pt-2">
                                    <label class="flex items-start gap-3 cursor-pointer">
                                        <input
                                            type="checkbox"
                                            id="kvkk"
                                            name="kvkk"
                                            required
                                            class="w-5 h-5 rounded border-gray-300 text-mint-600 mt-0.5"
                                        />
                                        <span class="text-xs text-gray-600 leading-relaxed">
                                            Kişisel verilerim <a href="/gizlilik-politikasi" class="text-mint-600 hover:underline font-semibold">Gizlilik Politikası</a>'na uygun şekilde işlenebilir. E-kitap indirimi ve Doç. Dr. Senai Aksoy'dan güncel bilgiler almak için haberleşebilirsiniz. <span class="text-red-500">*</span>
                                        </span>
                                    </label>
                                </div>

                                <!-- Submit Button -->
                                <button
                                    type="submit"
                                    id="download-btn"
                                    class="w-full bg-mint-600 hover:bg-mint-700 text-white font-bold py-4 px-6 rounded-lg transition-colors duration-300 flex items-center justify-center gap-2 text-lg mt-8"
                                >
                                    <span>📥 E-Kitabı İndir (PDF)</span>
                                </button>

                                <!-- Loading State -->
                                <div id="loading-message" style="display:none;" class="text-center text-mint-600 text-sm font-semibold">
                                    E-kitap hazırlanıyor...
                                </div>

                                <!-- Success Message -->
                                <div id="success-message" style="display:none;" class="bg-mint-50 border border-mint-300 rounded-lg p-4 text-mint-900 text-sm">
                                    ✓ Teşekkürler! E-kitap indiriliyor. Ayrıca e-postanıza indir bağlantısı gönderildi.
                                </div>
                            </form>

                            <!-- Trust Badge -->
                            <div class="mt-8 pt-8 border-t border-gray-200">
                                <p class="text-xs text-gray-500 text-center">
                                    🔒 Verileriniz güvenli, hiçbir ücret talep edilmez
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Content Section -->
        <section class="max-w-6xl mx-auto px-4 md:px-6 lg:px-8 py-20">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

                <!-- Content Preview 1 -->
                <div class="bg-gradient-to-br from-mint-50 to-mint-100 rounded-2xl p-8">
                    <div class="text-4xl mb-4">📋</div>
                    <h3 class="text-xl font-headline text-gray-900 mb-3">Faz 1: Folikül Gelişimi</h3>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        Yumurta kalitesini artıran besinler, antioksidan kaynakları, Akdeniz diyetinin uygulanması. Ruh halini düzenleyen, inflamasyonu azaltan beslenme sistemi.
                    </p>
                </div>

                <!-- Content Preview 2 -->
                <div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8">
                    <div class="text-4xl mb-4">🔄</div>
                    <h3 class="text-xl font-headline text-gray-900 mb-3">Faz 2 & 3: Transfer Hazırlığı</h3>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        Endometrial kalınlaşmasını destekleyen besinler, kan akışını geliştiren tarifler, implantasyon başarısını artıran vitaminler.
                    </p>
                </div>

                <!-- Content Preview 3 -->
                <div class="bg-gradient-to-br from-apricot-50 to-apricot-100 rounded-2xl p-8">
                    <div class="text-4xl mb-4">🌱</div>
                    <h3 class="text-xl font-headline text-gray-900 mb-3">Faz 4: Luteal Faz</h3>
                    <p class="text-gray-700 text-sm leading-relaxed">
                        Gebe kalma şansını artıran besinler, ısıtıcı tatifler, progesteronu destekleyen besinler, beslenme tabloları.
                    </p>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="bg-gray-50 py-20">
            <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
                <h2 class="text-3xl font-headline text-center text-gray-900 mb-16">Sık Sorulan Sorular</h2>

                <div class="space-y-6">
                    <details class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow cursor-pointer group">
                        <summary class="flex items-center justify-between font-semibold text-gray-900">
                            <span>E-kitap tamamen ücretsiz mi?</span>
                            <span class="group-open:rotate-180 transition-transform">▼</span>
                        </summary>
                        <p class="text-gray-700 mt-4 text-sm leading-relaxed">
                            Evet, e-kitap tamamen ücretsizdir. Doç. Dr. Senai Aksoy tarafından tüp bebek hastalarını bilgilendirmek amacıyla hazırlanmıştır. Herhangi bir ücret talep edilmez, spam email atılmaz.
                        </p>
                    </details>

                    <details class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow cursor-pointer group">
                        <summary class="flex items-center justify-between font-semibold text-gray-900">
                            <span>Verilerim nasıl kullanılacak?</span>
                            <span class="group-open:rotate-180 transition-transform">▼</span>
                        </summary>
                        <p class="text-gray-700 mt-4 text-sm leading-relaxed">
                            E-postanız e-kitabı indirme ve ileride önemli bilgiler yapıldığında haber gönderme amacıyla kullanılır. Üçüncü taraflarla paylaşılmaz, <a href="/gizlilik-politikasi" class="text-mint-600 hover:underline font-semibold">Gizlilik Politikası</a>'nı okuyabilirsiniz.
                        </p>
                    </details>

                    <details class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow cursor-pointer group">
                        <summary class="flex items-center justify-between font-semibold text-gray-900">
                            <span>PDF'i her zaman indirebilir miyim?</span>
                            <span class="group-open:rotate-180 transition-transform">▼</span>
                        </summary>
                        <p class="text-gray-700 mt-4 text-sm leading-relaxed">
                            Evet. İndirme linki e-postanıza gönderilecek ve bu sayfadan istediğiniz zaman yeniden indirebilirsiniz.
                        </p>
                    </details>

                    <details class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow cursor-pointer group">
                        <summary class="flex items-center justify-between font-semibold text-gray-900">
                            <span>Tüp bebek haricinde de uygulanabilir mi?</span>
                            <span class="group-open:rotate-180 transition-transform">▼</span>
                        </summary>
                        <p class="text-gray-700 mt-4 text-sm leading-relaxed">
                            E-kitap özel olarak tüp bebek (IVF) tedavi döngüsüne göre hazırlanmıştır. Ancak içerdiği Akdeniz diyeti ilkeleri genel üreme sağlığı ve doğal gebelik planlaması için de faydalıdır.
                        </p>
                    </details>
                </div>
            </div>
        </section>

    </main>
    <Footer />
</BaseLayout>

<script>
    // Form submission
    document.getElementById('ebook-form').addEventListener('submit', async (e) => {
        e.preventDefault();

        const fullname = document.getElementById('fullname').value;
        const email = document.getElementById('email').value;
        const phone = document.getElementById('phone').value || '';
        const status = document.getElementById('status').value || '';
        const kvkk = document.getElementById('kvkk').checked;

        if (!kvkk) {
            alert('Lütfen KVKK onayını işaretleyiniz');
            return;
        }

        // Loading göster
        document.getElementById('loading-message').style.display = 'block';
        document.getElementById('download-btn').disabled = true;

        try {
            // İndirme işlemini kaydet ve e-posta gönder (arka planda)
            try {
                await fetch('/api/ebook-subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fullname, email, phone, status })
                });
            } catch (err) {
                console.log('Sunucuya kaydedilemedi, ancak indirme devam ediyor.');
            }

            // Statik PDF i doğrudan indir (yüksek kaliteli, formatı ve Türkce karakterleri korunan versiyon)
            const pdfUrl = '/e-kitap/tup-bebek-beslenme-plani.pdf';
            const link = document.createElement('a');
            link.href = pdfUrl;
            link.download = '30_Gunluk_Tup_Bebek_Beslenme_Plani.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            // Success mesajı göster
            document.getElementById('loading-message').style.display = 'none';
            document.getElementById('success-message').style.display = 'block';

            // Form temizle
            document.getElementById('ebook-form').reset();

            // 5 saniye sonra success mesajını gizle
            setTimeout(() => {
                document.getElementById('success-message').style.display = 'none';
                document.getElementById('download-btn').disabled = false;
            }, 5000);

        } catch (error) {
            console.error('Hata:', error);
            alert('İndirme işlemi sırasında hata oluştu. Lütfen tekrar deneyiniz.');
            document.getElementById('loading-message').style.display = 'none';
            document.getElementById('download-btn').disabled = false;
        }
    });
</script>
