---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Psikolojik Destek ve Duygusal Rehber: İnfertilite Yolculuğu | tupbebek.com" description="İnfertilite sürecinin duygusal etkileri, çift ilişkileri, başarısız denemeler ve profesyonel destek alma zamanı. Duygusal rehber ve destek kaynakları.">
    <Header />
    <Breadcrumbs />

    <main class="pb-24">
        <!-- Hero Section - warmer tone -->
        <header class="max-w-5xl mx-auto px-8 mb-20">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-semibold uppercase tracking-wider mb-6">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">favorite</span>
                        Duygusal Rehber
                    </div>
                    <h1 class="font-headline text-5xl md:text-6xl text-on-surface leading-tight mb-8">
                        Psikolojik Destek: <span class="text-primary italic">Bu Yolculukta</span> Yalnız Değilsiniz
                    </h1>
                    <div class="flex items-center gap-4 p-4 bg-surface-container-low rounded-xl border-l-4 border-primary">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-dim">
                            <img class="w-full h-full object-cover" src="/images/senai-aksoy.jpg" alt="Dr. Senai Aksoy" width="512" height="512" loading="eager" fetchpriority="high"/>
                        </div>
                        <div>
                            <p class="font-headline italic text-on-surface text-sm">Psikolojik Danışmanlık:</p>
                            <p class="font-bold text-primary">Dr. Senai Aksoy</p>
                        </div>
                    </div>
                </div>
                <div class="hidden md:block w-72 shrink-0 aspect-[4/5] bg-surface-container-highest rounded-2xl overflow-hidden shadow-2xl">
                    <img class="w-full h-full object-cover grayscale opacity-80" src="/images/sorunlar/hormonal-cycles.jpg" alt="Duygusal destek" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
            </div>
        </header>

        <!-- Introduction - empathetic -->
        <section class="max-w-3xl mx-auto px-8 mb-24">
            <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed font-body italic mb-12">
                İnfertilite sadece tıbbi bir durum değil; derin duygusal, psikolojik ve ilişkisel bir yolculuktur. Kaygı, üzüntü, öfke, yalnızlık hissi ve güç kaybı deneyimleri yaygındır. Bu rehber, bu zorlu süreçte kendinizi anlamanız ve sağlıklı baş etme stratejileri geliştirmeniz için hazırlanmıştır.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">favorite_border</span>
                    <h3 class="font-bold text-sm mb-2">%70</h3>
                    <p class="text-xs text-on-surface-variant mb-0">İnfertilite kaygısı yaşayan çiftler</p>
                </div>
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">group</span>
                    <h3 class="font-bold text-sm mb-2">2-3x</h3>
                    <p class="text-xs text-on-surface-variant mb-0">Depresyon riski genel nüfus oranına göre</p>
                </div>
                <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border-t-2 border-primary-fixed">
                    <span class="material-symbols-outlined text-primary mb-3">psychology</span>
                    <h3 class="font-bold text-sm mb-2">CBT</h3>
                    <p class="text-xs text-on-surface-variant mb-0">Bilişsel Davranışçı Terapi etkili</p>
                </div>
            </div>
        </section>

        <!-- Quick-Nav Bar -->
        <nav id="quick-nav" class="sticky top-20 z-40 bg-white/90 backdrop-blur-sm border-b border-slate-100 shadow-sm mb-16">
            <div class="max-w-5xl mx-auto px-8 overflow-x-auto whitespace-nowrap">
                <div class="flex items-center gap-1 py-3">
                    <a href="#duygusal" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Duygusal Etki</a>
                    <a href="#cift" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Çift İlişkisi</a>
                    <a href="#basetme" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Baş Etme</a>
                    <a href="#yas" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Yas Süreci</a>
                    <a href="#destek" class="quick-nav-link px-4 py-2 text-sm font-semibold text-slate-500 hover:text-primary rounded-lg transition-colors shrink-0">Profesyonel Destek</a>
                </div>
            </div>
        </nav>

        <!-- Section 1: Duygusal Etkiler -->
        <section id="duygusal" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">1. İnfertilite ve Duygusal Etkiler</h2>
                        <div class="space-y-6 text-on-surface-variant">
                            <p>
                                İnfertilite deneyimi, birçok kişi için güçlü duygusal tepkiler tetikler. Kaygı, umutsuzluk, öfke, suçlama hissi ve özgüven kaybı sık görülür. Bu duygular, süreç ilerledikçe ve tedavi sonuçları known oldukça artabilir.
                            </p>
                            <p>
                                Araştırmalar, infertilite hastalarının %40-50'sinde orta-seviye depresif belirtiler, %60-70'inde ise anksiyete bozukluğu saptadı. Bu oranlar, Kronik hastalıklarla eşdeğer seviyededir.
                            </p>
                            <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                                <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">biotech</span>
                                    Yaygın Duygusal Belirtiler
                                </h4>
                                <div class="grid grid-cols-2 gap-4 text-sm">
                                    <div><strong>Kaygı:</strong> Gelecek korkusu, kontrol kaybı</div>
                                    <div><strong>Üzüntü:</strong> Gönül darlığı, hüzün, ağlama</div>
                                    <div><strong>Öfke:</strong> Adalet hissi, sinirlilik</div>
                                    <div><strong>Suçlama:</strong> Kendini suçlama,合作伙伴 suçlama</div>
                                    <div><strong>Yalnızlık:</strong> Sosyal çekilme, anlaşılmama</div>
                                    <div><strong>Güç Kaybı:</strong> İrade kaybı, çaresizlik</div>
                                </div>
                            </div>
                            <p class="text-sm text-on-surface-variant">
                                Bu duyguların hepsi <strong>normal</strong> bir süreçtir. İTarafsız, kabul eden, şefkatli bir tutumla bu duyguları ifade etmek iyileşme için ilk adımdır.
                            </p>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Duygusal destek" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                                <p class="text-2xl font-headline">%60</p>
                                <p class="text-[10px] text-on-surface-variant">Anksiyete oranı (infertil çiftler)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 2: Çift İlişkilerine Etkisi -->
        <section id="cift" class="max-w-5xl mx-auto px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-on-surface mb-6">2. Çift İlişkilerine Etkisi ve Baş Etme</h2>
                    <div class="space-y-6 text-on-surface-variant">
                        <p>
                            İnfertilite genellikle bir çiftin sorunu olmasına rağmen, her iki partnerin de farklı şekillerde etkilendiğini görürüz. Kadınlar genellikle duygusal yükü Alırken, erkekler daha çok "başarısız erkek" duygusunu yaşayabilir.
                        </p>
                        <p>
                            Cinsellik, komşuluk ilişkisi, iletişim kalitesi bozulabilir. "Amacılı" cinsellik, kaygı ve performans baskısı yaratır. Bazen çiftler birbirinden uzaklaşabilir; suçlama ve kavganın artmasına neden olabilir.
                        </p>
                        <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                            <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">psychology</span>
                                İletişim Stratejileri
                            </h4>
                            <div class="space-y-3 text-sm">
                                <p><strong>Açık İletişim:</strong> Duyguları önyargısız paylaşın. "Ben hissetme" ifadelerini kullanın. ("Ben hissetiyorum..." zorunda hissetmekten korkuyorum").</p>
                                <p><strong>Empati:</strong> Partnerinizin duygularını geçmişiniz. Onun deneyimini kabul edin, "çözüm bulma" modundan kaçının.</p>
                                <p><strong>Sınırlar:</strong> Aile, arkadaşlarla konuşma sınırları belirleyin. "Nasıl çocuğunuz yok?" gibi soruların etkisine yönetilemez.</p>
                                <p><strong>Birlikte Vakit:</strong> İnfertilite dışı birliktelik aktiviteleri planlayın. Tedavinin tümüne anlam verin.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="md:w-1/2">
                    <div class="relative group">
                        <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Çift destek" width="512" height="512" loading="lazy"/>
                        <div class="absolute -bottom-6 -left-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                            <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                            <p class="text-2xl font-headline">%50</p>
                            <p class="text-[10px] text-on-surface-variant">Çiftlerde iletişim sorunları</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 3: Baş Etme Stratejileri -->
        <section id="basetme" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">3. Baş Etme Stratejileri</h2>
                        <div class="space-y-6 text-on-surface-variant">
                            <p>
                                Bilinçlı baş etme stratejileri, duygusal dayanıklılığınızı artırabilir. Tedavi sürecinde sizin kontrolünüzde olan şeyler (yaşam tarzı, stres yönetimi, sosyal medya kullanımı) odaklanabileceğiniz alanlardır.
                            </p>
                            <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                                <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">biotech</span>
                                    Etkili Stratejiler
                                </h4>
                                <ul class="space-y-3 text-sm">
                                    <li class="flex gap-2">
                                        <span class="material-symbols-outlined text-primary shrink-0">check_circle</span>
                                        <span><strong>Bilinçli Farkındalık (Mindfulness):</strong> Günlük 10-15 dakika meditasyon, nefes egzersizleri (4-7-8 tekniği).</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="material-symbols-outlined text-primary shrink-0">check_circle</span>
                                        <span><strong>Fiziksel Aktivite:</strong> Düzenzel hafif egzersiz (yürüyüş, yoga, yüzme). Yoğun antrenmanlar (üretim bozulması riski) kaçının.</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="material-symbols-outlined text-primary shrink-0">check_circle</span>
                                        <span><strong>Günlük:</strong> Duyguları yazmak, şükran günlüğü, bullet journal.</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="material-symbols-outlined text-primary shrink-0">check_circle</span>
                                        <span><strong>Sosyal Medya Sınırı:</strong> Başarı hikayeleri tetikleyen içeriklerden uzaklaşın. "Digital detox" dönemleri yapın.</span>
                                    </li>
                                    <li class="flex gap-2">
                                        <span class="material-symbols-outlined text-primary shrink-0">check_circle</span>
                                        <span><strong>Sınır Belirleme:</strong> "İyiki" diye söylenen sorulara kısa cevaplar verin. "O adam sadece kendi yolunda" diyerek çevrenizi yönetin.</span>
                                    </li>
                                </ul>
                            </div>
                            <p class="text-sm text-on-surface-variant">
                                Hatırlayın: Kendinize karşı şefkatli olmak bir çaresizlik değil, güçlü bir psikolojik stratejidir.
                            </p>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Mindfulness ve baş etme" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Etkili</p>
                                <p class="text-2xl font-headline">%40</p>
                                <p class="text-[10px] text-on-surface-variant">Mindfulness'in anksiyete azaltma oranı</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 4: Başarısız Denemeler ve Yas -->
        <section id="yas" class="max-w-5xl mx-auto px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-on-surface mb-6">4. Başarısız Denemeler ve Yas Süreci</h2>
                    <div class="space-y-6 text-on-surface-variant">
                        <p>
                            Bir IVF döngüsünün sonuçlanması, bir "kayıp" deneyimidir. Gebelik testinin negatif çıkması veya düşük yaşamı deneyimlemek, beklentili bir bekleme süresinden sonra gelen bir yası andırır.
                        </p>
                        <p>
                            Yas süreci doğal ve gerekli bir süreçtir. Şok, inkara, öfke, pazarlık, depresyon ve kabul evrelerinden geçersiniz. Bu evreler düzensizdir; bazen aynı gün içinde birden çok evre yaşayabilirsiniz.
                        </p>
                        <div class="bg-surface-container-low border-l-4 border-primary rounded-xl p-6 mrd-container">
                            <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">biotech</span>
                                Ne Zaman Tekrar Denemeliyim?
                            </h4>
                            <div class="space-y-3 text-sm">
                                <div class="flex items-start gap-3">
                                    <span class="font-mono font-bold text-primary shrink-0">Kişisel karar</span>
                                    <span class="text-on-surface-variant">Hiçbir zaman "zorlamayın". Kendiniz hazır olduğunuzda devam edin.</span>
                                </div>
                                <div class="flex items-start gap-3 border-t border-outline-variant/10 pt-3">
                                    <span class="font-mono font-bold text-primary shrink-0">Klinik değerlendirme</span>
                                    <span class="text-on-surface-variant">Bir sonraki döngü için laboratoryal değişiklikler (embriyo tarama, vakum yerleştirme) istenebilir.</span>
                                </div>
                                <div class="flex items-start gap-3 border-t border-outline-variant/10 pt-3">
                                    <span class="font-mono font-bold text-primary shrink-0">Zamanlama</span>
                                    <span class="text-on-surface-variant">Çoğu merkez minimum 2-3 ay bekleme önerir; ancak psikolojik olarak hazır olunca hemen başlanabilir.</span>
                                </div>
                            </div>
                        </div>
                        <p class="text-sm text-on-surface-variant">
                            <strong>Unutmayın:</strong> Her döngü için sizin kararınız geçerlidir. Doktorunuz size yönerge verebilir, ancak siz kontroldesiniz.
                        </p>
                    </div>
                </div>
                <div class="md:w-1/2">
                    <div class="relative group">
                        <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Yas süreci" width="512" height="512" loading="lazy"/>
                        <div class="absolute -bottom-6 -left-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                            <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                            <p class="text-2xl font-headline">6-8</p>
                            <p class="text-[10px] text-on-surface-variant">Haftalık ortalama yas süresi</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 5: Profesyonel Destek -->
        <section id="destek" class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-8">
                <div class="flex flex-col md:flex-row gap-16 items-center">
                    <div class="md:w-1/2">
                        <h2 class="font-headline text-3xl text-on-surface mb-6">5. Ne Zaman Profesyonel Destek Aramalısınız?</h2>
                        <div class="space-y-6 text-on-surface-variant">
                            <p>
                                Bazen kendi kaynaklarınız yeterli olmayabilir. Profesyonel psikolojik destek, izolasyonu kırmak ve sağlıklı bir süreç yönetimi için kritik adımdır.
                            </p>
                            <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                                <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">psychology</span>
                                    Kırmızı Bayraklar (Yardım Zamanı)
                                </h4>
                                <ul class="space-y-2 text-sm">
                                    <li>• Sürekli uykusuzluk, iştahsızlık, backgroundColor kaybı</li>
                                    <li>• Kendine zarar verme düşünceleri veya intihar planları</li>
                                    <li>• anchorı sosyal çekilme, iş/okul performans düşüşü</li>
                                    <li>• Aşırı alkol/kullanım, uygunsuz davranışlar</li>
                                    <li>• Çift çatışmalarının artması, şiddet eğilimi</li>
                                    <li>• Tedavi kararlarında “çaresizlik” hissi</li>
                                </ul>
                            </div>
                            <div class="bg-surface-container-low border-l-4 border-primary rounded-xl p-6">
                                <h4 class="font-bold text-on-surface text-sm mb-3">Yardımcı Olabilecek Terapiler</h4>
                                <div class="space-y-3 text-sm">
                                    <div>
                                        <strong>CBT (Bilişsel Davranışçı Terapi):</strong> Olumsuz düşünce çürüme, davranış değişimi.
                                    </div>
                                    <div>
                                        <strong>EMDR:</strong> Travmatik anıların işlenmesi (özellikle gebelik kayıplarından sonra).
                                    </div>
                                    <div>
                                        <strong>Çift Terapisi:</strong> İletişim becerileri, müzakere, birlikte baş etme.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2">
                        <div class="relative group">
                            <img class="rounded-2xl shadow-xl w-full" src="/images/sorunlar/hormonal-cycles.jpg" alt="Profesyonel destek" width="512" height="512" loading="lazy"/>
                            <div class="absolute -bottom-6 -right-6 bg-surface-container-highest p-4 rounded-lg hidden md:block">
                                <p class="text-xs font-bold text-primary tracking-widest uppercase mb-1">Klinik Veri</p>
                                <p class="text-2xl font-headline">%30</p>
                                <p class="text-[10px] text-on-surface-variant">Terapi alan infertilite hastaları</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Section 6: Destek Grupları ve Kaynaklar -->
        <section id="kaynaklar" class="max-w-5xl mx-auto px-8 mb-24">
            <div class="flex flex-col md:flex-row-reverse gap-16 items-center">
                <div class="md:w-1/2">
                    <h2 class="font-headline text-3xl text-on-surface mb-6">6. Destek Grupları ve Kaynaklar</h2>
                    <div class="space-y-6 text-on-surface-variant">
                        <p>
                            Benzer deneyimleri yaşayan insanlarla bağlantı kurmak, yalnızlık hissini azaltabilir ve pratik bilgiler edinmenizi sağlayabilir.
                        </p>
                        <div class="bg-white border-l-4 border-primary rounded-xl p-6 mrd-container">
                            <h4 class="font-bold text-on-surface text-sm mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">group</span>
                                Türkçe Destek Grupları & Kaynaklar
                            </h4>
                            <ul class="space-y-3 text-sm">
                                <li class="flex gap-2">
                                    <span class="material-symbols-outlined text-primary shrink-0">link</span>
                                    <span><strong>tüp bebek Destek Forumları:</strong> tupbebek.com topluluk, çeşitli sosyal medya grupları</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="material-symbols-outlined text-primary shrink-0">link</span>
                                    <span><strong>Türkiye Üreme Tıbbı Dernekleri:</strong> TÜRMED, TİD</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="material-symbols-outlined text-primary shrink-0">link</span>
