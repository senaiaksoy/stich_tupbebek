---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Sıkça Sorulan Sorular | tupbebek.com">
    <Header />
    
    <header class="pt-32 pb-20 px-8 bg-surface-container-low overflow-hidden relative">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 items-center gap-12 relative z-10">
            <div class="space-y-6">
                <span class="inline-block px-4 py-1.5 rounded-full bg-primary-container text-on-primary-container text-xs font-semibold tracking-wider uppercase">Bilgi Merkezi</span>
                <h1 class="text-5xl md:text-6xl font-headline leading-tight text-on-surface">Sıkça Sorulan Sorular: Bilimsel Yanıtlar</h1>
                <p class="text-lg text-on-surface-variant max-w-xl leading-relaxed">
                    Tedavi süreci, başarı oranları ve tıbbi protokoller hakkında en çok merak edilen soruların kanıta dayalı yanıtları.
                </p>
                <div class="flex items-center gap-3 pt-4">
                    <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-on-surface">Bilimsel Doğruluk</p>
                        <p class="text-xs text-on-surface-variant">Tüm yanıtlar güncel literatüre dayanmaktadır.</p>
                    </div>
                </div>
            </div>
            <div class="relative">
                <div class="rounded-3xl overflow-hidden aspect-[4/3] shadow-2xl transform rotate-1">
                    <img alt="Scientific Visualization" class="w-full h-full object-cover" src="/images/sss/scientific-viz.jpg" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
                <div class="absolute -bottom-6 -left-6 bg-surface-container-lowest p-6 rounded-2xl shadow-xl max-w-xs hidden lg:block">
                    <p class="text-xs font-headline italic text-on-surface-variant mb-2">"Bilgi, en etkili tedavi bileşenidir."</p>
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-1 rounded-full bg-primary/20"></div>
                        <span class="text-[10px] font-bold uppercase tracking-tighter text-primary">Tıbbi Etik Kurulu</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-8 py-24">
        <div class="grid lg:grid-cols-12 gap-12 items-start">
            <!-- Category Navigation Sidebar -->
            <aside class="lg:col-span-3 sticky top-28 space-y-8">
                <div>
                    <h3 class="text-xs font-bold text-outline uppercase tracking-widest mb-6">Kategoriler</h3>
                    <nav class="space-y-2">
                        <button class="w-full text-left px-4 py-3 rounded-xl bg-surface-container-high text-primary font-bold flex justify-between items-center group transition-all">
                            Genel Sorular
                            <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity">arrow_forward</span>
                        </button>
                        <button class="w-full text-left px-4 py-3 rounded-xl hover:bg-surface-container text-on-surface-variant transition-all">Tedavi Süreci</button>
                        <button class="w-full text-left px-4 py-3 rounded-xl hover:bg-surface-container text-on-surface-variant transition-all">Başarı Oranları</button>
                        <button class="w-full text-left px-4 py-3 rounded-xl hover:bg-surface-container text-on-surface-variant transition-all">Yaşam Tarzı</button>
                    </nav>
                </div>
                <div class="p-6 rounded-2xl bg-tertiary-container text-on-tertiary-container">
                    <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined icon-filled text-xl">clinical_notes</span>
                    </div>
                    <h4 class="font-bold mb-2">Kişisel Danışmanlık</h4>
                    <p class="text-sm opacity-80 mb-4 leading-relaxed">Sizin durumunuza özel bilimsel veriler için uzman ekibimizle görüşün.</p>
                    <a class="text-sm font-bold flex items-center gap-2 group underline" href="#">
                        Uzmanla İletişim <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">trending_flat</span>
                    </a>
                </div>
            </aside>

            <!-- FAQ Accordion Section -->
            <div class="lg:col-span-9 space-y-20">
                <section>
                    <div class="mb-10 flex items-end justify-between">
                        <div>
                            <h2 class="text-3xl font-headline mb-2 text-on-surface">Genel Sorular</h2>
                            <p class="text-on-surface-variant text-sm">Üreme sağlığı ve tüp bebek temelleri hakkında temel bilgiler.</p>
                        </div>
                        <div class="w-20 h-px bg-outline-variant/30 mb-2"></div>
                    </div>
                    <div class="space-y-4">
                        <details class="group bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                <span class="text-lg font-medium text-on-surface pr-8">Tüp bebek tedavisi ne kadar sürer?</span>
                                <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                            </summary>
                            <div class="px-6 pb-8 pt-2">
                                <div class="w-full h-px bg-surface-container mb-6"></div>
                                <div class="text-on-surface-variant leading-relaxed space-y-4 max-w-4xl">
                                    <p>Standart bir tüp bebek siklusu, adet döneminin ikinci veya üçüncü günü başlar ve yaklaşık 15-20 günlük bir süreci kapsar. Bu süreç; yumurtalıkların uyarılması, yumurta toplama (OPU) ve embriyo transferi aşamalarından oluşur.</p>
                                    <p>Dondurulmuş embriyo transferi (FET) veya genetik tarama (PGT) gibi ek prosedürler gerektiğinde, toplam süre iki ay veya daha fazlasına yayılabilir. Tedavi planı hastanın hormonal profiline göre kişiselleştirilmektedir.</p>
                                </div>
                            </div>
                        </details>

                        <details class="group bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                <span class="text-lg font-medium text-on-surface pr-8">Yaşın başarı oranları üzerindeki etkisi nedir?</span>
                                <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                            </summary>
                            <div class="px-6 pb-8 pt-2">
                                <div class="w-full h-px bg-surface-container mb-6"></div>
                                <div class="text-on-surface-variant leading-relaxed max-w-4xl">
                                    <p>Kadın yaşı, tüp bebek başarısındaki en kritik bağımsız değişkendir. Tıbbi literatür, 35 yaş altındaki hastalarda başarı oranlarının en yüksek seviyede olduğunu, 40 yaş ve sonrasında ise over rezervindeki azalma ve oosit kalitesindeki düşüş nedeniyle oranların kademeli olarak azaldığını göstermektedir.</p>
                                </div>
                            </div>
                        </details>

                        <details class="group bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                <span class="text-lg font-medium text-on-surface pr-8">PGT testi her hastaya uygulanmalı mıdır?</span>
                                <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                            </summary>
                            <div class="px-6 pb-8 pt-2">
                                <div class="w-full h-px bg-surface-container mb-6"></div>
                                <div class="text-on-surface-variant leading-relaxed max-w-4xl">
                                    <p>Preimplantasyon Genetik Tanı (PGT), rutin bir uygulama olmayıp endikasyon bazlıdır. Genellikle; ileri anne yaşı (37+), tekrarlayan düşük öyküsü, başarısız tüp bebek denemeleri veya bilinen genetik hastalık taşıyıcılığı durumlarında klinik protokol olarak önerilir.</p>
                                    <p class="mt-4"><a href="/makaleler/genetik-testler" class="text-primary font-bold hover:underline inline-flex items-center gap-1">İlgili Makale: Genetik Tarama Teknolojileri <span class="material-symbols-outlined text-sm">open_in_new</span></a></p>
                                </div>
                            </div>
                        </details>

                        <details class="group bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                <span class="text-lg font-medium text-on-surface pr-8">Transfer sonrası dinlenme süreci nasıl olmalıdır?</span>
                                <span class="material-symbols-outlined transition-transform duration-300 group-open:rotate-180">expand_more</span>
                            </summary>
                            <div class="px-6 pb-8 pt-2">
                                <div class="w-full h-px bg-surface-container mb-6"></div>
                                <div class="text-on-surface-variant leading-relaxed max-w-4xl">
                                    <p>Modern klinik çalışmalar, transfer sonrası günlerce yatak istirahatinin gebelik oranlarını artırmadığını kanıtlamıştır. İşlem günü kısa bir istirahat yeterlidir. Sonraki günlerde aşırı fiziksel efordan kaçınmak kaydıyla günlük sosyal yaşama dönülmesi tavsiye edilir.</p>
                                    <p class="mt-4"><a href="/makaleler/dondurulmus-embriyo-transferi" class="text-primary font-bold hover:underline inline-flex items-center gap-1">İlgili Makale: Dondurulmuş Embriyo Transferi Rehberi <span class="material-symbols-outlined text-sm">open_in_new</span></a></p>
                                </div>
                            </div>
                        </details>
                    </div>
                </section>

                <section class="bg-surface-container p-10 rounded-3xl flex flex-col md:flex-row items-center gap-8 border border-outline-variant/10">
                    <div class="w-24 h-24 rounded-full bg-primary-container overflow-hidden shrink-0 border-4 border-white flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary text-4xl">verified_user</span>
                    </div>
                    <div class="flex-grow text-center md:text-left">
                        <h4 class="text-xl font-headline font-bold text-on-surface mb-1">Tıbbi İnceleme ve Onay</h4>
                        <p class="text-on-surface-variant mb-4">Bu sayfadaki tüm içerikler güncel tıbbi kılavuzlar doğrultusunda hazırlanmış ve denetlenmiştir.</p>
                        <div class="flex flex-wrap justify-center md:justify-start gap-4">
                            <span class="flex items-center gap-1.5 text-xs font-bold text-primary">
                                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                DR. SENAİ AKSOY
                            </span>
                            <span class="text-xs text-outline-variant">•</span>
                            <span class="text-xs font-medium text-on-surface-variant uppercase tracking-wide">Tıbbi İnceleme Kurulu Başkanı</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>
