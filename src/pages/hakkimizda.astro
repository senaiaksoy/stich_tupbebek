---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Hakkımızda | tupbebek.com">
    <Header />
    
    <main class="pt-32">
        <!-- Hero Section: The Editorial Statement -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
                <div class="lg:col-span-8">
                    <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4 block">HAKKIMIZDA</span>
                    <h1 class="font-headline text-5xl lg:text-7xl font-bold leading-tight text-on-surface mb-8">
                        Bağımsız, Bilimsel ve <br/><span class="text-primary-dim italic">Şeffaf Bilgi Kaynağı.</span>
                    </h1>
                    <p class="text-xl text-on-surface-variant max-w-2xl leading-relaxed">
                        tupbebek.com, infertilite yolculuğunda olan bireyler için ticari kaygılardan arındırılmış, akademik titizlikle hazırlanmış bir rehberdir. Biz bir klinik değiliz; doğru bilgiye erişim hakkınızın savunucusuyuz.
                    </p>
                </div>
                <div class="lg:col-span-4 pb-4">
                    <div class="bg-surface-container p-8 rounded-xl border-l-4 border-primary">
                        <p class="font-headline text-lg italic text-on-surface">"Bilgi, belirsizliğin panzehiridir."</p>
                        <p class="text-sm mt-4 text-on-surface-variant">— Akademik Kurul Misyonu</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Bento Grid: Mission & Existence -->
        <section class="bg-surface-container-low py-24">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Why We Exist -->
                    <div class="md:col-span-2 bg-surface-container-lowest p-12 rounded-xl shadow-sm">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="material-symbols-outlined text-primary text-4xl">clinical_notes</span>
                            <h2 class="font-headline text-3xl font-bold">Neden Buradayız?</h2>
                        </div>
                        <p class="text-lg text-on-surface-variant leading-relaxed mb-6">
                            İnfertilite tedavisi süreci, bilgi kirliliğinin ve duygusal sömürünün en yoğun olduğu alanlardan biridir. tupbebek.com, hastaların "en iyi klinik" reklamları arasında kaybolmadan, kendi tedavi süreçlerini anlayabilmeleri için kuruldu.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"></span>
                                <span class="text-on-surface">Karmaşık tıbbi verileri herkesin anlayabileceği bir dile dönüştürmek.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 flex-shrink-0"></span>
                                <span class="text-on-surface">Tedavi seçeneklerini ticari bir yönlendirme yapmadan sunmak.</span>
                            </li>
                        </ul>
                    </div>
                    <!-- Independent Status -->
                    <div class="bg-primary text-on-primary p-12 rounded-xl flex flex-col justify-between">
                        <div>
                            <span class="material-symbols-outlined text-4xl mb-6">verified_user</span>
                            <h3 class="font-headline text-2xl font-bold mb-4">Tam Bağımsızlık</h3>
                            <p class="opacity-90 leading-relaxed">
                                Bu portal herhangi bir tüp bebek merkezine, ilaç firmasına veya özel sağlık kuruluşuna bağlı değildir. İçeriklerimiz hiçbir sponsorlu yönlendirme içermez.
                            </p>
                        </div>
                        <div class="pt-8 border-t border-white/20">
                            <p class="text-sm font-bold tracking-wider uppercase">Bağımsızlık Sertifikası 2024</p>
                        </div>
                    </div>
                    <!-- Editorial Policy -->
                    <div class="bg-surface-container-high p-12 rounded-xl md:col-span-3">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                            <div>
                                <h2 class="font-headline text-3xl font-bold mb-6">Editoryal Politikamız</h2>
                                <p class="text-on-surface-variant leading-relaxed mb-8">
                                    Yayımladığımız her makale, her rehber ve her istatistik, "Kanıta Dayalı Tıp" (Evidence-Based Medicine) prensiplerine dayanır. Akademik kaynaklarımızı her içeriğin sonunda açıkça paylaşıyoruz.
                                </p>
                                <div class="grid grid-cols-2 gap-4">
                                    <div class="bg-surface-container-lowest p-4 rounded-lg">
                                        <p class="text-primary font-bold text-2xl mb-1">100%</p>
                                        <p class="text-xs uppercase tracking-tighter text-on-surface-variant font-bold">Akademik Onay</p>
                                    </div>
                                    <div class="bg-surface-container-lowest p-4 rounded-lg">
                                        <p class="text-primary font-bold text-2xl mb-1">0%</p>
                                        <p class="text-xs uppercase tracking-tighter text-on-surface-variant font-bold">Ticari Reklam</p>
                                    </div>
                                </div>
                            </div>
                            <div class="relative aspect-video rounded-xl overflow-hidden">
                                <img alt="Clinical Review" class="object-cover w-full h-full" src="/images/hakkimizda/clinical-review.jpg"/>
                                <div class="absolute inset-0 bg-primary/10"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Medical Reviewer: Dr. Senai Aksoy -->
        <section class="py-32">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4 block">TIBBİ İNCELEME KURULU</span>
                    <h2 class="font-headline text-4xl font-bold">Uzman Denetimi</h2>
                </div>
                <div class="bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm flex flex-col lg:flex-row border border-outline-variant/10">
                    <div class="lg:w-1/3 h-[500px]">
                        <img alt="Dr. Senai Aksoy" class="w-full h-full object-cover" src="/images/senai-aksoy.jpg"/>
                    </div>
                    <div class="lg:w-2/3 p-12 lg:p-20 flex flex-col justify-center">
                        <div class="inline-flex items-center gap-2 px-3 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-bold w-fit mb-6">
                            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                            MEDİKAL DİREKTÖR
                        </div>
                        <h3 class="font-headline text-4xl font-bold mb-2 text-on-surface">Dr. Senai Aksoy</h3>
                        <p class="text-primary text-xl font-medium mb-8">Tıbbi İnceleme Başkanı</p>
                        <p class="text-lg text-on-surface-variant leading-relaxed mb-8">
                            Dr. Senai Aksoy, tupbebek.com bünyesindeki tüm tıbbi içeriklerin bilimsel doğruluğunu ve güncelliğini denetleyen baş inceleyicimizdir. Yayınlanan her rehber, hastaların en doğru ve güncel tedavi protokollerine erişebilmesi için kendisinin ve ekibinin onayından geçer.
                        </p>
                        <div class="flex flex-wrap gap-4">
                            <div class="flex items-center gap-3 bg-surface p-4 rounded-xl border border-outline-variant/20">
                                <span class="material-symbols-outlined text-primary">school</span>
                                <span class="text-sm font-semibold">Akademik Doğrulama</span>
                            </div>
                            <div class="flex items-center gap-3 bg-surface p-4 rounded-xl border border-outline-variant/20">
                                <span class="material-symbols-outlined text-primary">fact_check</span>
                                <span class="text-sm font-semibold">Güncel Protokoller</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA / Final Statement -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 mb-32">
            <div class="bg-secondary-container rounded-3xl p-16 text-center relative overflow-hidden">
                <div class="relative z-10 max-w-2xl mx-auto">
                    <h2 class="font-headline text-3xl font-bold text-on-secondary-container mb-6">Sağlığınız İçin Bir Not</h2>
                    <p class="text-on-secondary-container opacity-80 mb-10 leading-relaxed">
                        tupbebek.com üzerinde yer alan bilgiler, profesyonel bir tıbbi tavsiye, teşhis veya tedavi yerine geçmez. Lütfen herhangi bir tıbbi karar vermeden önce uzman bir hekime danışınız.
                    </p>
                    <div class="flex flex-col sm:flex-row justify-center gap-4">
                        <a href="/sss" class="bg-primary text-on-primary px-8 py-4 rounded-xl font-bold hover:bg-primary-dim transition-all inline-block">Sıkça Sorulan Sorular</a>
                        <button class="bg-surface-container-lowest text-primary px-8 py-4 rounded-xl font-bold border border-primary/10 hover:bg-surface-container-high transition-all">İletişime Geçin</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
