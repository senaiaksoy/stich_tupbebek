---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Yardımcı Üreme Teknikleri ve Tedavi Yöntemleri | tupbebek.com" description="IVF, ICSI, IUI, aşılama, yumurta dondurma, PGT ve diğer yardımcı üreme tekniklerinin karşılaştırmalı rehberi.">
    <Header />
    
    <main id="main-content" tabindex="-1" class="pt-20">
        <!-- Hero Section -->
        <header class="relative overflow-hidden bg-surface-container-low pt-24 pb-32 px-8">
            <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <div class="lg:col-span-7">
                    <nav class="flex items-center gap-2 mb-6 text-sm text-on-surface-variant font-label">
                        <a href="/">Anasayfa</a>
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                        <span>Tedavi Yöntemleri</span>
                    </nav>
                    <h1 class="text-5xl lg:text-7xl font-headline text-primary mb-8 tracking-tight leading-tight">Yardımcı Üreme Teknikleri</h1>
                    <p class="text-xl text-on-surface-variant leading-relaxed max-w-2xl mb-10">
                        Modern tıbbın sunduğu en ileri reprodüktif teknolojiler, bilimsel protokoller çerçevesinde ve etik standartlara bağlı kalarak uygulanmaktadır. Bilimsel veriye dayalı tedavi metodolojimiz aşağıda detaylandırılmıştır.
                    </p>
                    <div class="flex items-center gap-4 py-4 border-l-4 border-tertiary pl-6 bg-surface-container-lowest/50 rounded-r-xl inline-flex">
                        <div class="flex flex-col">
                            <span class="text-xs uppercase tracking-widest text-on-tertiary-fixed-variant font-bold">Medical Reviewer</span>
                            <span class="text-lg font-headline text-on-surface">Dr. Senai Aksoy</span>
                        </div>
                    </div>
                </div>
                <div class="lg:col-span-5 relative">
                    <div class="aspect-square rounded-[2rem] overflow-hidden shadow-2xl rotate-3 bg-primary-container">
                        <img class="w-full h-full object-cover mix-blend-multiply opacity-80" src="/images/tedavi-yontemleri/lab-microscope.webp" alt="Laboratuvar mikroskobu" width="512" height="512" loading="eager" fetchpriority="high"/>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-surface-container-lowest p-6 rounded-xl shadow-lg max-w-[240px]">
                        <span class="material-symbols-outlined text-tertiary mb-2 block">verified</span>
                        <p class="text-xs font-label text-on-surface-variant italic leading-snug">"Tüm veriler güncel klinik araştırmalar ve ESHRE kılavuzları ile uyumludur."</p>
                    </div>
                </div>
            </div>
        </header>

        <!-- Treatments Grid -->
        <section class="py-24 px-8 max-w-7xl mx-auto">
            <div class="mb-16">
                <h2 class="text-3xl font-headline text-on-surface mb-4">Temel Tedavi Protokolleri</h2>
                <div class="h-1 w-24 bg-primary rounded-full"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Card 1: IVF & ICSI -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300 border border-transparent hover:border-outline-variant/10">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">science</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">IVF &amp; ICSI</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">In-vitro fertilizasyon ve intrasitoplazmik sperm enjeksiyonu tekniklerinin klinik entegrasyonu.</p>
                    <a href="/makaleler/azospermi-mikro-tese" class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
                <!-- Card 2: Aşılama (IUI) -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">medication</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">Aşılama (IUI)</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">İntrauterin inseminasyon ile kontrollü ovaryan stimülasyon sonrası fertilite optimizasyonu.</p>
                    <button class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </button>
                </div>
                <!-- Card 3: Yumurtlama Takibi -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">monitor_heart</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">Yumurtlama Takibi</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">Ultrasonografik ve hormonal parametreler eşliğinde ovülasyon döneminin hassas tespiti.</p>
                    <button class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </button>
                </div>
                <!-- Card 4: PGT -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">genetics</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">PGT</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">Preimplantasyon genetik tanı ile kromozomal anomali taraması ve embriyo seleksiyonu.</p>
                    <a href="/makaleler/genetik-testler" class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
                <!-- Card 5: Embriyo Dondurma -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">ac_unit</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">Embriyo Dondurma</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">Vitrifikasyon tekniği ile embriyo kriyoprezervasyonu ve dondurulmuş transfer siklusları.</p>
                    <a href="/makaleler/dondurulmus-embriyo-transferi" class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
                <!-- Card 6: Fertilite Koruma -->
                <div class="bg-surface-container-lowest p-8 rounded-xl flex flex-col group hover:shadow-xl transition-all duration-300">
                    <span class="material-symbols-outlined text-primary mb-6 text-4xl">shield_with_heart</span>
                    <h3 class="text-2xl font-headline mb-4 group-hover:text-primary transition-colors">Fertilite Koruma</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">Onkolojik veya sosyal endikasyonlar ile yumurta ve sperm hücrelerinin dondurulması.</p>
                    <button class="w-full py-3 bg-surface-container text-primary font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-primary hover:text-on-primary transition-all">
                        Bilimsel İnceleme
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </button>
                </div>
            </div>
        </section>

        <!-- Special Procedures Section -->
        <section class="py-24 bg-surface-container-low px-8">
            <div class="max-w-7xl mx-auto">
                <div class="mb-16 text-center">
                    <span class="text-tertiary font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Advanced Methodologies</span>
                    <h2 class="text-4xl font-headline text-on-surface">Özel Prosedürler</h2>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <!-- Procedure 1 -->
                    <div class="flex flex-col md:flex-row bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm">
                        <div class="md:w-1/3 bg-primary-container relative">
                            <img class="w-full h-full object-cover" src="/images/tedavi-yontemleri/petri-dish.webp" alt="EmbryoGlue" width="512" height="512" loading="lazy"/>
                        </div>
                        <div class="p-8 md:w-2/3">
                            <h3 class="text-xl font-headline text-primary mb-4">EmbryoGlue</h3>
                            <p class="text-sm text-on-surface-variant leading-relaxed mb-6">
                                Hyaluronan zenginleştirilmiş transfer medyası kullanımı ile embriyo-endometrium etkileşiminin biyo-kimyasal olarak desteklenmesi prosedürüdür.
                            </p>
                            <a href="/makaleler/embryoglue-faydalari" class="text-primary font-bold text-sm flex items-center gap-2 hover:underline">
                                <span class="material-symbols-outlined">description</span>
                                Bilimsel İnceleme
                            </a>
                        </div>
                    </div>
                    <!-- Procedure 2 -->
                    <div class="flex flex-col md:flex-row bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm">
                        <div class="md:w-1/3 bg-tertiary-container relative">
                            <img class="w-full h-full object-cover" src="/images/tedavi-yontemleri/clinical-lab.webp" alt="Endometrial Scratching" width="512" height="512" loading="lazy"/>
                        </div>
                        <div class="p-8 md:w-2/3">
                            <h3 class="text-xl font-headline text-primary mb-4">Endometrial Scratching</h3>
                            <p class="text-sm text-on-surface-variant leading-relaxed mb-6">
                                İmplantasyon penceresi öncesi endometrium dokusuna uygulanan mikro-uyarıların başarı oranları üzerindeki sitokin etkisi incelemesi.
                            </p>
                            <a href="/makaleler/ivf-oncesi-histeroskopi" class="text-primary font-bold text-sm flex items-center gap-2 hover:underline">
                                <span class="material-symbols-outlined">description</span>
                                Bilimsel İnceleme
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
