---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Editöryal Politika | tupbebek.com" description="İçerik üretim ilkelerimiz ve editoryal politikamız">
    <Header />
    <main id="main-content" tabindex="-1" class="py-24">
        <section class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
            <h1 class="font-headline text-4xl text-gray-900 mb-8">Editöryal Politika</h1>
            <p class="text-gray-600">İçerik yakında eklenecek.</p>
        </section>
    </main>
    <Footer />
</BaseLayout>
