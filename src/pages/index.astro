---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const recentArticles = (await getCollection('articles')).slice(0, 3);
---

<BaseLayout title="tupbebek.com | Üreme Sağlığı Bilgisi">
    <Header />
    
    <main class="pt-24">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-8 mb-20 relative">
            <div class="grid lg:grid-cols-2 gap-16 items-center py-20">
                <div class="order-2 lg:order-1">
                    <h1 class="text-5xl lg:text-6xl font-headline text-on-surface leading-tight mb-8">
                        Bilimsel Derinlik, <br/><span class="italic text-primary">İnsani Hassasiyet</span>
                    </h1>
                    <p class="text-lg text-secondary leading-relaxed mb-10 max-w-xl">
                        1996’dan bu yana, üreme tıbbındaki en ileri teknolojileri ve hakemli klinik verileri, otuz yılı aşkın hekimlik tecrübemizin süzgecinden geçiriyoruz. Akademik derinliğimizi, bir ailenin heyecanına duyduğumuz saygıyla harmanladık. Binlerce hikâyeye eşlik eden bu kapsamlı bilgi yolculuğunda, yanınızdayız.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="/tedavi-yontemleri" class="bg-primary text-on-primary px-8 py-3 rounded-xl font-medium hover:bg-primary-dim transition-colors inline-block">Yaşama Dokunan Tedaviler</a>
                        <a href="/makaleler" class="border border-outline-variant/30 text-primary px-8 py-3 rounded-xl font-medium hover:bg-surface-container transition-colors inline-block">Bilimsel Yaklaşımımız</a>
                    </div>
                </div>
                <div class="order-1 lg:order-2">
                    <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl relative">
                        <img alt="temiz ve steril laboratuvar ortamında, mavi klinik ışıklandırma ve tıbbi camlar altında petri kabının mikroskobik yakın çekimi" class="w-full h-full object-cover" src="/images/home/hero.jpg" width="512" height="512" loading="eager" fetchpriority="high"/>
                    </div>
                </div>
            </div>
        </section>

        <!-- Bento Knowledge Grid -->
        <section class="bg-surface-container-low py-24 relative overflow-hidden">
            <!-- Subtle Background glow -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-tertiary/5 blur-[120px] rounded-full"></div>

            <div class="max-w-7xl mx-auto px-8 relative z-10">
                <div class="mb-16 text-center">
                    <span class="text-[#C5A059] font-label uppercase tracking-[0.3em] text-xs font-bold mb-4 block">Akademik Rehber</span>
                    <h2 class="text-4xl lg:text-5xl font-headline text-on-surface mb-6">Temel Eğitim</h2>
                    <div class="h-0.5 w-24 bg-gradient-to-r from-transparent via-[#C5A059] to-transparent mx-auto opacity-50"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 auto-rows-[320px]">
                    <!-- Large Feature: Journey to Source of Life -->
                    <a href="/hakkimizda" class="md:col-span-8 md:row-span-2 bg-white/40 backdrop-blur-md border border-white/20 rounded-[2.5rem] flex flex-col md:flex-row group cursor-pointer overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-primary/10 transition-all duration-1000 ease-in-out">
                        <!-- Left Content (60%) -->
                        <div class="p-10 lg:p-12 md:w-[60%] flex flex-col justify-between relative z-10 bg-white/40">
                            <div>
                                <span class="text-primary/60 font-label uppercase tracking-widest text-xs font-bold mb-6 block">Klinik Derinlik</span>
                                <h3 class="text-4xl lg:text-5xl font-headline text-on-surface mb-8 group-hover:text-[#C5A059] transition-colors duration-700">Yaşamın Kaynağına <br/>Bilimsel Bir Yolculuk</h3>
                                <p class="text-secondary/90 max-w-md text-lg leading-relaxed font-light">
                                    İnsan fertilitesinin gizemli dünyasını, bilimin sınırlarını zorlayan araştırmalarla keşfedin. Doç. Dr. Senai Aksoy'un otuz yılı aşkın klinik derinliğiyle şekillenen bu rehber, biyolojik engelleri aşmanın vizyoner yollarını sunuyor.
                                </p>
                            </div>
                            <div class="mt-12">
                                <span class="flex items-center text-primary font-bold group-hover:text-[#C5A059] group-hover:gap-6 transition-all duration-700">
                                    KEŞFETMEYE BAŞLA <span class="material-symbols-outlined ml-3 scale-110">trending_flat</span>
                                </span>
                            </div>
                        </div>

                        <!-- Right Image Area (40%) -->
                        <div class="md:w-[40%] bg-primary relative flex items-center justify-center overflow-hidden">
                            <!-- Artistic Organic Frame -->
                            <div class="relative w-full h-full flex items-center justify-center p-8">
                                <div class="w-full h-full bg-white/5 backdrop-blur-sm rounded-[30%_70%_70%_30%_/_30%_30%_70%_70%] border border-white/10 overflow-hidden shadow-2xl relative group-hover:scale-105 transition-transform duration-1000 ease-in-out">
                                    <img 
                                        alt="yaşamın başlangıcını simgeleyen lüks safir mavisi ve altın moleküler yapılar içeren modern tıbbi illüstrasyon" 
                                        class="w-full h-full object-cover opacity-100 brightness-110 group-hover:scale-110 transition-transform duration-1000 ease-in-out" 
                                        src="/images/home/luxury-embryo.png" 
                                        width="512" height="512" 
                                        loading="lazy"
                                    />
                                    <!-- Inner Gold Glow -->
                                    <div class="absolute inset-0 bg-gradient-to-tr from-[#C5A059]/20 to-transparent pointer-events-none"></div>
                                </div>
                                <!-- Outer Gold Accents -->
                                <div class="absolute top-10 right-10 w-20 h-20 bg-[#C5A059]/10 blur-2xl rounded-full"></div>
                                <div class="absolute bottom-10 left-10 w-24 h-24 bg-primary-dim/20 blur-3xl rounded-full"></div>
                            </div>
                        </div>
                    </a>

                    <!-- Medium Feature: Futuristic Lab -->
                    <a href="/makaleler/laboratuvar-raporu-yorumlama" class="md:col-span-4 bg-surface-container-highest/50 backdrop-blur-sm rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-white/10 hover:border-[#C5A059]/30 hover:shadow-xl transition-all duration-700 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:shadow-md transition-all">
                                <span class="material-symbols-outlined text-[#C5A059]" style="font-size: 32px;">biotech</span>
                            </div>
                            <h3 class="text-2xl font-headline text-on-surface mb-5 group-hover:text-primary transition-colors">Fütüristik Laboratuvar: <br/>Mikro-Mükemmeliyet</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                Yaşamın ilk anlarını optimize eden, yapay zeka destekli inkübasyon ve ultra-modern embriyo seleksiyon sistemleriyle geleceği bugün inşa ediyoruz.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-[#C5A059] opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all">arrow_right_alt</span>
                    </a>

                    <!-- Medium Feature: Data Transparency -->
                    <a href="/makaleler/basari-oranlari" class="md:col-span-4 bg-primary text-on-primary rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer shadow-lg hover:shadow-primary/30 transition-all duration-1000 ease-in-out border border-primary-dim/20">
                        <div>
                            <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center mb-8 backdrop-blur-md">
                                <span class="material-symbols-outlined text-white/80" style="font-size: 32px;">analytics</span>
                            </div>
                            <h3 class="text-2xl font-headline mb-5">Veri Şeffaflığı ve <br/>Küresel Standart</h3>
                            <p class="text-on-primary/80 text-sm leading-relaxed font-light">
                                İstatistiğin ötesinde, her başarı yeni bir başlangıçtır. Veriye dayalı şeffaflık vizyonumuzla, kişiselleştirilmiş protokollerin dünya çapındaki başarısını analiz edin.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-white/50 group-hover:text-[#C5A059]/100 group-hover:translate-x-2 transition-all">north_east</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Latest Articles Section -->
        <section class="bg-surface-container py-24">
            <div class="max-w-7xl mx-auto px-8">
                <div class="flex justify-between items-end mb-12">
                    <div>
                        <h2 class="text-3xl font-headline text-on-surface mb-4">Son Makaleler</h2>
                        <p class="text-secondary">Üreme endokrinolojisi ve bilimindeki güncel yayınlar.</p>
                    </div>
                    <a href="/makaleler" class="hidden md:block text-primary font-semibold hover:underline">Bilimsel Arşivi Görüntüle</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {recentArticles.map(article => (
                        <article class="bg-surface-container-lowest rounded-2xl p-6 hover:shadow-lg transition-shadow">
                            <div class="aspect-video rounded-xl overflow-hidden mb-6">
                                <img 
                                    alt={article.data.imageAlt || article.data.title} 
                                    class="w-full h-full object-cover" 
                                    src={article.data.image} 
                                    width="512" height="512" 
                                    loading="lazy"
                                />
                            </div>
                            <span class="text-xs font-label font-bold text-tertiary uppercase tracking-tighter mb-3 block">{article.data.category}</span>
                            <a href={`/makaleler/${article.slug}`}>
                                <h3 class="text-xl font-headline text-on-surface mb-4 line-clamp-2 hover:text-primary transition-colors">
                                    {article.data.title}
                                </h3>
                            </a>
                            <p class="text-secondary text-sm mb-6 line-clamp-3 leading-relaxed">
                                {article.data.description}
                            </p>
                            <div class="flex items-center gap-3 pt-6 border-t border-surface-variant">
                                <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center overflow-hidden">
                                    <img src="/images/senai-aksoy.jpg" alt={article.data.author} class="w-full h-full object-cover" width="100" height="100" />
                                </div>
                                <span class="text-xs text-on-surface-variant font-medium uppercase tracking-widest">{article.data.author}</span>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <!-- Medical Reviewer Section -->
        <section class="py-20 bg-surface-container-low">
            <div class="max-w-3xl mx-auto px-8 text-center">
                <div class="mb-8">
                    <img alt="portre" class="w-24 h-24 rounded-full mx-auto object-cover brightness-110 mb-6 border-4 border-surface-container-lowest shadow-sm" src="/images/senai-aksoy.jpg" width="512" height="512" loading="lazy"/>
                    <h3 class="text-xl font-headline text-on-surface">Doç. Dr. Senai Aksoy</h3>
                    <p class="text-primary font-label uppercase tracking-widest text-xs font-bold mt-1">Tıbbi İnceleme & Bilimsel Onay</p>
                </div>
                <p class="text-secondary italic text-sm leading-relaxed">
                    tupbebek.com platformundaki bilimsel doğruluk ve klinik dürüstlük, titiz bir editoryal denetimle sürdürülmektedir. Tüm makaleler, üreme tıbbındaki en son yayınlanmış konsensüs ile uyumu sağlamak amacıyla uzman tıp doktorları tarafından incelemeye tabidir.
                </p>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
