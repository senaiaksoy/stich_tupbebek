    <script define:vars={{ heroSearchData }}>
      const input = document.getElementById('hero-search-input');
      const btn = document.getElementById('hero-search-btn');
      const wrapper = document.getElementById('hero-search-wrapper');
      const resultsBox = document.getElementById('hero-search-results');
      const resultsList = document.getElementById('hero-results-list');
      const noResults = document.getElementById('hero-no-results');

      let debounceTimer;

      function performSearch() {
        const query = input.value.trim().toLowerCase();
        if (!query) {
          resultsBox.classList.add('hidden');
          return;
        }

        const results = heroSearchData.filter(item => {
          return item.title.toLowerCase().includes(query) ||
                 item.description.toLowerCase().includes(query) ||
                 item.category.toLowerCase().includes(query);
        }).slice(0, 8);

        resultsBox.classList.remove('hidden');

        if (results.length === 0) {
          resultsList.innerHTML = '';
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
          resultsList.innerHTML = results.map(r => {
            const highlighted = r.title.replace(
              new RegExp(`(${query})`, 'gi'),
              '<mark class="bg-primary/20 text-primary font-semibold rounded px-0.5">$1</mark>'
            );
            return `
              <li>
                <a href="${r.url}" class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition-colors">
                  <span class="material-symbols-outlined text-primary/60 text-xl flex-shrink-0">article</span>
                  <div class="flex-1 min-w-0">
                    <h4 class="text-sm font-semibold text-on-surface line-clamp-1">${highlighted}</h4>
                    ${r.description ? `<p class="text-xs text-slate-500 line-clamp-1 mt-0.5">${r.description}</p>` : ''}
                  </div>
                  <span class="text-[10px] uppercase tracking-wider text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full flex-shrink-0">${r.category}</span>
                </a>
              </li>`;
          }).join('');
        }
      }

      // Search on input with debounce
      input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(performSearch, 200);
      });

      // KEŞFET button click
      btn.addEventListener('click', () => {
        performSearch();
      });

      // Enter key triggers search
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          performSearch();
        }
      });

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!wrapper.contains(e.target)) {
          resultsBox.classList.add('hidden');
        }
      });

      // Keyboard navigation in results
      input.addEventListener('keydown', (e) => {
        const links = resultsList.querySelectorAll('a');
        if (e.key === 'ArrowDown' && links.length > 0) {
          e.preventDefault();
          links[0].focus();
        }
      });

      resultsList.addEventListener('keydown', (e) => {
        const links = Array.from(resultsList.querySelectorAll('a'));
        const idx = links.indexOf(document.activeElement);
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          links[idx + 1]?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (idx === 0) input.focus();
          else links[idx - 1]?.focus();
        } else if (e.key === 'Escape') {
          resultsBox.classList.add('hidden');
          input.focus();
        }
      });
    </script>
</BaseLayout>
