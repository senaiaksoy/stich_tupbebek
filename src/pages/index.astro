---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KeyInfo from '../components/KeyInfo.astro';
import PatientJourney from '../components/PatientJourney.astro';
import RecentArticlesCarousel from '../components/RecentArticlesCarousel.astro';
import FAQHighlights from '../components/FAQHighlights.astro';

const allArticles = await getCollection('articles');
const recentArticles = allArticles.slice(0, 3);

// Prepare search data for hero search
const heroSearchData = allArticles.map(a => ({
    id: a.slug,
    title: a.data.title,
    description: a.data.description || '',
    url: `/makaleler/${a.slug}`,
    category: a.data.category || 'Makale'
}));
---

<BaseLayout title="tupbebek.com | Üreme Sağlığı Bilgisi">
    <Header />
    
    <main class="pt-24">
        <!-- Hero Section: Split Layout with Visual -->
        <section class="max-w-7xl mx-auto px-8 mb-16 relative">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center py-16 lg:py-24">
                <!-- Left: Content -->
                <div class="lg:col-span-7">
                    <span class="text-primary font-label uppercase tracking-[0.3em] text-xs font-bold mb-6 block">BAĞIMSIZ BİLİMSEL REHBER</span>
                    <h1 class="text-5xl lg:text-7xl font-headline text-on-surface leading-tight mb-8 max-w-2xl">
                        Bilimsel Derinlik, <br/><span class="italic text-primary">İnsani Hassasiyet</span>
                    </h1>

                    <!-- Mega Search Bar -->
                    <div class="w-full max-w-xl relative mb-10 group" id="hero-search-wrapper">
                        <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
                        <div class="relative bg-white shadow-2xl shadow-primary/5 rounded-[2rem] p-2 flex items-center border border-outline-variant/30 focus-within:border-primary transition-all">
                            <span class="material-symbols-outlined ml-6 text-slate-400">search</span>
                            <input
                                id="hero-search-input"
                                type="text"
                                placeholder="PCOS, Sperm Analizi, IVF..."
                                class="flex-1 bg-transparent border-none focus:ring-0 px-4 py-3 text-base text-on-surface placeholder:text-slate-400"
                                autocomplete="off"
                            />
                            <button id="hero-search-btn" class="bg-primary text-on-primary px-6 py-3 rounded-[1.5rem] font-bold hover:bg-primary-dim transition-all shadow-lg shadow-primary/20">
                                KEŞFET
                            </button>
                        </div>
                        <!-- Search Results Dropdown -->
                        <div id="hero-search-results" class="hidden absolute top-full left-0 right-0 mt-2 bg-white rounded-2xl shadow-2xl border border-outline-variant/20 overflow-hidden z-50 max-h-[400px] overflow-y-auto">
                            <ul id="hero-results-list" class="divide-y divide-slate-100"></ul>
                            <div id="hero-no-results" class="hidden p-6 text-center text-slate-500">
                                <span class="material-symbols-outlined text-3xl block mb-2 opacity-50">search_off</span>
                                <p class="text-sm font-medium">Sonuç bulunamadı</p>
                                <p class="text-xs mt-1 opacity-75">Farklı bir arama terimi deneyin</p>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Navigation Points -->
                    <div class="flex flex-wrap gap-4 mb-10">
                        <a href="/tani-sureci" class="group flex items-center gap-3 px-5 py-3 bg-surface-container rounded-2xl hover:bg-surface-container-high hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 border border-outline-variant/10">
                            <span class="w-10 h-10 bg-primary-container rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined icon-filled text-primary text-xl">clinical_notes</span>
                            </span>
                            <span class="font-bold text-sm">Tanı Süreci Nedir?</span>
                        </a>
                        <a href="/tedavi-yontemleri" class="group flex items-center gap-3 px-5 py-3 bg-surface-container rounded-2xl hover:bg-surface-container-high hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 border border-outline-variant/10">
                            <span class="w-10 h-10 bg-tertiary-container rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined icon-filled text-tertiary text-xl">biotech</span>
                            </span>
                            <span class="font-bold text-sm">Tedavi Seçeneklerimi Gör</span>
                        </a>
                        <a href="/makaleler" class="group flex items-center gap-3 px-5 py-3 bg-surface-container rounded-2xl hover:bg-surface-container-high hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 border border-outline-variant/10">
                            <span class="w-10 h-10 bg-secondary-container rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined icon-filled text-secondary text-xl">library_books</span>
                            </span>
                            <span class="font-bold text-sm">Bütün Makaleleri İncele</span>
                        </a>
                    </div>

                    <!-- Trust Badges Strip -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 border-y border-outline-variant/10">
                        <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                            <span class="text-xs font-bold uppercase tracking-widest text-accent">1996'dan Beri</span>
                            <p class="text-[10px] text-secondary">Sektörün Öncüsü</p>
                        </div>
                        <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                            <span class="text-xs font-bold uppercase tracking-widest text-accent">Kanıta Dayalı Tıp</span>
                            <p class="text-[10px] text-secondary">Bilimsel Literatür</p>
                        </div>
                        <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                            <span class="text-xs font-bold uppercase tracking-widest text-accent">Ticari Reklamsız</span>
                            <p class="text-[10px] text-secondary">Bağımsız Yayıncılık</p>
                        </div>
                        <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                            <span class="text-xs font-bold uppercase tracking-widest text-accent">Tıbbi Denetim</span>
                            <p class="text-[10px] text-secondary">Yayın Kurulu Onaylı</p>
                        </div>
                    </div>
                </div>

                <!-- Right: Hero Visual -->
                <div class="lg:col-span-5 relative hidden lg:block">
                    <div class="relative">
                        <!-- Main image -->
                        <div class="rounded-[2rem] overflow-hidden shadow-2xl shadow-primary/10 aspect-[4/5]">
                            <img
                                src="/images/home/hero.png"
                                alt="Modern üreme sağlığı laboratuvarı"
                                class="w-full h-full object-cover"
                                width="512" height="640"
                                loading="eager"
                                fetchpriority="high"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 via-transparent to-transparent"></div>
                        </div>
                        <!-- Floating stat card -->
                        <div class="absolute -bottom-6 -left-8 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-xl border border-outline-variant/10 max-w-[220px]">
                            <div class="flex items-center gap-3 mb-2">
                                <div class="w-10 h-10 bg-primary-container rounded-xl flex items-center justify-center">
                                    <span class="material-symbols-outlined icon-filled text-primary text-xl">shield_with_heart</span>
                                </div>
                                <span class="text-lg font-headline text-primary font-bold leading-tight">1996'dan Beri</span>
                            </div>
                            <p class="text-[10px] text-on-surface-variant font-label uppercase tracking-wider">İlk ve Tek Üreme Sağlığı Platformu</p>
                        </div>
                        <!-- Floating accent dot -->
                        <div class="absolute -top-4 -right-4 w-24 h-24 bg-accent-light/10 blur-2xl rounded-full"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Stats Section with Background Visual -->
        <section class="max-w-7xl mx-auto px-8 mb-24">
            <div class="relative rounded-[2.5rem] overflow-hidden">
                <!-- Background image -->
                <img src="/images/home/bento-1.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" width="1200" height="400" loading="lazy" aria-hidden="true" />
                <div class="absolute inset-0 bg-primary/85 backdrop-blur-sm"></div>
                <!-- Content -->
                <div class="relative z-10 p-12 lg:p-20 flex flex-wrap justify-around gap-12 text-center">
                    <div class="flex flex-col">
                        <span class="text-4xl lg:text-6xl font-headline text-white mb-2">1996</span>
                        <span class="text-xs font-bold uppercase tracking-widest text-white/70">Kuruluş Yılı</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-4xl lg:text-6xl font-headline text-white mb-2">100+</span>
                        <span class="text-xs font-bold uppercase tracking-widest text-white/70">Yayınlanmış Rehber</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-4xl lg:text-6xl font-headline text-white mb-2">%0</span>
                        <span class="text-xs font-bold uppercase tracking-widest text-white/70">Ticari Reklam İçeriği</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-4xl lg:text-6xl font-headline text-white mb-2">7/24</span>
                        <span class="text-xs font-bold uppercase tracking-widest text-white/70">Ücretsiz Erişim</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Critical Information Section -->
        <KeyInfo />

        <!-- Endometriozis & Adenomyozis Özel Bölüm -->
        <section class="py-24 bg-surface relative overflow-hidden">
            <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-error/5 blur-[150px] rounded-full -translate-y-1/2"></div>
            <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-tertiary/5 blur-[120px] rounded-full"></div>

            <div class="max-w-7xl mx-auto px-8 relative z-10">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

                    <!-- Sol: Resim -->
                    <div class="relative">
                        <div class="absolute -inset-4 bg-gradient-to-br from-error/10 via-tertiary/5 to-transparent rounded-[3rem] blur-2xl"></div>
                        <div class="relative rounded-[2rem] overflow-hidden shadow-2xl shadow-error/10 border border-white/50">
                            <img
                                src="/images/endometriozis-adenomyozis.png"
                                alt="Endometriozis ve Adenomyozis"
                                class="w-full h-auto object-cover"
                                width="800" height="800"
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/40 via-transparent to-transparent"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-6">
                                <span class="bg-white/90 backdrop-blur-sm text-error text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full">Özel Dosya</span>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ: İçerik -->
                    <div>
                        <span class="text-error font-label uppercase tracking-[0.3em] text-xs font-bold mb-4 block">KADIN SAĞLIĞI REHBERİ</span>
                        <h2 class="text-4xl lg:text-5xl font-headline text-on-surface mb-6 leading-tight">Endometriozis &<br/><span class="italic text-error">Adenomyozis</span></h2>

                        <p class="text-on-surface-variant leading-relaxed mb-4">
                            Üreme çağındaki kadınların yaklaşık <strong class="text-on-surface">%10-15</strong>'ini etkileyen endometriozis ve adenomyozis, infertilitenin en sık nedenlerinden ikisidir. Rahim iç tabakasının olmaması gereken yerlerde büyümesiyle karakterize bu iki hastalık; şiddetli ağrı, düzensiz kanama ve gebe kalamama gibi belirtilerle kendini gösterir.
                        </p>
                        <p class="text-on-surface-variant leading-relaxed mb-6">
                            Belirtilerin başlamasından doğru tanıya ulaşmaya kadar ortalama <strong class="text-on-surface">7-10 yıl</strong> geçmektedir. Erken tanı ve doğru tedavi yaklaşımıyla hem ağrı kontrolü hem de gebelik şansları önemli ölçüde artırılabilir. Rehberimizde hastalıkların evreleri, tanı yöntemleri, cerrahi ve medikal tedavi seçenekleri ile tüp bebek başarısına etkilerini detaylı olarak inceliyoruz.
                        </p>

                        <div class="flex flex-wrap gap-3 mb-8">
                            <span class="px-3 py-1.5 bg-error/10 text-error rounded-full text-xs font-semibold">Endometriozis</span>
                            <span class="px-3 py-1.5 bg-tertiary/10 text-tertiary rounded-full text-xs font-semibold">Adenomyozis</span>
                            <span class="px-3 py-1.5 bg-primary/10 text-primary rounded-full text-xs font-semibold">Karşılaştırma</span>
                            <span class="px-3 py-1.5 bg-secondary/10 text-secondary rounded-full text-xs font-semibold">Fertilite Etkisi</span>
                            <span class="px-3 py-1.5 bg-surface-container text-on-surface-variant rounded-full text-xs font-semibold">Tedavi Stratejileri</span>
                        </div>

                        <a href="/endometriozis-adenomyozis" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-2xl font-bold hover:shadow-xl hover:shadow-primary/20 transition-all hover:-translate-y-0.5">
                            Kapsamlı Rehberi İncele
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                    </div>

                </div>
            </div>
        </section>

        <!-- Patient Journey Map Section -->
        <PatientJourney />

        <!-- Bento Knowledge Grid -->
        <section class="bg-surface-container-low py-24 relative overflow-hidden">
            <!-- Subtle Background glow -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-tertiary/5 blur-[120px] rounded-full"></div>

            <div class="max-w-7xl mx-auto px-8 relative z-10">
                <div class="mb-16 text-center">
                    <span class="text-accent font-label uppercase tracking-[0.3em] text-xs font-bold mb-4 block">AKADEMİK REHBER</span>
                    <h2 class="text-4xl lg:text-5xl font-headline text-on-surface mb-6">Temel Eğitim Vitrini</h2>
                    <div class="h-0.5 w-24 bg-gradient-to-r from-transparent via-accent-light to-transparent mx-auto opacity-50"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 auto-rows-[320px]">
                    <!-- Large Feature: Journey to Source of Life -->
                    <a href="/hakkimizda" class="md:col-span-8 md:row-span-2 bg-white/40 backdrop-blur-md border border-white/20 rounded-[2.5rem] flex flex-col md:flex-row group cursor-pointer overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-primary/10 transition-all duration-1000 ease-in-out">
                        <!-- Left Content (60%) -->
                        <div class="p-10 lg:p-12 md:w-[60%] flex flex-col justify-between relative z-10 bg-white/40">
                            <div>
                                <span class="text-primary/60 font-label uppercase tracking-widest text-xs font-bold mb-6 block">Klinik Derinlik</span>
                                <h3 class="text-4xl lg:text-5xl font-headline text-on-surface mb-8 group-hover:text-accent transition-colors duration-700">Yaşamın Kaynağına <br/>Bilimsel Bir Yolculuk</h3>
                                <p class="text-secondary/90 max-w-md text-lg leading-relaxed font-light">
                                    İnsan fertilitesinin gizemli dünyasını, bilimin sınırlarını zorlayan araştırmalarla keşfedin. Yayın Kurulu'un otuz yılı aşkın klinik derinliğiyle şekillenen bu rehber, biyolojik engelleri aşmanın vizyoner yollarını sunuyor.
                                </p>
                            </div>
                            <div class="mt-12">
                                <span class="flex items-center text-primary font-bold group-hover:text-accent group-hover:gap-6 transition-all duration-700">
                                    KEŞFETMEYE BAŞLA <span class="material-symbols-outlined ml-3 scale-110">trending_flat</span>
                                </span>
                            </div>
                        </div>

                        <!-- Right Image Area (40%) -->
                        <div class="md:w-[40%] bg-primary relative flex items-center justify-center overflow-hidden">
                            <!-- Artistic Organic Frame -->
                            <div class="relative w-full h-full flex items-center justify-center p-8">
                                <div class="w-full h-full bg-white/5 backdrop-blur-sm rounded-[30%_70%_70%_30%_/_30%_30%_70%_70%] border border-white/10 overflow-hidden shadow-2xl relative group-hover:scale-105 transition-transform duration-1000 ease-in-out">
                                    <img 
                                        alt="yaşamın başlangıcını simgeleyen lüks safir mavisi ve altın moleküler yapılar içeren modern tıbbi illüstrasyon" 
                                        class="w-full h-full object-cover opacity-100 brightness-110 group-hover:scale-110 transition-transform duration-1000 ease-in-out" 
                                        src="/images/home/luxury-embryo.png" 
                                        width="512" height="512" 
                                        loading="lazy"
                                    />
                                    <!-- Inner Gold Glow -->
                                    <div class="absolute inset-0 bg-gradient-to-tr from-accent-light/20 to-transparent pointer-events-none"></div>
                                </div>
                                <!-- Outer Gold Accents -->
                                <div class="absolute top-10 right-10 w-20 h-20 bg-accent-light/10 blur-2xl rounded-full"></div>
                                <div class="absolute bottom-10 left-10 w-24 h-24 bg-primary-dim/20 blur-3xl rounded-full"></div>
                            </div>
                        </div>
                    </a>

                    <!-- Medium Feature: Futuristic Lab -->
                    <a href="/makaleler/laboratuvar-raporu-yorumlama" class="md:col-span-4 bg-surface-container-highest/50 backdrop-blur-sm rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-white/10 hover:border-accent-light/30 hover:shadow-xl transition-all duration-700 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-gradient-to-br from-accent-light/20 to-accent/10 rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:shadow-md group-hover:scale-110 transition-all duration-300">
                                <span class="material-symbols-outlined icon-filled text-accent" style="font-size: 28px;">biotech</span>
                            </div>
                            <h3 class="text-2xl font-headline text-on-surface mb-5 group-hover:text-primary transition-colors">Fütüristik Laboratuvar: <br/>Mikro-Mükemmeliyet</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                Yaşamın ilk anlarını optimize eden, yapay zeka destekli inkübasyon ve ultra-modern embriyo seleksiyon sistemleriyle geleceği bugün inşa ediyoruz.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-accent opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all">arrow_right_alt</span>
                    </a>

                    <!-- Medium Feature: Male Infertility (NEW) -->
                    <a href="/sorunlar#erkek" class="md:col-span-4 relative rounded-[2rem] flex flex-col justify-between group cursor-pointer border border-blue-100 hover:border-primary/50 transition-all duration-1000 ease-in-out overflow-hidden">
                        <!-- Background image -->
                        <img src="/images/home/article-2.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-15 group-hover:opacity-25 group-hover:scale-105 transition-all duration-1000" aria-hidden="true" width="400" height="320" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-white via-white/90 to-blue-50/70"></div>
                        <div class="relative z-10 p-10 flex flex-col justify-between h-full">
                            <div>
                                <div class="w-14 h-14 bg-primary text-on-primary rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform duration-300">
                                    <span class="material-symbols-outlined icon-filled" style="font-size: 28px;">male</span>
                                </div>
                                <h3 class="text-2xl font-headline text-on-surface mb-5">Erkek İnfertilitesi: <br/>Gizli Faktörler</h3>
                                <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                    Sperm sağlığı ve genetiği, bir ailenin oluşumunda eşit öneme sahiptir. Modern tanısal yaklaşımları keşfedin.
                                </p>
                            </div>
                            <span class="material-symbols-outlined self-end text-primary opacity-40 group-hover:opacity-100 transition-all">clinical_notes</span>
                        </div>
                    </a>

                    <!-- Medium Feature: Data Transparency (Repositioned) -->
                    <a href="/makaleler/basari-oranlari" class="md:col-span-8 relative rounded-[2.5rem] overflow-hidden group cursor-pointer shadow-lg hover:shadow-primary/30 transition-all duration-1000 ease-in-out border border-primary-dim/20">
                        <!-- Background image -->
                        <img src="/images/home/integrity.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-105 transition-transform duration-1000" aria-hidden="true" width="800" height="320" loading="lazy" />
                        <div class="absolute inset-0 bg-primary/90"></div>
                        <div class="relative z-10 p-10 flex flex-col md:flex-row gap-12 text-on-primary">
                            <div class="md:w-1/2 flex flex-col justify-between h-full">
                                <div>
                                    <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center mb-8 backdrop-blur-md group-hover:bg-white/20 group-hover:scale-110 transition-all duration-300">
                                        <span class="material-symbols-outlined icon-filled text-white/90" style="font-size: 28px;">analytics</span>
                                    </div>
                                    <h3 class="text-3xl font-headline mb-5">Veri Şeffaflığı ve <br/>Başarı Analizi</h3>
                                    <p class="text-on-primary/80 text-sm leading-relaxed font-light">
                                        Veriye dayalı şeffaflık vizyonumuzla, kişiselleştirilmiş protokollerin dünya çapındaki (SART data yaklaşımı) başarısını yaşa göre analiz edin.
                                    </p>
                                </div>
                                <span class="material-symbols-outlined self-end text-white/50 group-hover:text-accent/100 group-hover:translate-x-2 transition-all">north_east</span>
                            </div>
                            <div class="md:w-1/2 bg-white/5 backdrop-blur-md rounded-2xl p-6 flex flex-col justify-center border border-white/10">
                                <h4 class="text-xs font-bold uppercase tracking-widest mb-4 opacity-70 italic text-white/80">Yaşa Göre Başarı Oranları (IVF)</h4>
                                <div class="space-y-4">
                                    <div class="flex justify-between items-center border-b border-white/10 pb-2">
                                        <span class="text-sm">35 Yaş Altı</span>
                                        <span class="text-xl font-bold text-accent">~55%</span>
                                    </div>
                                    <div class="flex justify-between items-center border-b border-white/10 pb-2">
                                        <span class="text-sm">35 - 37 Yaş</span>
                                        <span class="text-xl font-bold text-accent">~45%</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm">38 - 40 Yaş</span>
                                        <span class="text-xl font-bold text-accent">~35%</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </section>

        <!-- Dynamic Content Showcase -->
        <RecentArticlesCarousel />
        
        <!-- FAQ Section -->
        <FAQHighlights />

        <!-- Medical Reviewer Section: Editorial Style -->
        <section class="py-24 bg-surface-container-low border-t border-outline-variant/10">
            <div class="max-w-6xl mx-auto px-8">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 bg-surface-container-lowest rounded-[2rem] overflow-hidden shadow-xl border border-outline-variant/10">
                    <!-- Large Photo -->
                    <div class="lg:col-span-5 relative">
                        <img
                            alt="Yayın Kurulu"
