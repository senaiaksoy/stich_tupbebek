---
import { getPublishedArticles } from '../utils/articles';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/home/HeroSection.astro';
import QuickGuideCards from '../components/home/QuickGuideCards.astro';
import SituationSelector from '../components/home/SituationSelector.astro';
import PatientJourney from '../components/PatientJourney.astro';
import RecentArticlesCarousel from '../components/RecentArticlesCarousel.astro';
import FAQHighlights from '../components/FAQHighlights.astro';

const recentArticles = (await getPublishedArticles()).slice(0, 3);
---

<BaseLayout title="tupbebek.com | Üreme Sağlığı Bilgisi" description="Tüp bebek (IVF), infertilite nedenleri, tedavi yöntemleri, başarı oranları ve üreme sağlığı hakkında bilimsel ve güncel bilgiler. Yayın kurulu denetiminde.">
    <Header hideSearch={true} />

    <!-- Trust Bar — Editoryal Güven Şeridi -->
    <div class="bg-gray-50 border-b border-gray-200 pt-[72px]">
      <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-3 flex flex-wrap items-center justify-center gap-2 sm:gap-3">
        <span class="inline-flex items-center gap-1.5 bg-white border border-gray-200 rounded-full px-3.5 py-1.5 text-xs sm:text-sm text-gray-600">
          <span class="material-symbols-outlined text-primary-600 text-base">verified</span>
          <span class="font-semibold text-gray-800">Doç. Dr. Aksoy</span> editörlüğünde okuyorsunuz
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-gray-200 rounded-full px-3.5 py-1.5 text-xs sm:text-sm text-gray-600">
          <span class="material-symbols-outlined text-primary-600 text-base">groups</span>
          Yayın kurulu tarafından denetlenir
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-gray-200 rounded-full px-3.5 py-1.5 text-xs sm:text-sm text-gray-600">
          <span class="material-symbols-outlined text-primary-600 text-base">update</span>
          Her içerik güncel araştırmalarla güncellenir
        </span>
        <span class="inline-flex items-center gap-1.5 bg-white border border-gray-200 rounded-full px-3.5 py-1.5 text-xs sm:text-sm text-gray-600">
          <span class="material-symbols-outlined text-primary-600 text-base">block</span>
          Burada reklam görmeyeceksiniz
        </span>
      </div>
    </div>

    <main id="main-content" tabindex="-1">

        <!-- Editorial Hero — Featured Article -->
        <HeroSection />

        <!-- Quick Guide Cards -->
        <QuickGuideCards />

        <!-- Durumunuzu Seçin — Dinamik Yönlendirme -->
        <SituationSelector />

        <!-- Tedavi Sürecine Genel Bakış — 3 Kolon Bilgi Kartları -->
        <section class="py-16 lg:py-20 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="mb-10 lg:mb-14">
                    <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-3">Tedavi Sürecine Genel Bakış</h2>
                    <p class="text-base text-gray-500 max-w-xl">Tüp bebek tedavisi hakkında merak edilen temel bilgiler.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
                    <!-- Kimler İçin -->
                    <div class="bg-white rounded-xl p-6 lg:p-8 border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center mb-5">
                            <span class="material-symbols-outlined text-primary-600 text-xl">groups</span>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-4">Kimler İçin Uygundur?</h3>
                        <ul class="space-y-3 text-sm text-gray-600">
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>En az 1 yıldır düzenli ilişkiye rağmen gebelik sağlayamayan çiftler</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Tüpler tıkalı olan kadınlar</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Ciddi erkek faktörü infertilitesi</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Yumurtlama bozukluğu (PCOS vb.)</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Azalmış yumurtalık rezervi</span>
                            </li>
                        </ul>
                        <a href="/kadin-infertilitesi" class="mt-5 inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold hover:gap-2.5 transition-all duration-300">
                            Detaylı Bilgi <span class="material-symbols-outlined text-base">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Maliyet -->
                    <div class="bg-white rounded-xl p-6 lg:p-8 border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center mb-5">
                            <span class="material-symbols-outlined text-primary-600 text-xl">payments</span>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-4">Maliyet ve Kapsam</h3>
                        <ul class="space-y-3 text-sm text-gray-600">
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>İlk denemede %50'ye varan devlet desteği</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>SGK kapsamında 3 deneme hakkı</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>İlaç maliyetlerinin büyük kısmı karşılanır</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Yaşa göre değişen ek tetkik ücretleri</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">check_circle</span>
                                <span>Tamamlayıcı sağlık sigortası seçenekleri</span>
                            </li>
                        </ul>
                        <a href="/sss" class="mt-5 inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold hover:gap-2.5 transition-all duration-300">
                            SSS'yi İncele <span class="material-symbols-outlined text-base">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Süreç -->
                    <div class="bg-white rounded-xl p-6 lg:p-8 border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center mb-5">
                            <span class="material-symbols-outlined text-primary-600 text-xl">event_repeat</span>
                        </div>
                        <h3 class="text-lg font-bold text-gray-900 mb-4">Süreç ve Zaman Çizelgesi</h3>
                        <ul class="space-y-3 text-sm text-gray-600">
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">schedule</span>
                                <span>Ön tetkikler: ~1 adet döngü</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">schedule</span>
                                <span>Yumurtalık uyarımı: 10-14 gün</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">schedule</span>
                                <span>Laboratuvar (ICSI/IVF): 3-5 gün</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">schedule</span>
                                <span>Embriyo transferi: 5. veya 6. gün</span>
                            </li>
                            <li class="flex items-start gap-2.5">
                                <span class="material-symbols-outlined text-primary-500 text-sm mt-0.5 shrink-0">schedule</span>
                                <span>Toplam süreç: ~4-6 hafta</span>
                            </li>
                        </ul>
                        <a href="/tedavi-yontemleri" class="mt-5 inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold hover:gap-2.5 transition-all duration-300">
                            Süreci İncele <span class="material-symbols-outlined text-base">arrow_forward</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>


        <!-- Patient Journey Map -->
        <PatientJourney />


        <!-- Güncel Makaleler -->
        <RecentArticlesCarousel />


        <!-- FAQ Section -->
        <FAQHighlights />


        <!-- Hızlı Erişim -->
        <section class="py-16 lg:py-20 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="mb-10 lg:mb-14">
                    <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-3">Hızlı Erişim</h2>
                    <p class="text-base text-gray-500">Sık kullanılan araçlar ve kaynaklar.</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 lg:gap-6">
                    <a href="/tbbi-sozluk" class="group flex items-center gap-4 p-5 bg-white rounded-xl border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-100 transition-colors">
                            <span class="material-symbols-outlined text-primary-600 text-xl">dictionary</span>
                        </div>
                        <div>
                            <h3 class="text-base font-bold text-gray-900 group-hover:text-primary-700 transition-colors">Tıbbi Sözlük</h3>
                            <p class="text-xs text-gray-500 mt-0.5">AMH, FSH, ICSI gibi terimlerin açıklamaları</p>
                        </div>
                    </a>

                    <a href="/sss" class="group flex items-center gap-4 p-5 bg-white rounded-xl border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-100 transition-colors">
                            <span class="material-symbols-outlined text-primary-600 text-xl">help</span>
                        </div>
                        <div>
                            <h3 class="text-base font-bold text-gray-900 group-hover:text-primary-700 transition-colors">Sık Sorulan Sorular</h3>
                            <p class="text-xs text-gray-500 mt-0.5">En çok merak edilen sorular ve yanıtları</p>
                        </div>
                    </a>

                    <a href="/ilac-rehberi" class="group flex items-center gap-4 p-5 bg-white rounded-xl border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                        <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-100 transition-colors">
                            <span class="material-symbols-outlined text-primary-600 text-xl">medication</span>
                        </div>
                        <div>
                            <h3 class="text-base font-bold text-gray-900 group-hover:text-primary-700 transition-colors">İlaç Rehberi</h3>
                            <p class="text-xs text-gray-500 mt-0.5">Gonadotropinler, GnRH analogları ve daha fazlası</p>
                        </div>
                    </a>
                </div>
            </div>
        </section>


        <!-- İstatistikler -->
        <section class="py-16 lg:py-20">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="bg-primary-50 rounded-2xl p-10 lg:p-16 border border-primary-100">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                        <div>
                            <span class="text-3xl lg:text-5xl font-headline font-bold text-primary-600">30+</span>
                            <p class="text-xs font-semibold uppercase tracking-wider text-primary-800/60 mt-2">Klinik Tecrübe</p>
                        </div>
                        <div>
                            <span class="text-3xl lg:text-5xl font-headline font-bold text-primary-600">100+</span>
                            <p class="text-xs font-semibold uppercase tracking-wider text-primary-800/60 mt-2">Bilimsel Makale</p>
                        </div>
                        <div>
                            <span class="text-3xl lg:text-5xl font-headline font-bold text-primary-600">ESHRE</span>
                            <p class="text-xs font-semibold uppercase tracking-wider text-primary-800/60 mt-2">Uluslararası Standart</p>
                        </div>
                        <div>
                            <span class="text-3xl lg:text-5xl font-headline font-bold text-primary-600">0</span>
                            <p class="text-xs font-semibold uppercase tracking-wider text-primary-800/60 mt-2">Ticari Reklam</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <!-- Editöryal Bağımsızlık -->
        <section class="py-16 lg:py-20 bg-gray-50 border-t border-gray-100">
            <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row items-start gap-8 lg:gap-12">
                    <div class="md:w-1/4 shrink-0">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                        <h3 class="text-lg font-bold text-gray-900 mt-2">Yayın Kurulu</h3>
                        <p class="text-xs font-semibold uppercase tracking-wide text-primary-600 mt-1">Tıbbi İnceleme & Onay</p>
                    </div>
                    <div class="md:w-3/4">
                        <h2 class="text-2xl lg:text-3xl font-headline font-bold text-gray-900 mb-4 leading-tight">Yanıltıcı Bilgiden Arındırılmış Bilimsel Kaynak</h2>
                        <p class="text-gray-500 text-sm leading-relaxed mb-5">
                            tupbebek.com'daki tüm içerikler, ticari kaygılardan arındırılmış, 30+ yıllık klinik tecrübe ve güncel dünya tıbbı literatürü (ESHRE, ASRM, WHO) ışığında hazırlanır. Bağımsızlığımız, dürüst bilgiye ulaşma hakkınızın teminatıdır.
                        </p>
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1 bg-white border border-gray-200 rounded-md text-xs font-semibold text-gray-500">Kanıta Dayalı Tıp</span>
                            <span class="px-3 py-1 bg-white border border-gray-200 rounded-md text-xs font-semibold text-gray-500">Reklamsız Yayın</span>
                            <span class="px-3 py-1 bg-white border border-gray-200 rounded-md text-xs font-semibold text-gray-500">Hakem Denetimi</span>
                        </div>
                        <a href="/editoryal-politika" class="mt-5 inline-flex items-center gap-1.5 text-primary-600 text-sm font-semibold hover:gap-2.5 transition-all duration-300">
                            Editöryal Politika <span class="material-symbols-outlined text-base">arrow_forward</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>


        <!-- Tıbbi Uyarı -->
        <section class="w-full bg-amber-50 border-y border-amber-200 py-6">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 flex items-start gap-3">
                <span class="material-symbols-outlined text-amber-500 shrink-0 mt-0.5 text-xl">warning</span>
                <div>
                    <h4 class="text-xs font-bold uppercase tracking-wide text-amber-800 mb-1.5">Tıbbi Uyarı</h4>
                    <p class="text-sm leading-relaxed text-amber-900">
                        Bu sitedeki tüm bilgiler eğitim ve genel bilgilendirme amaçlıdır.
                        Tıbbi tanı, tedavi veya kişisel sağlık önerisi yerine geçmez.
                        Sağlık durumunuzla ilgili kararlarınız için hekiminize danışınız.
                    </p>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
