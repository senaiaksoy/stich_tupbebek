---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PatientJourney from '../components/PatientJourney.astro';
import RecentArticlesCarousel from '../components/RecentArticlesCarousel.astro';
import FAQHighlights from '../components/FAQHighlights.astro';

const recentArticles = (await getCollection('articles')).slice(0, 3);
---

<BaseLayout title="tupbebek.com | Üreme Sağlığı Bilgisi" description="Tüp bebek (IVF), infertilite nedenleri, tedavi yöntemleri, başarı oranları ve üreme sağlığı hakkında bilimsel ve güncel bilgiler. Doç. Dr. Senai Aksoy editöryal denetiminde.">
    <Header />
    
    <main class="pt-24">

        <!-- Hero Section: Intent-Based & Informative -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 mb-16 relative">
            <div class="flex flex-col items-center text-center py-20 lg:py-28">
                <span class="text-primary font-label uppercase tracking-[0.3em] text-xs font-bold mb-6 block animate-fade-in">BAĞIMSIZ BİLİMSEL REHBER</span>
                <h1 class="text-hero font-headline text-on-surface leading-tight mb-12 max-w-4xl">
                    Bilimsel Derinlik, <br/><span class="italic text-primary">İnsani Hassasiyet</span>
                </h1>
                
                <!-- Mega Search Bar (FertilityIQ Style) -->
                <div class="w-full max-w-3xl relative mb-12 group">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
                    <div class="relative bg-white shadow-2xl shadow-primary/5 rounded-[2rem] p-2 flex items-center border border-outline-variant/30 focus-within:border-primary transition-all">
                        <span class="material-symbols-outlined ml-6 text-slate-400">search</span>
                        <input 
                            type="text" 
                            placeholder="Ne arıyorsunuz? Örn: PCOS, Sperm Analizi, IVF Başarı Oranları" 
                            class="flex-1 bg-transparent border-none focus:ring-0 px-6 py-4 text-lg text-on-surface placeholder:text-slate-400"
                        />
                        <button class="bg-primary text-on-primary px-8 py-4 rounded-[1.5rem] font-bold hover:bg-primary-dim transition-all shadow-lg shadow-primary/20">
                            KEŞFET
                        </button>
                    </div>
                </div>

                <!-- Quick Navigation Points -->
                <div class="flex flex-wrap justify-center gap-6 mb-16">
                    <a href="/kadin-infertilitesi" class="flex items-center gap-4 px-6 py-4 bg-surface-container rounded-2xl hover:bg-surface-container-high transition-all border border-outline-variant/10">
                        <span class="material-symbols-outlined text-primary">psychiatry</span>
                        <span class="font-bold text-sm">İnfertiliteyi Anla</span>
                    </a>
                    <a href="/rehberler" class="flex items-center gap-4 px-6 py-4 bg-surface-container rounded-2xl hover:bg-surface-container-high transition-all border border-outline-variant/10">
                        <span class="material-symbols-outlined text-primary">biotech</span>
                        <span class="font-bold text-sm">Tedavi Rehberine Git</span>
                    </a>
                    <a href="/makaleler" class="flex items-center gap-4 px-6 py-4 bg-surface-container rounded-2xl hover:bg-surface-container-high transition-all border border-outline-variant/10">
                        <span class="material-symbols-outlined text-primary">library_books</span>
                        <span class="font-bold text-sm">Tüm Makaleleri Keşfet</span>
                    </a>
                </div>

                <!-- Trust Badges Strip -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8 border-y border-outline-variant/10 w-full max-w-5xl">
                    <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                        <span class="text-xs font-bold uppercase tracking-widest text-[#C5A059]">1996'dan Beri</span>
                        <p class="text-[10px] text-secondary">Sektörün Öncüsü</p>
                    </div>
                    <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                        <span class="text-xs font-bold uppercase tracking-widest text-[#C5A059]">Kanıta Dayalı Tıp</span>
                        <p class="text-[10px] text-secondary">Bilimsel Literatür</p>
                    </div>
                    <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                        <span class="text-xs font-bold uppercase tracking-widest text-[#C5A059]">Ticari Reklamsız</span>
                        <p class="text-[10px] text-secondary">Bağımsız Yayıncılık</p>
                    </div>
                    <div class="flex flex-col items-center gap-1 opacity-70 hover:opacity-100 transition-opacity">
                        <span class="text-xs font-bold uppercase tracking-widest text-[#C5A059]">Tıbbi Denetim</span>
                        <p class="text-[10px] text-secondary">Dr. Senai Aksoy Onaylı</p>
                    </div>
                </div>
            </div>
        </section>


        <!-- Key Information: Decision-Making Section -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <div class="text-center mb-12">
                <span class="text-[#C5A059] font-label uppercase tracking-ultra text-xs font-bold mb-4 block">ANA BİLGİLER</span>
                <h2 class="text-3xl lg:text-4xl font-headline text-on-surface leading-snug">Tedavi Sürecine Genel Bakış</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Kimler İçin -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-outline-variant/10 hover:shadow-lg transition-shadow">
                    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-primary" style="font-size: 32px;">groups</span>
                    </div>
                    <h3 class="text-xl font-headline text-on-surface mb-4">Kimler İçin Uygundur?</h3>
                    <ul class="space-y-4 text-sm text-on-surface-variant">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>En az 1 yıldır düzenli ilişkiye rağmen gebelik sağlayamayan çiftler</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Tüpler tıkalı olan ve doğal yolla gebelik şansı olmayan kadınlar</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Ciddi erkek faktörü infertilitesi (düşük sperm sayısı / hareketliliği)</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Yumurtlama bozukluğu (PCOS vb.) olan hastalar</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Yumurtalık rezervi azalmış – yaşa bağlı üreme zorluğu yaşayanlar</span>
                        </li>
                    </ul>
                    <a href="/kadin-infertilitesi" class="mt-6 inline-flex items-center gap-2 text-primary text-sm font-bold hover:underline">
                        Detaylı Bilgi <span class="material-symbols-outlined text-sm">arrow_right_alt</span>
                    </a>
                </div>

                <!-- Maliyet -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-outline-variant/10 hover:shadow-lg transition-shadow">
                    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-primary" style="font-size: 32px;">payments</span>
                    </div>
                    <h3 class="text-xl font-headline text-on-surface mb-4">Maliyet ve Kapsam</h3>
                    <ul class="space-y-4 text-sm text-on-surface-variant">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Sağlık Bakanlığı destek programı ile ilk denemede %50'ye varan devlet desteği</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>SGK kapsamında 3 deneme (çift başı, tüm yurttaşlar için)</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>İlaç maliyetlerinin önemli kısmı devlet tarafından karşılanır</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Yaş ve sağlık durumuna göre değişen ek tetkik ücretleri olabilir</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                            <span>Özel sigorta / tamamlayıcı sağlık kapsamı kullanan merkezler mevcuttur</span>
                        </li>
                    </ul>
                    <a href="/sss" class="mt-6 inline-flex items-center gap-2 text-primary text-sm font-bold hover:underline">
                        SSS'yi Keşfet <span class="material-symbols-outlined text-sm">arrow_right_alt</span>
                    </a>
                </div>

                <!-- Süreç -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-outline-variant/10 hover:shadow-lg transition-shadow">
                    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-primary" style="font-size: 32px;">event_repeat</span>
                    </div>
                    <h3 class="text-xl font-headline text-on-surface mb-4">Süreç ve Zaman Çizelgesi</h3>
                    <ul class="space-y-4 text-sm text-on-surface-variant">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">schedule</span>
                            <span>İlk değerlendirme ve ön tetkikler: ~1 adet döngü</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">schedule</span>
                            <span>Yumurtalık uyarımı ve takip: 10 – 14 gün</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">schedule</span>
                            <span>Yumurta toplama ve laboratuvar (ICSI/IVF): 3 – 5 gün</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">schedule</span>
                            <span>Embriyo transferi: 5. veya 6. gün (blastokist aşaması)</span>
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-sm mt-0.5">schedule</span>
                            <span>Toplam süreç: ilk görüşmeden gebelik_testine ~4 – 6 hafta</span>
                        </li>
                    </ul>
                    <a href="/tedavi-yontemleri" class="mt-6 inline-flex items-center gap-2 text-primary text-sm font-bold hover:underline">
                        Süreci Detaylı İncele <span class="material-symbols-outlined text-sm">arrow_right_alt</span>
                    </a>
                </div>
            </div>
        </section>


        <!-- Bento Knowledge Grid -->
        <section class="bg-surface-container-low py-24 relative overflow-hidden">
            <!-- Subtle Background glow -->
            <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-tertiary/5 blur-[120px] rounded-full"></div>

            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 relative z-10">
                <div class="mb-16 text-center">
                    <span class="text-[#C5A059] font-label uppercase tracking-ultra text-xs font-bold mb-4 block">AKADEMİK REHBER</span>
                    <h2 class="text-3xl lg:text-4xl font-headline text-on-surface leading-snug mb-6">Temel Eğitim Vitrini</h2>
                    <div class="h-0.5 w-24 bg-gradient-to-r from-transparent via-[#C5A059] to-transparent mx-auto opacity-50"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 auto-rows-[320px]">
                    <!-- Large Feature: Woman Infertility (8 cols, row-span-2) -->
                    <a href="/kadin-infertilitesi" class="md:col-span-8 md:row-span-2 bg-white/40 backdrop-blur-md border border-white/20 rounded-[2.5rem] flex flex-col md:flex-row group cursor-pointer overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-primary/10 transition-all duration-1000 ease-in-out">
                        <!-- Left Content (60%) -->
                        <div class="p-10 lg:p-12 md:w-[60%] flex flex-col justify-between relative z-10 bg-white/40">
                            <div>
                                <span class="text-primary/60 font-label uppercase tracking-widest text-xs font-bold mb-6 block">Klinik Derinlik</span>
                                <h3 class="text-2xl lg:text-3xl font-headline text-on-surface mb-8 group-hover:text-[#C5A059] transition-colors duration-700 leading-tight">Kadın İnfertilitesi: <br/>Bilimsel Derinlik</h3>
                                <p class="text-secondary/90 max-w-md text-lg leading-relaxed font-light">
                                    Doç. Dr. Senai Aksoy'un 30+ yıllık klinik tecrübesiyle şekillenen bu rehber, kadın infertilitesinin nedenlerini, tanı süreçlerini ve tedavi yollarını bilimsel açıdan aydınlatır.
                                </p>
                            </div>
                            <div class="mt-12">
                                <span class="flex items-center text-primary font-bold group-hover:text-[#C5A059] group-hover:gap-6 transition-all duration-700">
                                    İNFERTİLİTEYİ ANLA <span class="material-symbols-outlined ml-3 scale-110">trending_flat</span>
                                </span>
                            </div>
                        </div>

                        <!-- Right Image Area (40%) -->
                        <div class="md:w-[40%] bg-primary relative flex items-center justify-center overflow-hidden">
                            <!-- Artistic Organic Frame -->
                            <div class="relative w-full h-full flex items-center justify-center p-8">
                                <div class="w-full h-full bg-white/5 backdrop-blur-sm rounded-[30%_70%_70%_30%_/_30%_30%_70%_70%] border border-white/10 overflow-hidden shadow-2xl relative group-hover:scale-105 transition-transform duration-1000 ease-in-out">
                                    <img
                                        alt="kadın infertilitesi ve üreme sağlığını simgeleyen modern tıbbi illüstrasyon"
                                        class="w-full h-full object-cover opacity-100 brightness-110 group-hover:scale-110 transition-transform duration-1000 ease-in-out"
                                        src="/images/home/luxury-embryo.webp"
                                        width="512" height="512"
                                        loading="lazy"
                                    />
                                    <!-- Inner Gold Glow -->
                                    <div class="absolute inset-0 bg-gradient-to-tr from-[#C5A059]/20 to-transparent pointer-events-none"></div>
                                </div>
                                <!-- Outer Gold Accents -->
                                <div class="absolute top-10 right-10 w-20 h-20 bg-[#C5A059]/10 blur-2xl rounded-full"></div>
                                <div class="absolute bottom-10 left-10 w-24 h-24 bg-primary-dim/20 blur-3xl rounded-full"></div>
                            </div>
                        </div>
                    </a>

                    <!-- Medium Feature: Lab Technology (4 cols) -->
                    <a href="/makaleler/laboratuvar-raporu-yorumlama" class="md:col-span-4 bg-surface-container-highest/50 backdrop-blur-sm rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-white/10 hover:border-[#C5A059]/30 hover:shadow-xl transition-all duration-700 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:shadow-md transition-all">
                                <span class="material-symbols-outlined text-[#C5A059]" style="font-size: 32px;">biotech</span>
                            </div>
                            <h3 class="text-xl lg:text-2xl font-headline text-on-surface mb-6 group-hover:text-primary transition-colors leading-snug">Fütüristik Laboratuvar: <br/>Mikro-Mükemmeliyet</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                Yaşamın ilk anlarını optimize eden, yapay zeka destekli inkübasyon ve ultra-modern embriyo seleksiyon sistemleriyle geleceği bugün inşa ediyoruz.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-[#C5A059] opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all">arrow_right_alt</span>
                    </a>

                    <!-- Medium Feature: Success Rates (4 cols) -->
                    <a href="/basari-oranlari" class="md:col-span-4 bg-surface-container-highest/50 backdrop-blur-sm rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-white/10 hover:border-[#C5A059]/30 hover:shadow-xl transition-all duration-700 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:shadow-md transition-all">
                                <span class="material-symbols-outlined text-[#C5A059]" style="font-size: 32px;">monitoring</span>
                            </div>
                            <h3 class="text-xl lg:text-2xl font-headline text-on-surface mb-6 group-hover:text-primary transition-colors leading-snug">Başarı Oranları: <br/>Veri Şeffaflığı</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                IVF ve diğer tedavi yöntemlerinde yaşa göre başarı oranları. Veriye dayalı şeffaflık vizyonumuzla kişiselleştirilmiş protokolleri analiz edin.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-[#C5A059] opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all">north_east</span>
                    </a>

                    <!-- NEW: Erkek İnfertilitesi (6 cols) -->
                    <a href="/erkek-infertilitesi" class="md:col-span-6 bg-blue-50/50 backdrop-blur-md rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-blue-100 hover:border-primary/50 transition-all duration-1000 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-primary text-on-primary rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-primary/20">
                                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">male</span>
                            </div>
                            <h3 class="text-xl lg:text-2xl font-headline text-on-surface mb-6 leading-snug">Erkek İnfertilitesi: <br/>Gizli Faktörler</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                Sperm sağlığı ve genetiği, bir ailenin oluşumunda eşit öneme sahiptir. Azospermi, varikosel ve hormonal dengesizlikler hakkında bilgi edinin.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-primary opacity-40 group-hover:opacity-100 transition-all">clinical_notes</span>
                    </a>

                    <!-- NEW: Duygusal Destek (6 cols) -->
                    <a href="/duygusal-destek" class="md:col-span-6 bg-purple-50/50 backdrop-blur-md rounded-[2rem] p-10 flex flex-col justify-between group cursor-pointer border border-purple-100 hover:border-purple-400 transition-all duration-1000 ease-in-out">
                        <div>
                            <div class="w-14 h-14 bg-purple-200 rounded-2xl flex items-center justify-center mb-8 shadow-sm group-hover:shadow-md transition-all">
                                <span class="material-symbols-outlined text-purple-600" style="font-size: 32px;">self_improvement</span>
                            </div>
                            <h3 class="text-xl lg:text-2xl font-headline text-on-surface mb-6 group-hover:text-purple-700 transition-colors leading-snug">Duygusal Destek: <br/>Birlikte Güçlüyüz</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed font-light">
                                İnfertilite süreci psikolojik olarak da yönetilmelidir. Stres azaltma, depresyon baş etme stratejileri ve çift olarak güçlenme rehberi.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-purple-400 opacity-40 group-hover:opacity-100 group-hover:translate-x-1 transition-all">psychiatry</span>
                    </a>
                </div>
            </div>
        </section>


        <!-- Patient Journey Map Section -->
        <PatientJourney />


        <!-- Dynamic Content Showcase -->
        <RecentArticlesCarousel />

        
        <!-- FAQ Section -->
        <FAQHighlights />


        <!-- Quick Access Section -->
        <section class="py-20 bg-surface">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="text-center mb-12">
                    <span class="text-[#C5A059] font-label uppercase tracking-ultra text-xs font-bold mb-4 block">KOLAY ERİŞİM</span>
                    <h2 class="text-3xl lg:text-4xl font-headline text-on-surface leading-snug">Hızlı Erişim</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <a href="/tbbi-sozluk" class="flex flex-col items-center p-10 bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-outline-variant/10 group">
                        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
                            <span class="material-symbols-outlined text-primary text-4xl">dictionary</span>
                        </div>
                        <h3 class="text-lg font-headline text-on-surface mb-2 group-hover:text-primary transition-colors">Tıbbi Sözlük</h3>
                        <p class="text-xs text-secondary text-center">AMH, FSH, ICSI gibi terimlerin açıklamaları</p>
                    </a>

                    <a href="/sss" class="flex flex-col items-center p-10 bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-outline-variant/10 group">
                        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
                            <span class="material-symbols-outlined text-primary text-4xl">help</span>
                        </div>
                        <h3 class="text-lg font-headline text-on-surface mb-2 group-hover:text-primary transition-colors">Sık Sorulan Sorular</h3>
                        <p class="text-xs text-secondary text-center">En çok merak edilen sorular ve yanıtları</p>
                    </a>

                    <a href="/ilac-rehberi" class="flex flex-col items-center p-10 bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 border border-outline-variant/10 group">
                        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
                            <span class="material-symbols-outlined text-primary text-4xl">medication</span>
                        </div>
                        <h3 class="text-lg font-headline text-on-surface mb-2 group-hover:text-primary transition-colors">İlaç Rehberi</h3>
                        <p class="text-xs text-secondary text-center">Gonadotropinler, GnRH analogları ve daha fazlası</p>
                    </a>
                </div>
            </div>
        </section>


        <!-- Stats Section -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <div class="bg-primary-container rounded-[2.5rem] p-12 lg:p-20 flex flex-wrap justify-around gap-12 text-center border border-primary/10">
                <div class="flex flex-col">
