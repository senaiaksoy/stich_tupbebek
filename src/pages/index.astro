---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const recentArticles = (await getCollection('articles')).slice(0, 3);
---

<BaseLayout title="tupbebek.com | Üreme Sağlığı Bilgisi">
    <Header />
    
    <main class="pt-24">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-8 mb-20 relative">
            <div class="grid lg:grid-cols-2 gap-16 items-center py-20">
                <div class="order-2 lg:order-1">
                    <h1 class="text-5xl lg:text-6xl font-headline text-on-surface leading-tight mb-8">
                        Bilimsel Derinlik, <br/><span class="italic text-primary">İnsani Hassasiyet</span>
                    </h1>
                    <p class="text-lg text-secondary leading-relaxed mb-10 max-w-xl">
                        1996’dan bu yana, üreme tıbbındaki en ileri teknolojileri ve hakemli klinik verileri, otuz yılı aşkın hekimlik tecrübemizin süzgecinden geçiriyoruz. Akademik derinliğimizi, bir ailenin heyecanına duyduğumuz saygıyla harmanladık. Binlerce hikâyeye eşlik eden bu kapsamlı bilgi yolculuğunda, yanınızdayız.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="/tedavi-yontemleri" class="bg-primary text-on-primary px-8 py-3 rounded-xl font-medium hover:bg-primary-dim transition-colors inline-block">Yaşama Dokunan Tedaviler</a>
                        <a href="/makaleler" class="border border-outline-variant/30 text-primary px-8 py-3 rounded-xl font-medium hover:bg-surface-container transition-colors inline-block">Bilimsel Yaklaşımımız</a>
                    </div>
                </div>
                <div class="order-1 lg:order-2">
                    <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl relative">
                        <img alt="temiz ve steril laboratuvar ortamında, mavi klinik ışıklandırma ve tıbbi camlar altında petri kabının mikroskobik yakın çekimi" class="w-full h-full object-cover" src="/images/home/hero.jpg" width="512" height="512" loading="eager" fetchpriority="high"/>
                    </div>
                </div>
            </div>
        </section>

        <!-- Bento Knowledge Grid -->
        <section class="bg-surface-container-low py-20">
            <div class="max-w-7xl mx-auto px-8">
                <div class="mb-12">
                    <h2 class="text-3xl font-headline text-on-surface mb-4 text-center">Temel Eğitim</h2>
                    <div class="h-1 w-16 bg-primary mx-auto rounded-full"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[300px]">
                    <!-- Large Feature: Understanding Infertility -->
                    <div class="md:col-span-8 md:row-span-2 bg-surface-container-lowest rounded-3xl p-10 flex flex-col justify-between group cursor-pointer overflow-hidden relative">
                        <div class="relative z-10">
                            <span class="text-primary font-label uppercase tracking-widest text-xs font-bold mb-4 block">Temeller</span>
                            <h3 class="text-4xl font-headline text-on-surface mb-6 max-w-md">Doç. Dr. Senai Aksoy</h3>
                            <p class="text-secondary max-w-md text-lg leading-relaxed">
                                Gebe kalmanın önündeki fizyolojik ve hormonal engellere kapsamlı bir bakış. Bu bölüm tanı protokollerini, yaşa bağlı düşüşü ve çevresel faktörleri akademik bir netlikle ele almaktadır.
                            </p>
                        </div>
                        <div class="mt-8 relative z-10">
                            <span class="flex items-center text-primary font-semibold group-hover:gap-4 transition-all">
                                Öğrenmeye Başla <span class="material-symbols-outlined ml-2">arrow_forward</span>
                            </span>
                        </div>
                        <img alt="tıbbi büyüme ve ilerlemeyi temsil eden beyaz kavisli merdivenlerin ve yumuşak doğal gölgelerin soyut mimari minimalist görünümü" class="absolute -right-20 -bottom-20 w-2/3 opacity-10 group-hover:scale-105 transition-transform duration-700 pointer-events-none" src="/images/home/bento-1.jpg" width="512" height="288" loading="lazy"/>
                    </div>
                    <!-- Medium Feature: Science of IVF -->
                    <div class="md:col-span-4 bg-surface-container-highest rounded-3xl p-8 flex flex-col justify-between group cursor-pointer border border-transparent hover:border-primary/20 transition-all">
                        <div>
                            <span class="material-symbols-outlined text-primary mb-4" style="font-size: 32px;">biotech</span>
                            <h3 class="text-2xl font-headline text-on-surface mb-4">Laboratuvar Teknolojileri</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed">
                                Oosit toplama işleminden blastokist gelişimine kadar laboratuvar sürecinin detaylı incelenmesi.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-outline opacity-40 group-hover:opacity-100 transition-opacity">arrow_outward</span>
                    </div>
                    <!-- Medium Feature: Success Rates -->
                    <div class="md:col-span-4 bg-primary text-on-primary rounded-3xl p-8 flex flex-col justify-between group cursor-pointer shadow-lg">
                        <div>
                            <span class="material-symbols-outlined text-on-primary/70 mb-4" style="font-size: 32px;">microbiology</span>
                            <h3 class="text-2xl font-headline mb-4">Başarı Oranları</h3>
                            <p class="text-on-primary/80 text-sm leading-relaxed">
                                Endometriyal reseptivite ve genetik tarama teknolojilerindeki son gelişmeler ve güncel başarı veri setlerinin keşfi.
                            </p>
                        </div>
                        <span class="material-symbols-outlined self-end text-on-primary/50 group-hover:translate-x-1 transition-transform">east</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Latest Articles Section -->
        <section class="bg-surface-container py-24">
            <div class="max-w-7xl mx-auto px-8">
                <div class="flex justify-between items-end mb-12">
                    <div>
                        <h2 class="text-3xl font-headline text-on-surface mb-4">Son Makaleler</h2>
                        <p class="text-secondary">Üreme endokrinolojisi ve bilimindeki güncel yayınlar.</p>
                    </div>
                    <a href="/makaleler" class="hidden md:block text-primary font-semibold hover:underline">Bilimsel Arşivi Görüntüle</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    {recentArticles.map(article => (
                        <article class="bg-surface-container-lowest rounded-2xl p-6 hover:shadow-lg transition-shadow">
                            <div class="aspect-video rounded-xl overflow-hidden mb-6">
                                <img 
                                    alt={article.data.imageAlt || article.data.title} 
                                    class="w-full h-full object-cover" 
                                    src={article.data.image} 
                                    width="512" height="512" 
                                    loading="lazy"
                                />
                            </div>
                            <span class="text-xs font-label font-bold text-tertiary uppercase tracking-tighter mb-3 block">{article.data.category}</span>
                            <a href={`/makaleler/${article.slug}`}>
                                <h3 class="text-xl font-headline text-on-surface mb-4 line-clamp-2 hover:text-primary transition-colors">
                                    {article.data.title}
                                </h3>
                            </a>
                            <p class="text-secondary text-sm mb-6 line-clamp-3 leading-relaxed">
                                {article.data.description}
                            </p>
                            <div class="flex items-center gap-3 pt-6 border-t border-surface-variant">
                                <div class="w-8 h-8 rounded-full bg-surface-container flex items-center justify-center overflow-hidden">
                                    <img src="/images/senai-aksoy.jpg" alt={article.data.author} class="w-full h-full object-cover" width="100" height="100" />
                                </div>
                                <span class="text-xs text-on-surface-variant font-medium uppercase tracking-widest">{article.data.author}</span>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <!-- Medical Reviewer Section -->
        <section class="py-20 bg-surface-container-low">
            <div class="max-w-3xl mx-auto px-8 text-center">
                <div class="mb-8">
                    <img alt="portre" class="w-24 h-24 rounded-full mx-auto object-cover brightness-110 mb-6 border-4 border-surface-container-lowest shadow-sm" src="/images/senai-aksoy.jpg" width="512" height="512" loading="lazy"/>
                    <h3 class="text-xl font-headline text-on-surface">Doç. Dr. Senai Aksoy</h3>
                    <p class="text-primary font-label uppercase tracking-widest text-xs font-bold mt-1">Tıbbi İnceleme & Bilimsel Onay</p>
                </div>
                <p class="text-secondary italic text-sm leading-relaxed">
                    tupbebek.com platformundaki bilimsel doğruluk ve klinik dürüstlük, titiz bir editoryal denetimle sürdürülmektedir. Tüm makaleler, üreme tıbbındaki en son yayınlanmış konsensüs ile uyumu sağlamak amacıyla uzman tıp doktorları tarafından incelemeye tabidir.
                </p>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
