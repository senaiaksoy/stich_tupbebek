---
import { getPublishedArticles } from '../../utils/articles';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const articles = await getPublishedArticles();

// Featured articles
const featuredArticles = articles.filter(a => a.data.featured).slice(0, 2);

// All articles sorted by date
const allArticles = articles.sort((a, b) =>
    (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
);

// Extract unique categories with counts
const categoryCounts = new Map<string, number>();
articles.forEach(a => {
    const cat = a.data.category;
    categoryCounts.set(cat, (categoryCounts.get(cat) || 0) + 1);
});
const categories = Array.from(categoryCounts.entries())
    .sort((a, b) => b[1] - a[1])
    .map(([name, count]) => ({ name, count }));
---

<BaseLayout title="Bilimsel Makaleler ve Yayınlar | tupbebek.com" description="Üreme sağlığı, IVF teknolojileri, infertilite tedavileri ve güncel literatür hakkında bilimsel makaleler. Yayın kurulu onaylı.">
    <Header />

    <main id="main-content" tabindex="-1" class="pt-32 pb-24">
        <!-- Hero Header -->
        <header class="max-w-7xl mx-auto px-6 mb-16">
            <div class="max-w-3xl">
                <nav class="flex items-center gap-2 text-xs font-label text-gray-600 mb-6 uppercase tracking-widest" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-primary-600 transition-colors">Ana Sayfa</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <span class="text-primary-600 font-semibold">Makaleler</span>
                </nav>
                <h1 class="font-headline text-4xl lg:text-5xl font-bold text-gray-900 leading-tight mb-6">
                    Bilimsel Yaklaşımlar ve <br/><span class="italic text-primary-600">Güncel Literatür</span>
                </h1>
                <p class="text-lg text-gray-600 leading-relaxed">Üreme sağlığı ve tüp bebek teknolojilerindeki en son gelişmeleri, klinik araştırmaları ve uzman görüşlerini içeren akademik arşivimiz.</p>

                <!-- Client-side filter banner -->
                <div id="filter-banner" class="mt-6 p-4 bg-primary-50 border border-primary-100 rounded-xl items-center justify-between" style="display:none;">
                  <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary-600">filter_alt</span>
                    <span id="filter-text" class="text-sm text-gray-900"></span>
                  </div>
                  <a href="/makaleler" class="text-xs text-primary-600 font-bold hover:underline flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">close</span>
                    Filtreyi Temizle
                  </a>
                </div>
            </div>
        </header>

        <!-- Category Filter Chips -->
        <section class="max-w-7xl mx-auto px-6 mb-16">
            <div class="flex flex-wrap gap-3" role="list" aria-label="Kategori filtreleri">
                <a href="/makaleler" class="category-chip active inline-flex items-center gap-2 px-5 py-2.5 min-h-[44px] rounded-full text-sm font-semibold bg-primary-600 text-white border-2 border-primary-600 transition-all" data-category="all">
                    <span class="material-symbols-outlined text-base">apps</span>
                    Tümünü Göster
                    <span class="text-xs opacity-75">({articles.length})</span>
                </a>
                {categories.map(cat => (
                    <button class="category-chip inline-flex items-center gap-2 px-5 py-2.5 min-h-[44px] rounded-full text-sm font-semibold bg-white text-gray-700 border-2 border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-all cursor-pointer" data-category={cat.name.toLowerCase()}>
                        {cat.name}
                        <span class="text-xs text-gray-400">({cat.count})</span>
                    </button>
                ))}
            </div>
        </section>

        <!-- Öne Çıkan Bilimsel Makaleler -->
        {featuredArticles.length > 0 && (
        <section class="bg-gray-50 py-20 mb-16">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex items-end justify-between mb-12">
                    <div>
                        <span class="text-xs font-bold text-primary-600 uppercase tracking-widest mb-3 block">ÖNE ÇIKANLAR</span>
                        <h2 class="font-headline text-3xl font-bold text-gray-900">Öne Çıkan Bilimsel Makaleler</h2>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    {featuredArticles.map(article => (
                        <a href={`/makaleler/${article.slug}`} class="group block bg-white rounded-xl overflow-hidden border border-gray-200 hover:shadow-md hover:border-primary-100 transition-all duration-300">
                            {article.data.image && (
                                <div class="aspect-video overflow-hidden">
                                    <img
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                        src={article.data.image}
                                        alt={article.data.imageAlt || article.data.title}
                                        width="640" height="360"
                                        loading="eager"
                                    />
                                </div>
                            )}
                            <div class="p-6 md:p-8">
                                <div class="flex items-center gap-3 mb-4">
                                    <span class="bg-primary-50 text-primary-600 px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase">{article.data.category}</span>
                                    <span class="bg-mint-50 text-mint-700 px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase">Öne Çıkan</span>
                                </div>
                                <h3 class="font-headline text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-600 transition-colors leading-snug">
                                    {article.data.title}
                                </h3>
                                <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-2">
                                    {article.data.description}
                                </p>
                                <div class="flex items-center gap-3">
                                    <span class="material-symbols-outlined text-mint-600 text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                                    <span class="text-xs font-semibold text-gray-700">{article.data.author}</span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
        )}

        <!-- Tüm Makaleler Grid -->
        <section class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col lg:flex-row gap-12">
                <!-- Articles Grid -->
                <div class="lg:w-2/3">
                    <h2 class="font-headline text-2xl font-bold text-gray-900 mb-8">Tüm Makaleler</h2>
                    <div id="articles-grid" class="space-y-6">
                        {allArticles.map(article => (
                            <article class="article-item group" data-title={article.data.title.toLowerCase()} data-desc={(article.data.description || '').toLowerCase()} data-category={article.data.category.toLowerCase()}>
                                <a href={`/makaleler/${article.slug}`} class="flex flex-col sm:flex-row gap-5 p-5 bg-white border border-gray-200 rounded-xl hover:shadow-md hover:border-primary-100 transition-all duration-300">
                                    {article.data.image && (
                                        <div class="sm:w-48 shrink-0 aspect-video sm:aspect-[4/3] rounded-lg overflow-hidden">
                                            <img
                                                src={article.data.image}
                                                alt={article.data.imageAlt || article.data.title}
                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                width="192" height="144" loading="lazy"
                                            />
                                        </div>
                                    )}
                                    <div class="flex-1 min-w-0 flex flex-col">
                                        <div class="flex items-center gap-3 mb-2">
                                            <span class="text-[10px] font-bold text-primary-600 uppercase tracking-widest">{article.data.category}</span>
                                            {article.data.publishDate && (
                                                <span class="text-[10px] text-gray-400">
                                                    {article.data.publishDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'short' })}
                                                </span>
                                            )}
                                        </div>
                                        <h3 class="font-headline text-base font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-2 leading-snug">
                                            {article.data.title}
                                        </h3>
                                        <p class="text-xs text-gray-500 leading-relaxed line-clamp-2 mb-3 flex-1">
                                            {article.data.description}
                                        </p>
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2">
                                                <span class="material-symbols-outlined text-mint-600 text-xs" style="font-variation-settings: 'FILL' 1;">verified</span>
                                                <span class="text-[10px] font-semibold text-gray-600">{article.data.author}</span>
                                            </div>
                                            <span class="material-symbols-outlined text-gray-300 group-hover:text-primary-600 group-hover:translate-x-1 transition-all text-sm">arrow_forward</span>
                                        </div>
                                    </div>
                                </a>
                            </article>
                        ))}
                    </div>

                    <!-- No results message -->
                    <div id="no-results" class="hidden text-center py-16">
                        <span class="material-symbols-outlined text-gray-300 text-5xl mb-4">search_off</span>
                        <p class="text-gray-500 font-semibold">Bu kriterlere uygun makale bulunamadı.</p>
                        <a href="/makaleler" class="text-sm text-primary-600 font-bold hover:underline mt-2 inline-block">Tüm makaleleri göster</a>
                    </div>
                </div>

                <!-- Sidebar -->
                <aside class="lg:w-1/3">
                    <div class="sticky top-32 space-y-8">
                        <!-- Newsletter -->
                        <div class="bg-primary-600 text-white rounded-xl p-8 overflow-hidden relative">
                            <div class="relative z-10">
                                <h3 class="font-headline text-xl font-bold mb-4">Bültene Abone Olun</h3>
                                <p class="text-sm opacity-90 mb-6 leading-relaxed">En yeni bilimsel araştırmalar ve tıbbi güncellemeler doğrudan e-posta kutunuza gelsin.</p>
                                <div class="space-y-3">
                                    <input class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 min-h-[44px] text-sm focus:outline-none focus:ring-2 focus:ring-white/30 placeholder:text-white/50" placeholder="E-posta adresiniz" type="email" aria-label="E-posta adresiniz"/>
                                    <button class="w-full bg-white text-primary-600 font-bold text-sm py-3 min-h-[44px] rounded-lg hover:bg-gray-100 transition-all">Kaydol</button>
                                </div>
                            </div>
                            <div class="absolute -right-8 -bottom-8 opacity-10">
                                <span class="material-symbols-outlined text-[160px]">mail</span>
                            </div>
                        </div>

                        <!-- Popular Categories -->
                        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                            <h3 class="font-headline text-sm font-bold text-gray-900 mb-4 uppercase tracking-widest">Kategoriler</h3>
                            <ul class="space-y-1">
                                {categories.slice(0, 8).map(cat => (
                                    <li>
                                        <button class="sidebar-cat-btn flex items-center justify-between w-full px-3 py-2.5 min-h-[44px] rounded-lg text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-600 transition-colors text-left" data-sidebar-category={cat.name.toLowerCase()}>
                                            <span>{cat.name}</span>
                                            <span class="text-xs text-gray-400 bg-gray-200 px-2 py-0.5 rounded-full">{cat.count}</span>
                                        </button>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </aside>
            </div>
        </section>
    </main>

    <Footer />

    <script is:inline>
      (function() {
        // Turkish character normalization
        function normalize(str) {
          return str.replace(/ı/g,'i').replace(/İ/g,'i')
                    .replace(/ö/g,'o').replace(/Ö/g,'o')
                    .replace(/ü/g,'u').replace(/Ü/g,'u')
                    .replace(/ş/g,'s').replace(/Ş/g,'s')
                    .replace(/ç/g,'c').replace(/Ç/g,'c')
                    .replace(/ğ/g,'g').replace(/Ğ/g,'g')
                    .toLowerCase();
        }

        var chips = document.querySelectorAll('.category-chip');
        var sidebarBtns = document.querySelectorAll('.sidebar-cat-btn');
        var articles = document.querySelectorAll('.article-item');
        var banner = document.getElementById('filter-banner');
        var filterText = document.getElementById('filter-text');
        var noResults = document.getElementById('no-results');

        // URL params
        var params = new URLSearchParams(window.location.search);
        var q = (params.get('q') || '').trim().toLowerCase();
        var qNorm = normalize(q);

        function filterByCategory(category) {
          var matchCount = 0;
          articles.forEach(function(article) {
            var articleCat = normalize(article.getAttribute('data-category') || '');
            var title = normalize(article.getAttribute('data-title') || '');
            var desc = normalize(article.getAttribute('data-desc') || '');

            var matches = true;
            if (category && category !== 'all') {
              if (articleCat !== normalize(category)) matches = false;
            }
            if (qNorm && title.indexOf(qNorm) === -1 && desc.indexOf(qNorm) === -1 && articleCat.indexOf(qNorm) === -1) {
              matches = false;
            }

            article.style.display = matches ? '' : 'none';
            if (matches) matchCount++;
          });

          // Update chips active state
          chips.forEach(function(chip) {
            var chipCat = chip.getAttribute('data-category');
            if (chipCat === (category || 'all')) {
              chip.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
              chip.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
            } else {
              chip.classList.remove('bg-primary-600', 'text-white', 'border-primary-600');
              chip.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
            }
          });

          // Show/hide banner
          if (banner && filterText && category && category !== 'all') {
            filterText.innerHTML = '<strong>Kategori:</strong> ' + category + ' <span style="opacity:0.6">(' + matchCount + ' sonuc)</span>';
            banner.style.display = 'flex';
          } else if (banner && !q) {
            banner.style.display = 'none';
          }

          // No results
          if (noResults) {
            noResults.classList.toggle('hidden', matchCount > 0);
          }
        }

        // Category chip clicks
        chips.forEach(function(chip) {
          chip.addEventListener('click', function(e) {
            e.preventDefault();
            var cat = chip.getAttribute('data-category');
            filterByCategory(cat);
          });
        });

        // Sidebar category clicks
        sidebarBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            var cat = btn.getAttribute('data-sidebar-category');
            filterByCategory(cat);
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        });

        // URL param based filtering on load
        var cat = (params.get('category') || '').trim().toLowerCase();
        if (q && banner && filterText) {
          filterText.innerHTML = '<strong>Arama:</strong> "' + q + '"';
          banner.style.display = 'flex';
          filterByCategory('all');
        } else if (cat) {
          filterByCategory(cat);
        }
      })();
    </script>
</BaseLayout>
