---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const articles = await getCollection('articles');
const featuredArticles = articles.filter(a => a.data.featured).slice(0, 2);
const recentArticles = articles.filter(a => !a.data.featured).sort((a, b) =>
    (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
);
---

<BaseLayout title="Bilimsel Makaleler ve Yayınlar | tupbebek.com" description="Üreme sağlığı, IVF teknolojileri, infertilite tedavileri ve güncel literatür hakkında bilimsel makaleler. Yayın kurulu onaylı.">
    <Header />
    
    <main id="main-content" tabindex="-1" class="pt-32 pb-24">
        <!-- Hero Header -->
        <header class="max-w-7xl mx-auto px-6 mb-20">
            <div class="max-w-3xl">
                <nav class="flex items-center gap-2 text-xs font-label text-gray-600 mb-6 uppercase tracking-widest">
                    <a href="/">Ana Sayfa</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <span class="text-primary-600 font-semibold">Makaleler</span>
                </nav>
                <h1 class="font-headline text-5xl font-bold text-gray-900 leading-tight mb-6">Bilimsel Yaklaşımlar ve <br/><span class="italic text-primary-600">Güncel Literatür</span></h1>
                <p class="font-body text-lg text-gray-600 leading-relaxed">Üreme sağlığı ve tüp bebek teknolojilerindeki en son gelişmeleri, klinik araştırmaları ve uzman görüşlerini içeren akademik arşivimiz.</p>
                <!-- Client-side filter banner (shown by JS when ?q= or ?category= present) -->
                <div id="filter-banner" class="mt-6 p-4 bg-primary-50 border border-primary-100 rounded-xl items-center justify-between" style="display:none;">
                  <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary-600">filter_alt</span>
                    <span id="filter-text" class="text-sm text-gray-900"></span>
                  </div>
                  <a href="/makaleler" class="text-xs text-primary-600 font-bold hover:underline flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">close</span>
                    Filtreyi Temizle
                  </a>
                </div>
            </div>
        </header>

        <!-- Category Bento Grid -->
        <section class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="md:col-span-2 bg-gray-50 rounded-xl p-8 flex flex-col justify-between group cursor-pointer transition-all hover:bg-gray-100">
                    <div>
                        <span class="material-symbols-outlined text-primary-600 mb-4 text-3xl">biotech</span>
                        <h3 class="font-headline text-2xl font-semibold mb-3">İnfertilite Çözümleri</h3>
                        <p class="font-body text-sm text-gray-600">Modern tıbbın sunduğu en yeni kısırlık tedavi protokolleri ve başarı oranları analizi.</p>
                    </div>
                    <div class="mt-8 flex items-center gap-2 text-primary-600 font-semibold text-sm">
                        Keşfet <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </div>
                </div>
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 flex flex-col justify-between group cursor-pointer transition-all hover:shadow-lg">
                    <div>
                        <span class="material-symbols-outlined text-mint-600 mb-4 text-3xl">science</span>
                        <h3 class="font-headline text-xl font-semibold mb-3">Embriyoloji</h3>
                        <p class="font-body text-sm text-gray-600">Laboratuvar ortamında yaşamın başlangıcı.</p>
                    </div>
                    <div class="mt-6 text-mint-600 font-semibold text-xs tracking-wider">14 MAKALE</div>
                </div>
                <div class="bg-gray-100 rounded-xl p-8 flex flex-col justify-between group cursor-pointer transition-all hover:bg-gray-200">
                    <div>
                        <span class="material-symbols-outlined text-gray-500 mb-4 text-3xl">genetics</span>
                        <h3 class="font-headline text-xl font-semibold mb-3">Genetik</h3>
                        <p class="font-body text-sm text-gray-600">PGT-A ve kalıtsal tarama teknolojileri.</p>
                    </div>
                    <div class="mt-6 text-gray-500 font-semibold text-xs tracking-wider">08 MAKALE</div>
                </div>
            </div>
        </section>

        <!-- Öne Çıkan Bilimsel Makaleler -->
        <section class="bg-gray-50 py-24">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex items-end justify-between mb-12">
                    <div>
                        <h2 class="font-headline text-3xl font-bold mb-4">Öne Çıkan Bilimsel Makaleler</h2>
                        <div class="h-1 w-20 bg-primary-600"></div>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    {featuredArticles.map((article, index) => (
                        <article class={`flex flex-col md:flex-row gap-8 items-center ${index === 1 ? 'md:flex-row-reverse' : ''}`}>
                            <div class="w-full md:w-1/2 aspect-[4/5] rounded-xl overflow-hidden shadow-xl">
                                <img 
                                    class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" 
                                    src={article.data.image} 
                                    alt={article.data.imageAlt || article.data.title}
                                    width="512" height="512"
                                    loading="eager"
                                    fetchpriority="high"
                                />
                            </div>
                            <div class={`w-full md:w-1/2 ${index === 1 ? 'md:text-right' : ''}`}>
                                <div class={`flex items-center gap-4 mb-4 ${index === 1 ? 'justify-end' : ''}`}>
                                    <span class="bg-mint-100 text-mint-700 px-3 py-1 rounded text-[10px] font-bold tracking-widest uppercase">Derin İnceleme</span>
                                    <span class="text-xs text-gray-600 font-label">12 Dakika Okuma</span>
                                </div>
                                <a href={`/makaleler/${article.slug}`}>
                                    <h3 class="font-headline text-2xl font-bold mb-4 leading-snug hover:text-primary-600 transition-colors cursor-pointer">
                                        {article.data.title}
                                    </h3>
                                </a>
                                <p class="font-body text-gray-600 mb-6 leading-relaxed text-sm">
                                    {article.data.description}
                                </p>
                                <div class={`flex items-center gap-4 bg-gray-50 p-4 rounded-xl border border-gray-200 ${index === 1 ? 'justify-end' : ''}`}>
                                    {index === 0 && (
                                        <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-primary-600">verified_user</span>
                                        </div>
                                    )}
                                    <div>
                                        <p class="text-xs font-bold text-gray-900">Yayın Kurulu Onaylı</p>
                                        <p class="text-[10px] text-gray-600">Hekim Onaylı Bilimsel İçerik</p>
                                    </div>
                                    {index === 1 && (
                                        <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-primary-600">verified_user</span>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <!-- Güncel Makaleler Feed -->
        <section class="max-w-7xl mx-auto px-6 py-24">
            <div class="flex flex-col md:flex-row gap-16">
                <!-- Feed Column -->
                <div class="md:w-2/3">
                    <h2 class="font-headline text-3xl font-bold mb-12">Güncel Makaleler</h2>
                    <div class="space-y-16">
                        {recentArticles.map(article => (
                            <article class="group cursor-pointer article-item" data-title={article.data.title.toLowerCase()} data-desc={(article.data.description || '').toLowerCase()} data-category={(article.data.category || '').toLowerCase()}>
                                <a href={`/makaleler/${article.slug}`}>
                                    <div class="flex items-center gap-4 text-xs font-label text-gray-600 mb-4">
                                        <span class="text-primary-600 font-bold uppercase">{article.data.category}</span>
                                        <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                                        <span>Mart 2024</span>
                                    </div>
                                    <h3 class="font-headline text-2xl font-bold mb-4 group-hover:text-primary-600 transition-colors">
                                        {article.data.title}
                                    </h3>
                                    <p class="font-body text-gray-600 leading-relaxed mb-6">
                                        {article.data.description}
                                    </p>
                                </a>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-mint-600 text-sm" style="font-variation-settings: 'FILL' 1;">verified</span>
                                        <span class="text-xs font-semibold text-gray-900">İnceleme: {article.data.author}</span>
                                    </div>
                                    <span class="material-symbols-outlined text-gray-400 group-hover:translate-x-1 transition-transform">arrow_forward</span>
                                </div>
                                <div class="mt-8 h-[1px] w-full bg-gray-200"></div>
                            </article>
                        ))}
                    </div>
                    <button class="mt-16 w-full py-4 border border-gray-300 rounded-xl font-label text-sm text-gray-600 hover:bg-gray-100 transition-all">Daha Fazla Makale Yükle</button>
                </div>

                <!-- Sidebar / Newsletter -->
                <aside class="md:w-1/3">
                    <div class="sticky top-32 space-y-8">
                        <div class="bg-primary-600 text-white rounded-xl p-8 overflow-hidden relative">
                            <div class="relative z-10">
                                <h3 class="font-headline text-xl font-bold mb-4 italic">Bültene Abone Olun</h3>
                                <p class="font-body text-sm opacity-90 mb-6 leading-relaxed">En yeni bilimsel araştırmalar ve tıbbi güncellemeler doğrudan e-posta kutunuza gelsin.</p>
                                <div class="space-y-4">
                                    <input class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-white/30 placeholder:text-white/50" placeholder="E-posta adresiniz" type="email"/>
                                    <button class="w-full bg-white text-primary-600 font-bold text-sm py-3 rounded-lg hover:bg-gray-100 transition-all">Kaydol</button>
                                </div>
                            </div>
                            <div class="absolute -right-8 -bottom-8 opacity-10">
                                <span class="material-symbols-outlined text-[160px]">mail</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </section>
    </main>

    <Footer />

    <script is:inline>
      // Client-side article filtering based on URL query params
      (function() {
        // Turkish character normalization for search matching
        function normalize(str) {
          return str.replace(/ı/g,'i').replace(/İ/g,'i')
                    .replace(/ö/g,'o').replace(/Ö/g,'o')
                    .replace(/ü/g,'u').replace(/Ü/g,'u')
                    .replace(/ş/g,'s').replace(/Ş/g,'s')
                    .replace(/ç/g,'c').replace(/Ç/g,'c')
                    .replace(/ğ/g,'g').replace(/Ğ/g,'g')
                    .toLowerCase();
        }

        // Category display labels
        var catLabels = { kadin: 'Kadın', erkek: 'Erkek', tedavi: 'Tedavi' };

        var params = new URLSearchParams(window.location.search);
        var q = (params.get('q') || '').trim().toLowerCase();
        var cat = (params.get('category') || '').trim().toLowerCase();
        var qNorm = normalize(q);
        var catNorm = normalize(cat);

        if (!q && !cat) return; // No filters, show everything

        var banner = document.getElementById('filter-banner');
        var filterText = document.getElementById('filter-text');
        if (!banner || !filterText) return;

        var label = '';
        if (q) label += '<strong>Arama:</strong> "' + q + '"';
        if (cat) label += '<strong>Kategori:</strong> ' + (catLabels[cat] || cat);

        var articles = document.querySelectorAll('.article-item');
        var matchCount = 0;
        articles.forEach(function(article) {
          var title = normalize(article.getAttribute('data-title') || '');
          var desc = normalize(article.getAttribute('data-desc') || '');
          var articleCat = normalize(article.getAttribute('data-category') || '');

          var matches = true;
          if (qNorm && title.indexOf(qNorm) === -1 && desc.indexOf(qNorm) === -1 && articleCat.indexOf(qNorm) === -1) {
            matches = false;
          }
          if (catNorm && articleCat.indexOf(catNorm) === -1) {
            matches = false;
          }

          if (matches) {
            matchCount++;
            article.style.display = '';
          } else {
            article.style.display = 'none';
          }
        });

        label += ' <span style="opacity:0.6">(' + matchCount + ' sonuç)</span>';
        filterText.innerHTML = label;
        banner.style.display = 'flex';
      })();
    </script>
</BaseLayout>
