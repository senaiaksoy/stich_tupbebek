---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import ArticleMeta from '../../components/ArticleMeta.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const publishDateStr = entry.data.publishDate
    ? entry.data.publishDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const lastModifiedStr = entry.data.lastModified
    ? entry.data.lastModified.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const reviewDateStr = entry.data.reviewDate
    ? entry.data.reviewDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const articleUrl = `https://tupbebek.com/makaleler/${entry.slug}`;
---

<BaseLayout title={`${entry.data.title} | tupbebek.com`} description={entry.data.description} image={entry.data.image}>
    <Header />
    <ReadingProgress />

    <main id="main-content" tabindex="-1" class="pt-32 pb-24">
        <article class="max-w-4xl mx-auto px-6 relative">
            <!-- Breadcrumb -->
            <header class="mb-12">
                <nav class="flex items-center gap-2 text-xs font-label text-gray-600 mb-6 uppercase tracking-widest" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-primary-600 transition-colors">Ana Sayfa</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <a href="/makaleler" class="hover:text-primary-600 transition-colors">Makaleler</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <span class="text-primary-600 font-semibold">{entry.data.category}</span>
                </nav>

                <!-- Title -->
                <h1 class="font-headline text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
                    {entry.data.title}
                </h1>

                <!-- Description -->
                {entry.data.description && (
                    <p class="text-lg text-gray-600 leading-relaxed mb-8">{entry.data.description}</p>
                )}

                <!-- Author & Date Bar -->
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 py-5 border-y border-gray-200">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary-600 text-xl" style="font-variation-settings: 'FILL' 1;">verified</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-gray-900">{entry.data.author}</p>
                            <p class="text-xs text-gray-500">
                                {entry.data.medicalReviewer && entry.data.medicalReviewer !== entry.data.author
                                    ? `Tibbi Inceleme: ${entry.data.medicalReviewer}`
                                    : 'Yayin Kurulu Onayli'
                                }
                            </p>
                        </div>
                    </div>
                    <div class="sm:ml-auto flex items-center gap-4 text-xs text-gray-500">
                        {publishDateStr && (
                            <time datetime={entry.data.publishDate?.toISOString()}>
                                <span class="material-symbols-outlined text-sm align-text-bottom mr-1">calendar_today</span>
                                {publishDateStr}
                            </time>
                        )}
                        {lastModifiedStr && (
                            <span>
                                <span class="material-symbols-outlined text-sm align-text-bottom mr-1">update</span>
                                {lastModifiedStr}
                            </span>
                        )}
                    </div>
                </div>
            </header>

            <!-- Hero Image -->
            {entry.data.image && (
                <div class="aspect-video rounded-2xl overflow-hidden mb-12 shadow-xl">
                    <img
                        src={entry.data.image}
                        alt={entry.data.imageAlt || entry.data.title}
                        class="w-full h-full object-cover"
                        width="896" height="504"
                        loading="eager"
                        fetchpriority="high"
                    />
                </div>
            )}

            <!-- Article Content — AI-skimmable prose -->
            <div class="prose-medical">
                <Content />
            </div>

            <!-- Share Buttons -->
            <div class="mt-12 pt-8 border-t border-gray-200">
                <ShareButtons title={entry.data.title} url={articleUrl} />
            </div>

            <!-- Medical Review Info -->
            <div class="mt-8">
                <ArticleMeta
                    reviewedBy={entry.data.medicalReviewer}
                    reviewDate={reviewDateStr}
                    lastUpdated={lastModifiedStr}
                />
            </div>

            <!-- Medical Disclaimer -->
            <footer class="mt-12">
                <div class="bg-gray-50 p-6 md:p-8 rounded-2xl border border-gray-200">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-amber-600">info</span>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-gray-900 mb-2">Tibbi Bilgi Notu</h4>
                            <p class="text-xs text-gray-600 leading-relaxed">
                                Bu makale, tupbebek.com yayin kurulu tarafindan tibbi dogruluk ve guncel klinik protokoller acisindan incelenmis ve onaylanmistir. Sunulan bilgiler genel bilgilendirme amacidir; kisisel tibbi tani veya tedavi yerine gecmez. Saglik kararlari icin mutlaka bir hekime danismanizi oneririz.
                            </p>
                        </div>
                    </div>
                </div>
            </footer>

            <!-- Related Articles -->
            <RelatedArticles currentSlug={entry.slug} category={entry.data.category} />
        </article>

        <!-- Table of Contents (fixed sidebar on xl screens) -->
        <TableOfContents />
    </main>

    <Footer />
</BaseLayout>
