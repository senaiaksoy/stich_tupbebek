---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} | tupbebek.com`} description={entry.data.description} image={entry.data.image}>
    <Header />
    
    <main id="main-content" tabindex="-1" class="pt-32 pb-24">
        <article class="max-w-4xl mx-auto px-6">
            <header class="mb-12">
                <nav class="flex items-center gap-2 text-xs font-label text-gray-600 mb-6 uppercase tracking-widest">
                    <a href="/">Ana Sayfa</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <a href="/makaleler">Makaleler</a>
                    <span class="material-symbols-outlined text-[10px]">chevron_right</span>
                    <span class="text-primary-600 font-semibold">{entry.data.category}</span>
                </nav>
                <h1 class="font-headline text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-8">
                    {entry.data.title}
                </h1>
                
                <div class="flex items-center gap-4 py-6 border-y border-gray-200">
                    {entry.data.image && (
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-gray-100">
                             <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                        </div>
                    )}
                    <div>
                        <p class="text-sm font-bold text-gray-900">tupbebek.com Yayın Kurulu</p>
                        <p class="text-xs text-gray-600 uppercase tracking-tighter">Yayın Kurulu Onayı</p>
                    </div>
                    <div class="ml-auto text-right">
                        <p class="text-xs text-gray-600 uppercase tracking-widest leading-none mb-1">Yayınlanma</p>
                        <p class="text-sm font-bold text-primary-600">Mart 2024</p>
                    </div>
                </div>
            </header>

            {entry.data.image && (
                <div class="aspect-video rounded-3xl overflow-hidden mb-16 shadow-2xl">
                    <img 
                        src={entry.data.image} 
                        alt={entry.data.imageAlt || entry.data.title} 
                        class="w-full h-full object-cover"
                        width="512"
                        height="512"
                        loading="eager"
                        fetchpriority="high"
                    />
                </div>
            )}

            <div class="prose prose-lg max-w-none prose-gray dark:prose-invert 
                prose-headings:font-headline prose-headings:text-gray-900 
                prose-p:text-gray-600 prose-p:leading-relaxed
                prose-li:text-gray-600
                prose-strong:text-gray-900 prose-strong:font-bold">
                <Content />
            </div>

            <footer class="mt-20 pt-12 border-t border-gray-200">
                <div class="bg-gray-50 p-8 rounded-2xl flex flex-col md:flex-row items-center gap-8 border border-gray-200">
                    <div class="w-20 h-20 rounded-full bg-gray-100 overflow-hidden shrink-0 border-4 border-white">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                    </div>
                    <div>
                        <h4 class="text-xl font-headline font-bold text-gray-900 mb-2 italic">Tıbbi Bilgi Notu</h4>
                        <p class="text-sm text-gray-600 leading-relaxed">
                            Bu makale, tupbebek.com yayın kurulu tarafından tıbbi doğruluk ve güncel klinik protokoller açısından incelenmiş ve onaylanmıştır. Sunulan bilgiler genel bilgilendirme amaçlıdır.
                        </p>
                    </div>
                </div>
            </footer>
        </article>
    </main>

    <Footer />
</BaseLayout>
