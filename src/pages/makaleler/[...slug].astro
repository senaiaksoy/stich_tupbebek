---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import EEATBadge from '../../components/EEATBadge.astro';
import ReferenceList from '../../components/ReferenceList.astro';
import MedicalDisclaimer from '../../components/MedicalDisclaimer.astro';
import EditorKunyesi from '../../components/EditorKunyesi.astro';
import UzmanaSor from '../../components/forms/UzmanaSor.astro';
import LeadMagnet from '../../components/forms/LeadMagnet.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const publishable = articles.filter(entry => {
    const status = entry.data.status;
    return !status || status === 'published';
  });
  return publishable.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Resolve author name
const authorName = typeof entry.data.author === 'string'
    ? entry.data.author
    : entry.data.author.name;
const authorTitle = typeof entry.data.author === 'string'
    ? entry.data.authorTitle
    : entry.data.author.title;
const authorCredentials = typeof entry.data.author === 'string'
    ? entry.data.authorCredentials
    : entry.data.author.credentials;

const publishDateStr = entry.data.publishDate
    ? entry.data.publishDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const lastModifiedStr = entry.data.lastModified
    ? entry.data.lastModified.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const reviewDateStr = entry.data.reviewDate
    ? entry.data.reviewDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;
const articleUrl = `https://tupbebek.com/makaleler/${entry.slug}`;
const referenceCount = entry.data.references?.length || 0;
---

<BaseLayout title={`${entry.data.title} | tupbebek.com`} description={entry.data.description} image={entry.data.image}>
    <Header />
    <ReadingProgress />

    <!-- Article-specific JSON-LD -->
    <ArticleSchema entry={entry} url={articleUrl} />

    <main id="main-content" tabindex="-1" class="pt-32 pb-24">
        <!-- Full-width article header -->
        <div class="max-w-3xl mx-auto px-4 md:px-6">
            <header class="mb-10">
                <!-- Title -->
                <h1 class="font-headline text-3xl md:text-4xl lg:text-[2.75rem] font-bold text-gray-900 leading-tight mb-5">
                    {entry.data.title}
                </h1>

                <!-- Description -->
                {entry.data.description && (
                    <p class="text-lg text-gray-500 leading-relaxed mb-8">{entry.data.description}</p>
                )}

                <!-- E-E-A-T Transparency Badge -->
                <EEATBadge
                    author={authorName}
                    authorTitle={authorTitle}
                    authorCredentials={authorCredentials}
                    medicalReviewer={entry.data.medicalReviewer}
                    reviewerTitle={entry.data.reviewerTitle}
                    reviewDate={reviewDateStr}
                    lastModified={lastModifiedStr}
                    publishDate={publishDateStr}
                    status={entry.data.status || 'published'}
                    referenceCount={referenceCount}
                />

                <!-- Editor Kunyesi (compact - makale başı) -->
                <div class="mt-5">
                    <EditorKunyesi variant="compact" />
                </div>
            </header>

            <!-- Hero Image -->
            {entry.data.image && (
                <div class="aspect-video rounded-xl overflow-hidden mb-10 border border-gray-100">
                    <img
                        src={entry.data.image}
                        alt={entry.data.imageAlt || entry.data.title}
                        class="w-full h-full object-cover"
                        width="896" height="504"
                        loading="eager"
                        fetchpriority="high"
                    />
                </div>
            )}

            <!-- Video Embed (if article has videoId) -->
            {entry.data.videoId && (
                <YouTubeEmbed
                    id={entry.data.videoId}
                    title={entry.data.videoTitle || entry.data.title}
                />
            )}
        </div>

        <!-- Two-column layout: Content + Sidebar -->
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-[minmax(0,_3fr)_minmax(220px,_1fr)] lg:gap-12 xl:gap-16">

                <!-- Main Content Column -->
                <article class="max-w-3xl">
                    <!-- Article Content — prose -->
                    <div class="prose-medical">
                        <Content />
                    </div>

                    <!-- Scientific References -->
                    {entry.data.references && (
                        <ReferenceList references={entry.data.references} />
                    )}

                    <!-- Share Buttons -->
                    <div class="mt-10 pt-8 border-t border-gray-200">
                        <ShareButtons title={entry.data.title} url={articleUrl} />
                    </div>

                    <!-- Editor Kunyesi (full - makale sonu) -->
                    <div class="mt-10">
                        <EditorKunyesi variant="full" />
                    </div>

                    <!-- Medical Disclaimer -->
                    <div class="mt-8">
                        <MedicalDisclaimer />
                    </div>

                    <!-- Lead Forms -->
                    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-6">
                        <UzmanaSor />
                        <LeadMagnet />
                    </div>
                </article>

                <!-- Sidebar Column (sticky) -->
                <aside class="hidden lg:block">
                    <div class="sticky top-28 space-y-8 max-h-[calc(100vh-8rem)] overflow-y-auto">
                        <!-- Table of Contents -->
                        <TableOfContents />

                        <!-- Sidebar Related Articles -->
                        <div class="pt-6 border-t border-gray-200">
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">İlgili Makaleler</p>
                            <RelatedArticles currentSlug={entry.slug} category={entry.data.category} variant="sidebar" />
                        </div>
                    </div>
                </aside>
            </div>
        </div>

        <!-- Mobile Related Articles (below content) -->
        <div class="lg:hidden max-w-3xl mx-auto px-4 md:px-6 mt-14">
            <RelatedArticles currentSlug={entry.slug} category={entry.data.category} />
        </div>
    </main>

    <Footer />
</BaseLayout>
