---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StatsStrip from '../components/StatsStrip.astro';
import RelatedContent from '../components/RelatedContent.astro';
import DisclaimerBar from '../components/DisclaimerBar.astro';
---

<BaseLayout title="Açıklanamayan İnfertilite: Nedenleri ve Tedavisi | tupbebek.com" description="Açıklanamayan (idiyopatik) infertilite tanısı, nedenleri, gizli faktörler ve tedavi seçenekleri.">
    <Header />

    <main id="main-content" tabindex="-1" class="pb-24">
        <!-- Hero Section -->
        <header class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-20">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-xs font-semibold uppercase tracking-wider mb-6">
                        <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">help</span>
                        Tanı Zorlukları
                    </div>
                    <h1 class="font-headline text-5xl md:text-6xl text-on-surface leading-tight mb-8">
                        Açıklanamayan İnfertilite: <span class="text-primary italic">Bilinmeyen</span> Nedenler
                    </h1>
                    <div class="flex items-center gap-4 p-4 bg-surface-container-low rounded-xl border-l-4 border-primary">
                        <div class="w-12 h-12 rounded-full overflow-hidden bg-surface-dim">
                            <span class="material-symbols-outlined text-primary text-2xl">verified</span>
                        </div>
                        <div>
                            <p class="font-headline italic text-on-surface text-sm">İnceleme:</p>
                            <p class="font-bold text-primary">Doç. Yayın Kurulu</p>
                        </div>
                    </div>
                </div>
                <div class="hidden md:block w-72 shrink-0 aspect-[4/5] bg-surface-container-highest rounded-2xl overflow-hidden shadow-2xl">
                    <img class="w-full h-full object-cover grayscale opacity-80" src="/images/sorunlar/hormonal-cycles.webp" alt="Açıklanamayan infertilite" width="512" height="512" loading="eager" fetchpriority="high"/>
                </div>
            </div>
        </header>

        <!-- Introduction -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed font-body italic mb-12">
                Açıklanamayan infertilite, standart tanı testlerinde herhangi bir belirgin neden bulunamamasına rağmen gebelik oluşmamasıdır. İnfertilite vakalarının %10-15'i bu kategoriye girer. Ancak bu, problemin olmadığı anlamına gelmez; gözardı edilen veya saptanmayan faktörler vardır.
            </p>
            <StatsStrip items={[
              { icon: 'question_mark', heading: '%10-15', text: 'İnfertilite vakalarında açıklanamayan durum' },
              { icon: 'search', heading: 'Gizli Faktörler', text: 'Saptanmayan endometriozis, oosit kalitesi' },
              { icon: 'biotech', heading: 'Tedavi', text: 'IVF sıklıkla etkili çözüm sunuyor' }
            ]} />
        </section>

        <!-- Gizli Faktörler -->
        <section class="bg-surface-container-low py-24 mb-24">
            <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8">
                <h2 class="font-headline text-3xl text-on-surface mb-12">Gizli Nedenler</h2>
                <div class="space-y-6">
                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">layers</span>
                            Tanı Edilmemiş Endometriozis
                        </h4>
                        <p class="text-sm text-on-surface-variant">
                            Endometriozis tanısı, çoğu zaman laparoskopi (cerrahi inceleme) ile konur. Basit ultrasound ile saptanması zordur. Hafif endometriozis, infertiliteye neden olabilir ancak standart testlerde görülmeyebilir.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">dna</span>
                            Oosit (Yumurta) Kalitesi
                        </h4>
                        <p class="text-sm text-on-surface-variant">
                            Yumurta sayısı normal bile olsa, kalitesi düşük olabilir. Bu, hormon testleri veya ultrasound ile ölçülmez. IVF süresi bu sorunları ortaya çıkarabilir. Genetik anormallikler (anöploidi) gözlemlenemeyebilir.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">biotech</span>
                            Sperm DNA Fragmentasyonu
                        </h4>
                        <p class="text-sm text-on-surface-variant">
                            Semen analizi normal bile olsa, sperm DNA fragmentasyonu yüksek olabilir. Bu, IUI başarısını azaltır ama IVF/ICSI ile çözülebilir. Özel testler gerekir.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">science</span>
                            Implantasyon Kusurları
                        </h4>
                        <p class="text-sm text-on-surface-variant">
                            Embriyonun rahme tutunması (implantasyon) ile ilgili sorunlar (endometriyal alıcılık bozukluğu) tanısı kolay değildir. Endometrial taşma veya alıcılık testleri hâlâ araştırma aşamasındadır.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tedavi Seçenekleri -->
        <section class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 mb-24">
            <h2 class="font-headline text-3xl text-on-surface mb-12">Tedavi Yaklaşımları</h2>
            <div class="space-y-6 text-on-surface-variant">
                <p>
                    Açıklanamayan infertilitede <a href="/tani-sureci" class="text-primary hover:underline">kapsamlı tanı süreci</a> sonrası, tedavi seçenekleri şunlardır:
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-3">Bekleme ve İzlem</h4>
                        <p class="text-sm text-on-surface-variant">
                            Ilk 2-3 yıl içinde ~50% doğal gebelik sağlanabilir. Nisbeten genç ve impatient olmayan çiftler için uygun olabilir.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-3">Clomiphene/Letrozole + IUI</h4>
                        <p class="text-sm text-on-surface-variant">
                            Over stimülasyonu ve yapay inseminasyon (IUI). Başarı oranı ~15-20% per döngü. 3-6 döngü denenmesi tavsiye edilir.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-3">IVF/ICSI</h4>
                        <p class="text-sm text-on-surface-variant">
                            Gizli faktörleri ortaya çıkarır. Yumurta kalitesi, embriyo gelişimi ve implantasyon değerlendirilir. <a href="/tedavi-yontemleri" class="text-primary hover:underline">Tedavi yöntemleri</a> sayfasında detaylı bilgi bulabilirsiniz.
                        </p>
                    </div>

                    <div class="bg-white border-l-4 border-primary rounded-xl p-6">
                        <h4 class="font-bold text-on-surface text-sm mb-3">Endometriozis Cerrahisi</h4>
                        <p class="text-sm text-on-surface-variant">
                            Laparoskopi tanı amaçlı yapılabilir. Tespit edilen endometriozis cerrahi olarak tedavi edilir.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- İlgili Kaynaklar -->
        <RelatedContent items={[
          { href: '/tani-sureci', icon: 'assignment', title: 'Tanı Süreci', description: 'Kapsamlı infertilite değerlendirmesi' },
          { href: '/tedavi-yontemleri', icon: 'biotech', title: 'Tedavi Yöntemleri', description: 'IUI, IVF ve diğer seçenekler' },
          { href: '/kadin-infertilitesi', icon: 'woman', title: 'Kadın Faktörleri', description: 'Endometriozis ve diğer nedenler' }
        ]} />

        <!-- Doktor Onay -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8 mb-16">
            <div class="bg-surface-container-low p-8 rounded-2xl border-l-4 border-primary flex flex-col md:flex-row items-center gap-8">
                <div class="w-20 h-20 rounded-full overflow-hidden bg-surface-dim shrink-0">
                    <span class="material-symbols-outlined text-primary text-2xl">verified</span>
                </div>
                <div>
                    <p class="font-headline text-lg text-on-surface mb-1">Doç. Yayın Kurulu</p>
                    <p class="text-sm text-on-surface-variant">
                        Bu rehber, üreme sağlığı alanında uzman <strong class="text-primary">tupbebek.com yayın kurulu</strong> tarafından tıbbi açıdan incelenmiş ve onaylanmıştır.
                    </p>
                </div>
            </div>
        </section>

        <!-- Yasal Uyarı -->
        <section class="max-w-3xl mx-auto px-4 md:px-6 lg:px-8">
            <DisclaimerBar title="Yasal Uyarı">
                Bu rehber genel bilgilendirme amaçlıdır. Açıklanamayan infertilite hakkında kişisel kararlar için lütfen bir üreme sağlığı uzmanına danışınız. tupbebek.com, bu bilgilere dayanılarak alınan kararlardan sorumlu tutulamaz.
            </DisclaimerBar>
        </section>
    </main>

    <Footer />
</BaseLayout>
