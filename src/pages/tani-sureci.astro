---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="İnfertilite Tanı Süreci | tupbebek.com" description="Kadın ve erkek infertilite değerlendirmesi, hormon testleri, semen analizi, genetik tarama ve tanı yöntemleri hakkında adım adım rehber.">
    <Header />
    
    <main id="main-content" tabindex="-1" class="pt-24">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-20">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <span class="text-primary-600 font-semibold tracking-widest text-sm uppercase mb-4 block">Klinik Rehber</span>
                    <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6">
                        İnfertilite Tanı Süreci: <span class="text-primary-dim">Adım Adım Yol Haritası</span>
                    </h1>
                    <p class="text-lg text-gray-600 leading-relaxed max-w-xl mb-8">
                        Doğru tedavi, doğru teşhisle başlar. tupbebek.com olarak, tanı sürecinin her aşamasında bilimsel rigor ve hasta odaklı yaklaşımı birleştiriyoruz.
                    </p>
                    <div class="flex items-center gap-4 p-4 bg-gray-100 rounded-xl inline-flex">
                        <span class="material-symbols-outlined text-primary-600 text-2xl">verified</span>
                        <div>
                            <p class="text-sm font-bold text-gray-900">Yayın Kurulu</p>
                            <p class="text-xs text-gray-600 uppercase tracking-tighter">Tıbbi İnceleme</p>
                        </div>
                    </div>
                </div>
                <div class="relative">
                    <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl bg-gray-50">
                        <img alt="Medical Diagnosis Illustration" class="w-full h-full object-cover mix-blend-multiply opacity-90" src="/images/tani-sureci/dna-cells.webp" width="512" height="512" loading="eager" fetchpriority="high"/>
                    </div>
                    <div class="absolute -bottom-6 -left-6 bg-gray-50 p-6 rounded-2xl shadow-xl max-w-xs border border-gray-200">
                        <p class="text-primary-600 font-bold text-xl mb-1">98% Doğruluk</p>
                        <p class="text-xs text-gray-600 font-medium uppercase tracking-wider leading-tight">Modern laboratuvar teknikleri ile kesin sonuçlar</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process Timeline Section -->
        <section class="bg-gray-50 py-24">
            <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-headline font-bold text-gray-900 mb-4">Tanı Yolculuğunuz</h2>
                    <div class="w-24 h-1 bg-primary-600 mx-auto rounded-full"></div>
                </div>
                <!-- Bento Grid Process -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Step 1: Initial Consultation -->
                    <div class="md:col-span-2 bg-gray-50 p-10 rounded-3xl shadow-sm flex flex-col justify-between">
                        <div>
                            <div class="flex items-center gap-4 mb-6">
                                <span class="w-10 h-10 rounded-full bg-primary-50 text-primary-800 flex items-center justify-center font-bold">01</span>
                                <h3 class="text-2xl font-headline font-bold">İlk Görüşme (Initial Consultation)</h3>
                            </div>
                            <p class="text-gray-600 leading-relaxed mb-6">
                                Sürecin en kritik aşamasıdır. Doktorunuzla yapacağınız bu görüşmede, tıbbi geçmişiniz, yaşam tarzınız ve önceki denemeleriniz detaylıca analiz edilir. Bu aşama, kişiselleştirilmiş bir tanı planının temelini oluşturur.
                            </p>
                            <ul class="space-y-4 mb-8">
                                <li class="flex items-start gap-4">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary-600 mt-2 flex-shrink-0"></span>
                                    <span class="text-sm font-medium">Tıbbi Özgeçmiş Analizi</span>
                                </li>
                                <li class="flex items-start gap-4">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary-600 mt-2 flex-shrink-0"></span>
                                    <span class="text-sm font-medium">Fiziksel Muayene</span>
                                </li>
                                <li class="flex items-start gap-4">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary-600 mt-2 flex-shrink-0"></span>
                                    <span class="text-sm font-medium">Psikolojik Destek Planlaması</span>
                                </li>
                            </ul>
                        </div>
                        <img alt="Consultation" class="rounded-2xl h-48 w-full object-cover" src="/images/tani-sureci/consultation.webp" width="512" height="512" loading="lazy"/>
                    </div>
                    <!-- Step 2: Male Evaluation -->
                    <div class="bg-gray-50 p-10 rounded-3xl shadow-sm">
                        <div class="flex items-center gap-4 mb-6">
                            <span class="w-10 h-10 rounded-full bg-gray-100 text-gray-700 flex items-center justify-center font-bold">02</span>
                            <h3 class="text-2xl font-headline font-bold">Erkek Değerlendirmesi</h3>
                        </div>
                        <p class="text-sm text-gray-600 leading-relaxed mb-6">
                            Erkek fertilitesi, infertilite vakalarının yaklaşık %40'ını oluşturur. Temel test olan Sperm Analizi (Spermiogram), Dünya Sağlık Örgütü (WHO) kriterlerine göre değerlendirilir.
                        </p>
                        <div class="bg-gray-100 p-6 rounded-2xl mb-6">
                            <h4 class="text-xs font-bold uppercase tracking-widest mb-3 text-primary-600">Analiz Parametreleri</h4>
                            <div class="space-y-2">
                                <div class="flex justify-between text-xs"><span>Sayı</span><span class="font-bold">15 Milyon+</span></div>
                                <div class="flex justify-between text-xs"><span>Hareketlilik</span><span class="font-bold">%40+</span></div>
                                <div class="flex justify-between text-xs"><span>Morfoloji</span><span class="font-bold">%4+ (Kruger)</span></div>
                            </div>
                        </div>
                        <span class="material-symbols-outlined text-4xl text-primary-200">biotech</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Next Steps Section -->
        <section class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-24">
            <div class="bg-primary-600 rounded-[3rem] p-12 lg:p-20 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-1/2 h-full opacity-10">
                    <img alt="Medical Texture" class="w-full h-full object-cover" src="/images/tani-sureci/abstract-cells.webp" width="512" height="512" loading="lazy"/>
                </div>
                <div class="relative z-10 max-w-2xl">
                    <h2 class="text-4xl lg:text-5xl font-headline font-bold mb-6">Sonraki Adımlar</h2>
                    <p class="text-lg opacity-90 mb-10 leading-relaxed">
                        Tanı süreci tamamlandığında, elde edilen tüm veriler yayın kurulumuz tarafından multidisipliner bir yaklaşımla değerlendirilir. Size özel tedavi protokolü (IVF, IUI veya İlaç Tedavisi) bu aşamadan sonra belirlenir.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="/tedavi-yontemleri" class="bg-white text-primary-600 px-8 py-4 rounded-xl font-bold hover:bg-gray-100 transition-all inline-block">Tedavi Yöntemlerini İncele</a>
                        <button class="border border-white/30 text-white px-8 py-4 rounded-xl font-bold hover:bg-gray-100/10 transition-all">Danışmanlık Al</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
